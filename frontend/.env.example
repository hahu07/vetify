# Real Party ID strings from the target Canton ledger — must match the same
# parties the backend is configured with (backend/.env.example's
# CANTON_*_PARTY_ID). Obtain by allocating each party once against the
# participant (POST /v2/parties {"partyIdHint": "Business"}) and recording the
# resulting `party` string from the response.
VITE_BUSINESS_PARTY_ID=Business::...
VITE_VETIFY_PARTY_ID=Vetify::...
VITE_VERIFIER_PARTY_ID=Verifier::...
VITE_FI_PARTY_ID=FinancialInstitution::...
VITE_RISK_COMMITTEE_PARTY_ID=RiskCommittee::...
VITE_SENTINEL_PARTY_ID=Sentinel::...
VITE_ADVISOR_PARTY_ID=Advisor::...
VITE_ASSESSOR_PARTY_ID=Assessor::...
