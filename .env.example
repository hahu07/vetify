# Root-level env, read by `docker compose` only (not by backend/agents/frontend
# — each of those has its own .env, see docs/local-dev-startup.md).

# Host port docker-compose.yml publishes Postgres on. Defaults to 5432, but
# that's frequently already bound by a system-level Postgres on dev machines
# (`ss -ltnp | grep 5432` to check). If you set this, also update
# backend/.env's PQS_POSTGRES_PORT/APP_POSTGRES_PORT to match.
POSTGRES_HOST_PORT=5432
