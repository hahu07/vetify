-- | Stage 7-10: the full real-world Murabahah bundle.
--
-- Sequence: Wa'd -> Wakala -> AssetPurchaseRecord (+ Qabdh gate) ->
-- MurabahahProposal -> MurabahahContract (+ optional RahnAgreement) ->
-- RepaymentRecord x N (+ LatePaymentCharity if late) -> optional IbraRequest
-- -> CloseContract / DefaultContract.
--
-- Each contract corresponds to a distinct legal act required by AAOIFI
-- Standard No. 8 (Murabahah), No. 23 (Wakala), No. 39 (Rahn).
-- Leaf module — depends only on Vetify.Types.
module Vetify.Murabahah where

import Vetify.Types
import Vetify.Governance (OfficerRole(..), AuthorizedOfficer, AuthorizedSentinel, AuthorizedAdvisor, requireActiveOfficer, requireActiveSentinel, requireActiveAdvisor)

-- | State-machine enforcement: the single source of truth for legal
-- MurabahahStatus transitions, replacing ad hoc `assertMsg (status == X)`
-- checks that would otherwise be duplicated across FlagDelinquent,
-- ResumeActive, CloseContract, CloseDefaultedContract, and DefaultContract.
isValidMurabahahTransition : MurabahahStatus -> MurabahahStatus -> Bool
isValidMurabahahTransition Active     Delinquent = True
isValidMurabahahTransition Delinquent Active     = True
isValidMurabahahTransition Active     Completed  = True
isValidMurabahahTransition Delinquent Completed  = True
isValidMurabahahTransition Delinquent Defaulted  = True
isValidMurabahahTransition Defaulted  Completed  = True
-- An ambiguous delinquency signal (FlagForDelinquencyReview) escalates from
-- Active for a human sentinel to resolve, then either clears back to Active
-- or confirms into Delinquent.
isValidMurabahahTransition Active                 DelinquencyManualReview = True
isValidMurabahahTransition DelinquencyManualReview Active                 = True
isValidMurabahahTransition DelinquencyManualReview Delinquent             = True
isValidMurabahahTransition _          _          = False

-- | True if a payment made on `paymentDate` against an installment due
-- `dueDate` counts as late, honoring an active payment moratorium (which
-- suppresses lateness for payments made on or before the moratorium's end
-- date). Extracted from RecordPayment for readability.
isPaymentLate : Optional Date -> Date -> Date -> Bool
isPaymentLate activeMoratorium dueDate paymentDate =
  case activeMoratorium of
    Some endDate -> paymentDate > dueDate && paymentDate > endDate
    None         -> paymentDate > dueDate

-- | Validates a payment allocation's components are all non-negative, when
-- one is supplied. Extracted from RecordPayment for readability.
assertValidPaymentAllocation : Optional PaymentAllocation -> Update ()
assertValidPaymentAllocation allocation =
  case allocation of
    Some alloc ->
      assertMsg "Payment allocation components must be non-negative"
        (alloc.principalComponent >= 0.0 && alloc.profitComponent >= 0.0
          && alloc.feesCharged >= 0.0 && alloc.charityProvision >= 0.0)
    None -> return ()

-- | Named result for RecordPayment, in place of an anonymous 3-tuple.
data RecordPaymentResult = RecordPaymentResult
  with
    updatedContract   : ContractId MurabahahContract
    repaymentRecord   : ContractId RepaymentRecord
    charityObligation : Optional (ContractId LatePaymentCharity)
  deriving (Eq, Show)

-- | Named result for RecordGSMSweep, replacing an anonymous 3-tuple —
-- mirrors RecordPaymentResult's rationale above. Field names are distinct
-- from RecordPaymentResult's (Daml record field selectors are module-level
-- and cannot be reused across two records in the same module).
data GSMSweepResult = GSMSweepResult
  with
    updatedInvocation : ContractId GSMInvocation
    sweptContract     : ContractId MurabahahContract
    recoveryRecord    : ContractId RecoveryPaymentRecord
  deriving (Eq, Show)

-- | The payment schedule, extracted into its own contract — avoids embedding
-- the full `[PaymentScheduleEntry]` list in every version of
-- MurabahahContract and MurabahahProposal; accessed via ContractId instead.
-- Has no contract key, to avoid a key collision when an offer is declined
-- and retried, or when a facility is restructured.
template PaymentScheduleContract
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    regulator            : Optional Party
    facilityRef          : Text
    cacRegNumber         : Text
    entries              : [PaymentScheduleEntry]
  where
    signatory financialInstitution
    observer [business, vetify] ++ optional [] pure regulator
    ensure not (null entries)

-- ─── 1. Wa'd (Binding Promise to Purchase) ────────────────────────────────

-- | AAOIFI Std No. 8, §2/2: the client must make an irrevocable promise to
-- purchase the identified asset from the FI before the FI commits capital to
-- acquire it. Without the Wa'd there is no legitimate basis for the FI to
-- buy on the client's behalf.
template MurabahahWad
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    businessName         : Text
    cacRegNumber         : Text
    terms                : FinancingTerms
    assetDetails         : AssetDetails
    -- | Carries the financing reference from FinancingRequest for
    -- end-to-end traceability.
    financingRef         : Optional Text
    -- | Ledger time after which the Wa'd offer lapses.
    offerExpiresAt       : Optional Time
  where
    signatory business
    observer financialInstitution, vetify

    ensure assetDetails.estimatedCost > 0.0

    -- | vetify expires a Wa'd whose offer window has passed without FI action.
    choice ExpireWad : ()
      controller vetify
      do
        now <- getTime
        case offerExpiresAt of
          None -> assertMsg "No offer expiry configured on this Wa'd" False
          Some expiry -> assertMsg "Wa'd offer window has not yet elapsed" (now > expiry)
        return ()

    -- | Path A: the FI appoints the business as purchasing agent (Wakala).
    -- Most common in digital SME financing — the business knows the
    -- supplier.
    choice ProceedWithWakala : ContractId MurabahahWakala
      controller financialInstitution
      do
        create MurabahahWakala with
          business
          vetify
          financialInstitution
          businessName
          cacRegNumber
          terms
          assetDetails
          agencyFee = None

    -- | Path B: the FI purchases the asset directly from the supplier.
    choice ProceedDirectly : ContractId AssetPurchaseRecord
      with
        actualCost            : Decimal
        purchaseDate          : Date
        invoiceRef            : Text
        -- | 0.0 if not applicable.
        freightCost           : Decimal
        customsDuty           : Decimal
        insurancePremium      : Decimal
        -- | 0.0 if none.
        otherAcquisitionCosts : Decimal
      controller financialInstitution
      do
        assertMsg "Actual purchase cost must be positive" (actualCost > 0.0)
        let totalAcquisitionCost = actualCost + freightCost + customsDuty + insurancePremium + otherAcquisitionCosts
        create AssetPurchaseRecord with
          business
          vetify
          financialInstitution
          businessName
          cacRegNumber
          terms
          assetDetails
          actualCost
          purchaseDate
          invoiceRef
          freightCost
          customsDuty
          insurancePremium
          otherAcquisitionCosts
          totalAcquisitionCost
          purchasedViaWakala   = False
          deliveryAcknowledged = False
          ownershipDocuments   = []
          supplierDetails      = None
          additionalAssets     = []

    -- | The FI attaches the supplier's formal quotation before committing to
    -- the Wakala. Nonconsuming — the Wa'd stays active; the quotation is a
    -- side record.
    nonconsuming choice AttachQuotation : ContractId SupplierQuotation
      with
        supplierName  : Text
        quotationRef  : Text
        quotedAmount  : Decimal
        validUntil    : Optional Date
      controller financialInstitution
      do
        assertMsg "Quotation reference must not be empty" (quotationRef /= "")
        assertMsg "Quoted amount must be positive" (quotedAmount > 0.0)
        assertMsg "Supplier name must not be empty" (supplierName /= "")
        create SupplierQuotation with
          financialInstitution; vetify; business
          businessName; cacRegNumber
          supplierName; quotationRef; quotedAmount; validUntil
          assetDescription = assetDetails.description

    -- | The business withdraws the promise, e.g. supplier unavailable or
    -- changed circumstances. Off-ledger consequences (cost recovery) are
    -- handled by the FI's policy.
    choice WithdrawWad : ()
      with reason : Text
      controller business
      do
        assertMsg "Reason must not be empty" (reason /= "")
        t <- getTime
        create WadWithdrawalRecord with
          business; financialInstitution; vetify
          businessName; cacRegNumber; reason
          withdrawnAt = t
        return ()


-- ─── 2. Wakala (Agency Agreement) ─────────────────────────────────────────

-- | AAOIFI Std No. 23: the FI appoints the business as its purchasing agent.
-- Ownership of the asset vests in the FI the moment the business-as-agent
-- completes the purchase — not in the business personally.
template MurabahahWakala
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    businessName         : Text
    cacRegNumber         : Text
    terms                : FinancingTerms
    assetDetails         : AssetDetails
    -- | `None` = gratuitous (standard Nigerian practice).
    agencyFee            : Optional Decimal
  where
    signatory financialInstitution
    observer business, vetify

    -- | The business, as agent, records the completed asset purchase.
    -- Exercising this choice constitutes both acceptance of the agency and
    -- delivery of the purchase evidence to the FI.
    choice RecordAssetPurchase : ContractId AssetPurchaseRecord
      with
        actualCost            : Decimal
        purchaseDate          : Date
        invoiceRef            : Text
        freightCost           : Decimal
        customsDuty           : Decimal
        insurancePremium      : Decimal
        otherAcquisitionCosts : Decimal
      controller business
      do
        assertMsg "Actual purchase cost must be positive" (actualCost > 0.0)
        let totalAcquisitionCost = actualCost + freightCost + customsDuty + insurancePremium + otherAcquisitionCosts
        create AssetPurchaseRecord with
          business
          vetify
          financialInstitution
          businessName
          cacRegNumber
          terms
          assetDetails
          actualCost
          purchaseDate
          invoiceRef
          freightCost
          customsDuty
          insurancePremium
          otherAcquisitionCosts
          totalAcquisitionCost
          purchasedViaWakala   = True
          deliveryAcknowledged = False
          ownershipDocuments   = []
          supplierDetails      = None
          additionalAssets     = []

    -- | The business declines the agency appointment; the FI must buy
    -- directly.
    choice DeclineAgency : ()
      with reason : Text
      controller business
      do
        assertMsg "Reason must not be empty" (reason /= "")
        t <- getTime
        create AgencyWithdrawalRecord with
          business; financialInstitution; vetify
          businessName; cacRegNumber; reason
          declinedAt = t
        return ()


-- ─── 3. AssetPurchaseRecord + Qabdh gate ──────────────────────────────────

-- | Immutable evidence that the FI (directly or via Wakala) owns the asset.
-- AAOIFI Std No. 8, §3/1: the FI cannot sell what it does not own. The
-- two-step design enforces the Shariah sequence: (a) FI ownership is
-- recorded first; (b) the business acknowledges receipt/constructive
-- possession (Qabdh) second; (c) only after both can the FI make the sale
-- offer (MurabahahProposal).
template AssetPurchaseRecord
  with
    business                : Party
    vetify                  : Party
    financialInstitution    : Party
    businessName            : Text
    cacRegNumber            : Text
    terms                   : FinancingTerms
    assetDetails            : AssetDetails
    -- | Direct purchase price paid to the supplier.
    actualCost              : Decimal
    purchaseDate            : Date
    invoiceRef              : Text
    freightCost             : Decimal
    customsDuty             : Decimal
    insurancePremium        : Decimal
    otherAcquisitionCosts   : Decimal
    -- | `= actualCost + freight + duty + insurance + other` (AAOIFI §3/3).
    totalAcquisitionCost    : Decimal
    purchasedViaWakala      : Bool
    deliveryAcknowledged    : Bool
    -- | Title documents, bills of lading, warehouse receipts.
    ownershipDocuments      : [DocumentRef]
    -- | Supplier identity and contact.
    supplierDetails         : Optional SupplierDetails
    -- | Secondary assets or suppliers in the same transaction.
    additionalAssets        : [AssetLineItem]
  where
    signatory financialInstitution
    observer business, vetify

    ensure actualCost > 0.0
        && freightCost >= 0.0
        && customsDuty >= 0.0
        && insurancePremium >= 0.0
        && otherAcquisitionCosts >= 0.0
        && totalAcquisitionCost == actualCost + freightCost + customsDuty + insurancePremium + otherAcquisitionCosts

    -- | The business confirms constructive or actual possession of the
    -- asset (Qabdh). Required before the FI can make the Murabahah sale
    -- offer.
    choice AcknowledgeDelivery : ContractId AssetPurchaseRecord
      controller business
      do
        assertMsg "Delivery already acknowledged" (not deliveryAcknowledged)
        create this with deliveryAcknowledged = True

    -- | The business rejects a defective or incorrect asset before
    -- accepting delivery. Nonconsuming — the AssetPurchaseRecord stays
    -- live; the FI must replace the asset or the parties must agree to
    -- cancel via RequestCancellation -> ConfirmCancellation.
    nonconsuming choice RejectDelivery : ContractId AssetRejectionRecord
      with
        reason            : Text
        defectDescription : Text
      controller business
      do
        assertMsg "Cannot reject an already-acknowledged delivery" (not deliveryAcknowledged)
        assertMsg "Rejection reason must not be empty" (reason /= "")
        t <- getTime
        create AssetRejectionRecord with
          business
          vetify
          financialInstitution
          businessName
          cacRegNumber
          reason
          defectDescription
          rejectedAt = t

    -- | The FI supplies a replacement asset after a business rejection.
    -- Consuming — archives the old purchase record and creates a fresh one
    -- with corrected asset details. Ancillary costs reset to 0.0; the FI
    -- may update them via the new AssetPurchaseRecord's choices.
    choice ProceedWithReplacement : ContractId AssetPurchaseRecord
      with
        newActualCost   : Decimal
        newPurchaseDate : Date
        newInvoiceRef   : Text
        replacementNote : Text
      controller financialInstitution
      do
        assertMsg "Replacement cost must be positive" (newActualCost > 0.0)
        assertMsg "Invoice reference must not be empty" (newInvoiceRef /= "")
        assertMsg "Replacement note must not be empty" (replacementNote /= "")
        create this with
          actualCost            = newActualCost
          purchaseDate          = newPurchaseDate
          invoiceRef            = newInvoiceRef
          freightCost           = 0.0
          customsDuty           = 0.0
          insurancePremium      = 0.0
          otherAcquisitionCosts = 0.0
          totalAcquisitionCost  = newActualCost
          deliveryAcknowledged  = False

    -- | The business initiates deal cancellation after a failed rejection,
    -- e.g. the FI cannot source a suitable replacement. Nonconsuming — the
    -- AssetPurchaseRecord stays live until the FI confirms.
    nonconsuming choice RequestCancellation : ContractId AcquisitionCancellationRequest
      with reason : Text
      controller business
      do
        assertMsg "Cancellation reason must not be empty" (reason /= "")
        create AcquisitionCancellationRequest with
          business; vetify; financialInstitution; businessName; cacRegNumber; reason

    -- | The FI accepts the cancellation — archives the request via its own
    -- choice, then archives this purchase record.
    choice ConfirmCancellation : ()
      with reqCid : ContractId AcquisitionCancellationRequest
      controller financialInstitution
      do
        exercise reqCid AcceptCancellation
        return ()

    -- | The FI formally offers the asset at cost plus disclosed profit
    -- (Ijab). Gated by Qabdh: the business must have acknowledged delivery
    -- first. AAOIFI Std No. 8, §3/3: the disclosed cost must equal the
    -- total acquisition cost.
    choice OfferMurabahah : ContractId MurabahahProposal
      with
        murabahahTerms        : MurabahahTerms
        paymentSchedule       : [PaymentScheduleEntry]
        regulator             : Optional Party
        -- | The Shari'a Supervisory Board party that will certify the
        -- executed terms.
        advisor               : Party
        -- | Unique facility identifier for the MurabahahContract key.
        facilityRef           : Text
        startDate             : Date
        -- | When the business's acceptance window closes.
        acceptanceExpiresAt   : Optional Time
      controller financialInstitution
      do
        assertMsg "Delivery must be acknowledged (Qabdh) before making the sale offer"
          deliveryAcknowledged
        assertMsg "Disclosed cost must match total acquisition cost (AAOIFI §3/3)"
          (murabahahTerms.assetCost == totalAcquisitionCost)
        assertMsg "Disclosed profit invariant: salePrice must equal assetCost + profitAmount"
          (murabahahTerms.salePrice == murabahahTerms.assetCost + murabahahTerms.profitAmount)
        assertMsg "Profit must be non-negative" (murabahahTerms.profitAmount >= 0.0)
        assertMsg "Payment schedule length must match tenure"
          (length paymentSchedule == murabahahTerms.tenureMonths)
        assertMsg "Facility reference must not be empty" (facilityRef /= "")
        let fRef = facilityRef  -- bind locally to avoid field-selector ambiguity
        -- If an acceptance window is set it must be in the future.
        case acceptanceExpiresAt of
          Some expiry -> do
            t <- getTime
            assertMsg "acceptanceExpiresAt must be in the future" (expiry > t)
          None -> return ()
        schedCid <- create PaymentScheduleContract with
          financialInstitution = financialInstitution
          vetify               = vetify
          business             = business
          regulator            = regulator
          facilityRef          = fRef
          cacRegNumber         = cacRegNumber
          entries              = paymentSchedule
        create MurabahahProposal with
          business             = business
          vetify               = vetify
          financialInstitution = financialInstitution
          advisor              = advisor
          regulator            = regulator
          facilityRef          = fRef
          businessName         = businessName
          cacRegNumber         = cacRegNumber
          terms                = terms
          assetDetails         = assetDetails
          actualCost           = totalAcquisitionCost  -- AAOIFI §3/3: proposal carries total cost
          murabahahTerms       = murabahahTerms
          paymentScheduleCid   = schedCid
          startDate            = startDate
          acceptanceExpiresAt  = acceptanceExpiresAt

    -- | The business records receipt of a partial delivery milestone during
    -- the Wakala phase. Nonconsuming — the AssetPurchaseRecord stays active
    -- until full Qabdh is acknowledged.
    nonconsuming choice RecordDeliveryMilestone : ContractId DeliveryMilestone
      with
        milestoneDescription : Text
        quantityDelivered    : Decimal
        milestoneDate        : Date
        evidenceRef          : Optional Text
      controller business
      do
        assertMsg "Cannot record milestone after delivery is fully acknowledged"
          (not deliveryAcknowledged)
        assertMsg "Milestone description must not be empty" (milestoneDescription /= "")
        assertMsg "Quantity delivered must be positive" (quantityDelivered > 0.0)
        create DeliveryMilestone with
          financialInstitution
          vetify
          business
          businessName
          cacRegNumber
          milestoneDescription
          quantityDelivered
          milestoneDate
          evidenceRef

    -- | The FI records that the supplier failed (cancellation, insolvency,
    -- non-delivery). Consuming — archives the AssetPurchaseRecord; the
    -- Wakala sub-flow must restart.
    choice RecordSupplierFailure : ContractId SupplierFailureRecord
      with
        failureType        : SupplierFailureType
        failureDescription : Text
        refundAmount       : Optional Decimal
      controller financialInstitution
      do
        assertMsg "Failure description must not be empty" (failureDescription /= "")
        t <- getTime
        create SupplierFailureRecord with
          financialInstitution
          vetify
          business
          businessName
          cacRegNumber
          failureType
          failureDescription
          refundAmount
          failedAt = t

    -- | The FI records proof of payment to the supplier — separate from the
    -- business-to-FI RepaymentRecord. Nonconsuming: the purchase record
    -- stays active.
    nonconsuming choice RecordSupplierPayment : ContractId SupplierPaymentRecord
      with
        amountPaid          : Decimal
        paymentDate         : Date
        paymentRef          : Text
        bankConfirmationRef : Optional Text
      controller financialInstitution
      do
        assertMsg "Payment amount must be positive" (amountPaid > 0.0)
        assertMsg "Payment reference must not be empty" (paymentRef /= "")
        create SupplierPaymentRecord with
          financialInstitution
          vetify
          business
          businessName
          cacRegNumber
          supplierDetails
          amountPaid
          paymentDate
          paymentRef
          bankConfirmationRef
          purchasedViaWakala

    -- | Registers a document against this facility; creates an immutable
    -- DocumentEntry for lifecycle management (verify, supersede).
    nonconsuming choice RegisterDocument : ContractId DocumentEntry
      with
        documentRef  : DocumentRef
        registeredBy : Text
      controller financialInstitution
      do
        assertMsg "Registered-by name must not be empty" (registeredBy /= "")
        t <- getTime
        create DocumentEntry with
          financialInstitution; vetify; business
          businessName; cacRegNumber
          documentRef; registeredBy
          uploadedAt = t
          verifiedAt = None
          superseded = False


-- ─── 4. MurabahahProposal (Ijab — formal sale offer) ─────────────────────

-- | The FI's formal offer to sell the asset at cost plus disclosed profit.
-- The regulator does not observe the proposal — only the accepted contract.
template MurabahahProposal
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    -- | The genuinely independent Shari'a Supervisory Board party (AAOIFI
    -- GSIFI No. 1/2). Certifies the executed terms below.
    advisor              : Party
    regulator            : Optional Party
    -- | Unique facility identifier, threaded to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    terms                : FinancingTerms
    assetDetails         : AssetDetails
    -- | Total acquisition cost (AAOIFI §3/3); passed from OfferMurabahah.
    actualCost           : Decimal
    murabahahTerms       : MurabahahTerms
    paymentScheduleCid   : ContractId PaymentScheduleContract
    startDate            : Date
    -- | When the business's acceptance window closes; `None` = no expiry.
    acceptanceExpiresAt  : Optional Time
  where
    signatory financialInstitution
    observer business, vetify, advisor

    ensure murabahahTerms.salePrice == murabahahTerms.assetCost + murabahahTerms.profitAmount
        && murabahahTerms.profitAmount >= 0.0
        && murabahahTerms.assetCost > 0.0
        && murabahahTerms.installmentAmount > 0.0
        && murabahahTerms.assetCost == actualCost

    -- | The advisor (Shari'a Supervisory Board) certifies the executed
    -- terms of this proposal — the actual sale price, disclosed cost,
    -- profit amount, and tenure the business is about to be bound to —
    -- closing the AAOIFI GSIFI No. 1/2 governance loop that the Stage-3
    -- sector pre-check alone does not (that only clears the business's
    -- line of activity, not the financial structure of a specific
    -- facility). Nonconsuming: the proposal stays live for acceptance.
    --
    -- Controller `advisor, vetify`: advisor makes the real call; vetify
    -- co-signs since ComplianceReview-style dual-controller authorization —
    -- identical rationale to RecordShariahPreCheck.
    nonconsuming choice CertifyShariahTerms : ContractId ShariahContractCertification
      with
        certificationRef : Text
        aaoifiStandards  : [Text]
        rationale        : Text
        -- | The SSB member/scholar signing off (audit attribution).
        certifiedBy      : Text
        -- | The registered AuthorizedAdvisor entry for `advisor` —
        -- caller-supplied, since SDK 3.4.11 / Daml-LF 2.1/2.2 does not
        -- support contract keys.
        advisorCid       : ContractId AuthorizedAdvisor
      controller advisor, vetify
      do
        requireActiveAdvisor vetify advisor advisorCid
        assertMsg "Certification reference must not be empty" (certificationRef /= "")
        assertMsg "Certifying scholar/member must be named" (certifiedBy /= "")
        now <- getTime
        create ShariahContractCertification with
          advisor
          business
          financialInstitution
          vetify
          facilityRef
          businessName
          cacRegNumber
          certifiedSalePrice    = murabahahTerms.salePrice
          certifiedAssetCost    = murabahahTerms.assetCost
          certifiedProfitAmount = murabahahTerms.profitAmount
          certifiedTenureMonths = murabahahTerms.tenureMonths
          certificationRef
          verdict               = "COMPLIANT"
          aaoifiStandards
          rationale
          certifiedBy
          certifiedAt           = now

    -- | The business accepts (Qabul), forming the bilateral binding
    -- contract. `sentinel` is a choice argument — not threaded through the
    -- Wa'd/Wakala/AssetPurchaseRecord/Proposal chain the way vetify/
    -- regulator are — because the backend supplies it from its own config
    -- at submission time, the same as any other structured argument the
    -- business's own session wouldn't organically know; this avoids
    -- rippling a Stage-9-only party through every earlier acquisition-chain
    -- template.
    --
    -- A valid advisor certification of these terms is a hard gate: the
    -- business cannot execute a contract whose sale price, profit, cost, or
    -- tenure the SSB has not signed off on. A revoked or stale
    -- certification (terms since changed) fails the fetch or the equality
    -- checks below, so acceptance is blocked.
    choice AcceptProposal : ContractId MurabahahContract
      with
        sentinel         : Party
        certificationCid : ContractId ShariahContractCertification
      controller business
      do
        cert <- fetch certificationCid
        assertMsg "Certification is for a different facility"
          (cert.facilityRef == facilityRef)
        assertMsg "Certification was issued by a different advisor than this proposal's"
          (cert.advisor == advisor)
        assertMsg "Certification verdict is not COMPLIANT"
          (cert.verdict == "COMPLIANT")
        assertMsg "Certified sale price does not match the proposal's terms"
          (cert.certifiedSalePrice == murabahahTerms.salePrice)
        assertMsg "Certified profit amount does not match the proposal's terms"
          (cert.certifiedProfitAmount == murabahahTerms.profitAmount)
        assertMsg "Certified asset cost does not match the proposal's terms"
          (cert.certifiedAssetCost == murabahahTerms.assetCost)
        assertMsg "Certified tenure does not match the proposal's terms"
          (cert.certifiedTenureMonths == murabahahTerms.tenureMonths)
        create MurabahahContract with
          business
          vetify
          financialInstitution
          regulator
          sentinel
          facilityRef
          businessName
          cacRegNumber
          terms
          assetDetails
          murabahahTerms
          paymentScheduleCid
          startDate
          outstandingBalance     = murabahahTerms.salePrice
          installmentsPaid       = 0
          pendingInstallmentPaid = 0.0
          status                 = Active
          activeMoratorium       = None
          scheduleVersion        = 1
          restructuringCount     = 0
          shariahCertificationRef = cert.certificationRef
          shariahCertifiedBy      = cert.certifiedBy

    -- | The business declines the offered terms.
    choice DeclineProposal : ()
      with reason : Text
      controller business
      do
        assertMsg "Reason must not be empty" (reason /= "")
        t <- getTime
        create ProposalDeclineRecord with
          business; financialInstitution; vetify
          businessName; cacRegNumber; facilityRef; reason
          declinedAt = t
        return ()

    -- | vetify expires a proposal whose acceptance window has elapsed.
    choice ExpireProposal : ()
      controller vetify
      do
        now <- getTime
        case acceptanceExpiresAt of
          None -> assertMsg "No acceptance expiry configured on this proposal" False
          Some expiry -> assertMsg "Proposal acceptance window has not yet elapsed" (now > expiry)
        return ()

    -- | The FI withdraws its offer before the business responds.
    choice WithdrawProposal : ()
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Withdrawal reason must not be empty" (reason /= "")
        return ()


-- ─── 4b. ShariahContractCertification (per-contract SSB sign-off) ─────────

-- | The advisor's (Shari'a Supervisory Board's) certification of the exact
-- financial structure of a specific facility — its disclosed cost, profit,
-- sale price, and tenure — created via CertifyShariahTerms on the
-- corresponding MurabahahProposal. AcceptProposal fetches this and
-- hard-checks that its snapshot still matches the proposal's terms, so the
-- business cannot execute a contract the SSB has not signed off on. Closes
-- the AAOIFI GSIFI No. 1/2 execution-time governance loop that the Stage-3
-- sector pre-check alone leaves open.
template ShariahContractCertification
  with
    advisor               : Party
    business              : Party
    financialInstitution  : Party
    vetify                : Party
    facilityRef           : Text
    businessName          : Text
    cacRegNumber          : Text
    certifiedSalePrice    : Decimal
    certifiedAssetCost    : Decimal
    certifiedProfitAmount : Decimal
    certifiedTenureMonths : Int
    certificationRef      : Text
    -- | "COMPLIANT" — only a compliant certification can gate acceptance.
    verdict               : Text
    -- | E.g. ["Std No. 8", "Std No. 40"].
    aaoifiStandards       : [Text]
    rationale             : Text
    -- | SSB scholar/member name (audit attribution).
    certifiedBy           : Text
    certifiedAt           : Time
  where
    signatory advisor
    observer business, financialInstitution, vetify
    ensure certificationRef /= "" && certifiedBy /= ""
        && certifiedSalePrice == certifiedAssetCost + certifiedProfitAmount

    -- | The advisor withdraws a certification, e.g. terms changed after
    -- sign-off, or an error is discovered before acceptance. Archiving it
    -- makes AcceptProposal's fetch fail, blocking execution until a fresh
    -- certification is issued. Creates an immutable revocation record for
    -- the audit trail.
    choice RevokeCertification : ContractId ShariahCertificationRevocation
      with
        revocationRef : Text
        reason        : Text
        revokedBy     : Text
      controller advisor
      do
        assertMsg "Revocation reference must not be empty" (revocationRef /= "")
        assertMsg "Revocation reason must not be empty" (reason /= "")
        assertMsg "Revoking member must be named" (revokedBy /= "")
        now <- getTime
        create ShariahCertificationRevocation with
          advisor; business; financialInstitution; vetify
          facilityRef; businessName; cacRegNumber
          originalCertificationRef = certificationRef
          revocationRef; reason; revokedBy
          revokedAt = now


-- | Immutable audit record created when an advisor revokes a certification.
template ShariahCertificationRevocation
  with
    advisor                  : Party
    business                 : Party
    financialInstitution     : Party
    vetify                   : Party
    facilityRef              : Text
    businessName             : Text
    cacRegNumber             : Text
    originalCertificationRef : Text
    revocationRef            : Text
    reason                   : Text
    revokedBy                : Text
    revokedAt                : Time
  where
    signatory advisor
    observer business, financialInstitution, vetify


-- ─── 5. MurabahahContract (Active bilateral contract) ─────────────────────

-- | Signed by both business and financialInstitution. The regulator observes
-- this contract and all RepaymentRecords.
template MurabahahContract
  with
    business               : Party
    vetify                 : Party
    financialInstitution   : Party
    regulator              : Optional Party
    -- | Stage 9: vetify's own portfolio-monitoring team.
    sentinel               : Party
    -- | Unique per `(business, financialInstitution)`; part of the contract
    -- key.
    facilityRef            : Text
    businessName           : Text
    cacRegNumber           : Text
    terms                  : FinancingTerms
    assetDetails           : AssetDetails
    murabahahTerms         : MurabahahTerms
    paymentScheduleCid     : ContractId PaymentScheduleContract
    startDate              : Date
    outstandingBalance     : Decimal
    installmentsPaid       : Int
    -- | Accumulates partial payments for the current installment.
    pendingInstallmentPaid : Decimal
    status                 : MurabahahStatus
    -- | If `Some d`, payments on/before `d` suppress the `wasLate` flag.
    activeMoratorium       : Optional Date
    -- | Incremented on ApproveRestructuring.
    scheduleVersion        : Int
    -- | Checked against `UnderwritingPolicy.maxRestructuringsPerFacility`.
    restructuringCount     : Int
    -- | The advisor's ShariahContractCertification.certificationRef that
    -- gated this execution (regulator-observable examiner proof).
    shariahCertificationRef : Text
    -- | The SSB scholar/member who signed off on these terms.
    shariahCertifiedBy      : Text
  where
    signatory business, financialInstitution
    observer [vetify, sentinel] ++ optional [] pure regulator

    -- No contract key (Daml-LF 2.1/2.2, SDK 3.4.11, does not support
    -- contract keys): ledger-enforced uniqueness of
    -- (business, financialInstitution, facilityRef) is no longer
    -- guaranteed.

    ensure murabahahTerms.salePrice == murabahahTerms.assetCost + murabahahTerms.profitAmount
        && outstandingBalance >= 0.0
        && installmentsPaid >= 0
        && pendingInstallmentPaid >= 0.0
        && facilityRef /= ""
        && scheduleVersion >= 1
        && restructuringCount >= 0

    -- | The FI records a repayment installment. Guards: amount > 0, no
    -- overpayment, strict sequence. Status is preserved — a partial payment
    -- does not auto-cure delinquency. Creates a LatePaymentCharity if
    -- `paymentDate > dueDate` (AAOIFI Std No. 8, §2/4/20).
    choice RecordPayment : RecordPaymentResult
      with
        paymentDate       : Date
        amountPaid        : Decimal
        installmentNo     : Int
        -- | Principal/profit/fee breakdown.
        allocation        : Optional PaymentAllocation
        -- | Repayment bank account or wallet.
        settlementAccount : Optional SettlementAccount
        -- | mono.co collection ref; `None` = manual.
        directDebitRef    : Optional Text
        -- | An existing active PaymentIdempotencyGuard for
        -- `(financialInstitution, directDebitRef)`, if the caller found one
        -- via a PQS query before submitting this exercise — caller-supplied,
        -- since SDK 3.4.11 / Daml-LF 2.1/2.2 does not support contract keys.
        -- `Some` here always fails the transaction (see below); the
        -- argument exists so the caller doesn't have to guess `None` and
        -- rely on this choice alone to catch the duplicate.
        existingGuardCid  : Optional (ContractId PaymentIdempotencyGuard)
      controller financialInstitution
      do
        assertMsg "Can only record payment on an Active or Delinquent contract"
          (status == Active || status == Delinquent)
        assertMsg "Payment amount must be positive" (amountPaid > 0.0)
        assertMsg "Payment exceeds outstanding balance" (amountPaid <= outstandingBalance)
        assertMsg "Installment number out of sequence" (installmentNo == installmentsPaid + 1)
        -- Idempotency: reject a replayed off-ledger payment reference.
        -- NOT atomic on SDK 3.4.11 / Daml-LF 2.1/2.2 (no contract keys): two
        -- concurrent RecordPayment calls with the same directDebitRef could
        -- each see `existingGuardCid = None` and both proceed to create a
        -- PaymentIdempotencyGuard, defeating the dedup — a real, accepted
        -- regression from the SDK 3.5.1 key-backed version. The caller
        -- (backend) is expected to query PQS for an existing guard
        -- immediately before submitting this exercise, which closes the
        -- race in the common (non-concurrent) case but not fully.
        case directDebitRef of
          Some ref -> do
            assertMsg "Duplicate payment reference (directDebitRef already processed)"
              (existingGuardCid == None)
            _ <- create PaymentIdempotencyGuard with financialInstitution; directDebitRef = ref
            return ()
          None -> return ()
        sched <- fetch paymentScheduleCid
        let entry = find (\e -> e.installmentNo == installmentNo) sched.entries
        case entry of
          None -> assertFail "Installment not found in payment schedule"
          Some e -> do
            let newBalance          = outstandingBalance - amountPaid
            let totalForInstallment = pendingInstallmentPaid + amountPaid
            let installmentComplete = totalForInstallment >= e.dueAmount
            let isLate = isPaymentLate activeMoratorium e.dueDate paymentDate
            assertValidPaymentAllocation allocation
            -- Advance installmentsPaid only when the full due amount is
            -- accumulated.
            let (newInstallmentsPaid, newPendingPaid) =
                  if installmentComplete
                    then (installmentsPaid + 1, 0.0)
                    else (installmentsPaid, totalForInstallment)
            updated <- create this with
              outstandingBalance     = newBalance
              installmentsPaid       = newInstallmentsPaid
              pendingInstallmentPaid = newPendingPaid
            record <- create RepaymentRecord with
              business; vetify; financialInstitution; regulator
              facilityRef; businessName; cacRegNumber
              installmentNo
              dueDate          = e.dueDate
              paymentDate
              amountPaid
              remainingBalance = newBalance
              wasLate          = isLate
              allocation
              settlementAccount
              directDebitRef
            -- Sadaqah only on the completing payment of a late installment
            -- (AAOIFI Std No. 8, §2/4/20).
            charityObligation <-
              if isLate && installmentComplete
                then do
                  cid <- create LatePaymentCharity with
                    business; vetify; financialInstitution
                    businessName; cacRegNumber
                    installmentNo
                    dueDate       = e.dueDate
                    paymentDate
                    charityAmount = None
                    settled       = False
                  return (Some cid)
                else return None
            return RecordPaymentResult with
              updatedContract   = updated
              repaymentRecord   = record
              charityObligation

    -- | The sentinel (vetify's own portfolio-monitoring team) makes the
    -- real delinquency call, deterministically scored off-ledger
    -- (agents/src/scoring/monitoring.ts) — mirrors the assessor's real
    -- decision authority over Stage 6.
    --
    -- Dual controller `sentinel, vetify`: not a `lookupByKey` need this
    -- time, but the atomic AuditEvent creation below is signed vetify, and
    -- MurabahahContract's own signatories are business/financialInstitution
    -- — vetify's authority isn't free here and must be an explicit
    -- controller (the same rationale class as BeginUnderwriting's dual
    -- controller). `requireActiveSentinel` fails closed if sentinel isn't a
    -- currently registered, active AuthorizedSentinel.
    choice FlagDelinquent : (ContractId MurabahahContract, ContractId AuditEvent)
      with
        reason      : Text
        -- | The registered AuthorizedSentinel entry for `sentinel` —
        -- caller-supplied, since SDK 3.4.11 / Daml-LF 2.1/2.2 does not
        -- support contract keys.
        sentinelCid : ContractId AuthorizedSentinel
      controller sentinel, vetify
      do
        requireActiveSentinel vetify sentinel sentinelCid
        assertMsg "Invalid status transition" (isValidMurabahahTransition status Delinquent)
        updated <- create this with status = Delinquent
        t <- getTime
        evt <- create AuditEvent with
          vetify; financialInstitution; regulator; businessName; cacRegNumber
          eventType  = "DELINQUENCY_FLAGGED"
          description = "MurabahahContract " <> facilityRef <> " flagged delinquent: " <> reason
          actedBy    = "sentinel"
          occurredAt = t
        return (updated, evt)

    -- | The sentinel clears delinquency once arrears are fully settled, or
    -- a DelinquencyManualReview case resolves as a false positive.
    choice ResumeActive : (ContractId MurabahahContract, ContractId AuditEvent)
      with
        note        : Text
        -- | The registered AuthorizedSentinel entry for `sentinel` —
        -- caller-supplied, since SDK 3.4.11 / Daml-LF 2.1/2.2 does not
        -- support contract keys.
        sentinelCid : ContractId AuthorizedSentinel
      controller sentinel, vetify
      do
        requireActiveSentinel vetify sentinel sentinelCid
        assertMsg "Invalid status transition" (isValidMurabahahTransition status Active)
        updated <- create this with status = Active
        t <- getTime
        evt <- create AuditEvent with
          vetify; financialInstitution; regulator; businessName; cacRegNumber
          eventType  = "CONTRACT_RESUMED"
          description = "MurabahahContract " <> facilityRef <> " resumed to Active: " <> note
          actedBy    = "sentinel"
          occurredAt = t
        return (updated, evt)

    -- | Pure escalation, no sentinel decision made yet — mirrors
    -- FlagUnderwritingForManualReview's vetify-alone pattern. Used when the
    -- deterministic engine can't confidently resolve the signal (one missed
    -- payment, or a possible unrecorded bank credit offsetting an apparent
    -- miss).
    choice FlagForDelinquencyReview : ContractId MurabahahContract
      with note : Text
      controller vetify
      do
        assertMsg "Invalid status transition" (isValidMurabahahTransition status DelinquencyManualReview)
        create this with status = DelinquencyManualReview

    -- | Stage 10: the FI closes a fully repaid contract. CloseContract and
    -- CloseDefaultedContract both target Completed but from disjoint source
    -- statuses gated to two distinct choices (a Defaulted facility must go
    -- through CloseDefaultedContract, not this one) — isValidMurabahahTransition
    -- alone can't express that per-choice restriction, so the source status
    -- is checked explicitly here in addition to being a validated edge in
    -- the transition graph.
    choice CloseContract : ContractId MurabahahContract
      with closingDate : Date
      controller financialInstitution
      do
        assertMsg "Can only close an Active or Delinquent contract"
          (status == Active || status == Delinquent)
        assertMsg "Invalid status transition" (isValidMurabahahTransition status Completed)
        assertMsg "Can only close a fully repaid contract" (outstandingBalance <= 0.0)
        create this with status = Completed

    -- | Recovery path: the FI closes a defaulted contract once full
    -- recovery brings the balance to zero.
    choice CloseDefaultedContract : ContractId MurabahahContract
      with closingDate : Date
      controller financialInstitution
      do
        assertMsg "Only usable on a Defaulted contract" (status == Defaulted)
        assertMsg "Invalid status transition" (isValidMurabahahTransition status Completed)
        assertMsg "Outstanding balance must be zero before closure" (outstandingBalance <= 0.0)
        create this with status = Completed

    -- | The FI formally defaults an unrecoverable delinquent contract.
    -- Creates a dedicated DefaultRecord alongside the status flip, signed
    -- by financialInstitution (the controller) rather than the
    -- vetify-signed AuditEvent template — vetify has no authority in this
    -- transaction (it is only an observer of MurabahahContract, not a
    -- signatory or controller of this choice).
    choice DefaultContract : (ContractId MurabahahContract, ContractId DefaultRecord)
      with
        reason      : Text
        defaultedBy : Text  -- ^ Officer name for audit trail.
      controller financialInstitution
      do
        assertMsg "Invalid status transition" (isValidMurabahahTransition status Defaulted)
        assertMsg "Reason must not be empty" (reason /= "")
        updated <- create this with status = Defaulted
        t <- getTime
        record <- create DefaultRecord with
          financialInstitution; vetify; business; regulator
          facilityRef; businessName; cacRegNumber
          reason; defaultedBy
          defaultedAt = t
        return (updated, record)

    -- | The business requests a modification of the repayment schedule.
    -- Nonconsuming — the contract stays active while the FI reviews the
    -- request.
    nonconsuming choice RequestRestructuring : ContractId RestructuringRequest
      with
        proposedSchedule : [PaymentScheduleEntry]
        reason           : Text
        requestDate      : Date
      controller business
      do
        assertMsg "Can only restructure an Active or Delinquent contract"
          (status == Active || status == Delinquent)
        assertMsg "Restructuring reason must not be empty" (reason /= "")
        let totalProposed = foldl (\acc e -> acc + e.dueAmount) 0.0 proposedSchedule
        assertMsg "New schedule total cannot exceed outstanding balance (no debt increase)"
          (totalProposed <= outstandingBalance)
        assertMsg "Proposed schedule must not be empty" (not (null proposedSchedule))
        create RestructuringRequest with
          business; vetify; financialInstitution; regulator
          facilityRef; businessName; cacRegNumber
          outstandingBalance; proposedSchedule; reason; requestDate

    -- | The FI approves the restructuring, replacing the payment schedule.
    -- The FI may adjust the proposed schedule (e.g. fewer installments) on
    -- approval.
    choice ApproveRestructuring : ContractId MurabahahContract
      with
        reqCid              : ContractId RestructuringRequest
        approvedSchedule    : [PaymentScheduleEntry]
        restructuringDate   : Date
        -- | Business limit (Financing.UnderwritingPolicy.maxRestructuringsPerFacility,
        -- threaded in as an argument rather than fetched — Murabahah is a
        -- leaf module and cannot import Financing without an import cycle).
        maxRestructurings   : Optional Int
      controller financialInstitution
      do
        assertMsg "Can only restructure an Active or Delinquent contract"
          (status == Active || status == Delinquent)
        assertMsg "Approved schedule must not be empty" (not (null approvedSchedule))
        let totalApproved = foldl (\acc e -> acc + e.dueAmount) 0.0 approvedSchedule
        assertMsg "Approved schedule total cannot exceed outstanding balance"
          (totalApproved <= outstandingBalance)
        case maxRestructurings of
          Some maxR -> assertMsg "Restructuring frequency limit exceeded" (restructuringCount < maxR)
          None      -> return ()
        req <- fetch reqCid
        assertMsg "Restructuring request is for a different facility" (req.facilityRef == facilityRef)
        archive reqCid
        archive paymentScheduleCid
        newSchedCid <- create PaymentScheduleContract with
          financialInstitution = financialInstitution
          vetify               = vetify
          business             = business
          regulator            = regulator
          facilityRef          = facilityRef
          cacRegNumber         = cacRegNumber
          entries              = approvedSchedule
        create this with
          paymentScheduleCid     = newSchedCid
          pendingInstallmentPaid = 0.0
          scheduleVersion        = scheduleVersion + 1
          restructuringCount     = restructuringCount + 1

    -- | The FI rejects the restructuring request.
    choice RejectRestructuring : ContractId RestructuringRejectionRecord
      with
        reqCid  : ContractId RestructuringRequest
        reason  : Text
      controller financialInstitution
      do
        assertMsg "Rejection reason must not be empty" (reason /= "")
        req <- fetch reqCid
        assertMsg "Restructuring request is for a different facility" (req.facilityRef == facilityRef)
        archive reqCid
        t <- getTime
        create RestructuringRejectionRecord with
          financialInstitution; vetify; business
          businessName; cacRegNumber; facilityRef; reason
          rejectedAt = t

    -- | The FI records the actual settlement after Ibra' (full or partial)
    -- is granted. The IbraRequest is consumed by GrantIbra/GrantPartialIbra
    -- before this is called, so the FI passes `settlementType` explicitly.
    -- Consuming — archives this contract. FullIbra: outstanding balance is
    -- zeroed and the contract is Completed. PartialIbra: balance is
    -- reduced; the contract remains Active for further payments.
    choice RecordEarlySettlement
        : (ContractId MurabahahContract, ContractId RepaymentRecord)
      with
        settlementType    : IbraSettlementType
        settlementAmount  : Decimal
        settlementDate    : Date
        settlementAccount : Optional SettlementAccount
      controller financialInstitution
      do
        assertMsg "Contract must be Active for early settlement" (status == Active)
        assertMsg "Settlement amount must be positive" (settlementAmount > 0.0)
        assertMsg "Settlement amount must not exceed outstanding balance"
          (settlementAmount <= outstandingBalance)
        let installNo      = installmentsPaid + 1
        let reducedBalance = outstandingBalance - settlementAmount
        -- FullIbra zeros the balance (the FI waives the remainder);
        -- PartialIbra reduces it.
        let finalBalance   = case settlementType of
              FullIbra    -> 0.0
              PartialIbra -> reducedBalance
        record <- create RepaymentRecord with
          business; vetify; financialInstitution; regulator
          facilityRef; businessName; cacRegNumber
          installmentNo    = installNo
          dueDate          = settlementDate
          paymentDate      = settlementDate
          amountPaid       = settlementAmount
          remainingBalance = finalBalance
          wasLate          = False
          allocation       = None
          settlementAccount
          directDebitRef   = None
        updated <- case settlementType of
          FullIbra ->
            create this with
              outstandingBalance = 0.0
              installmentsPaid   = installNo
              status             = Completed
          PartialIbra ->
            create this with
              outstandingBalance = reducedBalance
              installmentsPaid   = installNo
        return (updated, record)

    -- | The business raises a formal dispute against the FI's actions on
    -- this contract. Nonconsuming — the contract stays active while the
    -- dispute is resolved.
    nonconsuming choice RaiseDispute : ContractId DisputeRecord
      with
        disputeType : DisputeType
        disputeDesc : Text
        evidenceRef : Optional Text
      controller business
      do
        assertMsg "Dispute description must not be empty" (disputeDesc /= "")
        t <- getTime
        create DisputeRecord with
          business; vetify; financialInstitution; regulator
          businessName; cacRegNumber
          disputeType
          description = disputeDesc
          evidenceRef
          raisedAt    = t

    -- | The business requests early settlement (full or partial).
    -- Nonconsuming — the request is a side contract; the main contract
    -- stays active until the FI grants Ibra' and the business pays the net
    -- amount.
    nonconsuming choice RequestIbra : ContractId IbraRequest
      with
        requestedSettlementDate : Date
        settlementType          : IbraSettlementType
        -- | Target partial amount; `None` = full balance.
        requestedAmount         : Optional Decimal
      controller business
      do
        assertMsg "Ibra' can only be requested on an Active contract" (status == Active)
        case requestedAmount of
          Some amt -> assertMsg "Partial settlement amount must be positive and less than outstanding balance"
                        (amt > 0.0 && amt < outstandingBalance)
          None -> return ()
        create IbraRequest with
          business; vetify; financialInstitution
          facilityRef; businessName; cacRegNumber
          outstandingBalance; requestedSettlementDate
          settlementType; requestedAmount

    -- | The FI issues a formal written demand to a defaulted business.
    -- Nonconsuming — the Defaulted contract stays alive for recovery
    -- tracking.
    nonconsuming choice IssueDemandNotice : ContractId DemandNotice
      with
        demandDate       : Date
        demandRef        : Text
        responseDeadline : Date
        -- | True = valid GSM consent exists; gates GSMInvocation.
        gsmEligible      : Bool
      controller financialInstitution
      do
        assertMsg "Can only issue demand notice on a Defaulted contract" (status == Defaulted)
        assertMsg "Demand reference must not be empty" (demandRef /= "")
        assertMsg "Response deadline must be after demand date" (responseDeadline > demandDate)
        create DemandNotice with
          financialInstitution; vetify; business; regulator
          facilityRef; businessName; cacRegNumber
          demandDate; demandRef; responseDeadline; gsmEligible
          outstandingAmount = outstandingBalance

    -- | The FI records a partial recovery receipt after enforcement or
    -- negotiation.
    choice RecordRecoveryPayment
        : (ContractId MurabahahContract, ContractId RecoveryPaymentRecord)
      with
        amountRecovered : Decimal
        recoveryDate    : Date
        -- | "COLLATERAL_SALE", "GUARANTOR", "COURT_JUDGMENT", "VOLUNTARY".
        recoverySource  : Text
      controller financialInstitution
      do
        assertMsg "Can only record recovery on a Defaulted contract" (status == Defaulted)
        assertMsg "Recovery amount must be positive" (amountRecovered > 0.0)
        assertMsg "Recovery amount must not exceed outstanding balance"
          (amountRecovered <= outstandingBalance)
        assertMsg "Recovery source must not be empty" (recoverySource /= "")
        let newBalance = outstandingBalance - amountRecovered
        updated <- create this with outstandingBalance = newBalance
        record <- create RecoveryPaymentRecord with
          financialInstitution; vetify; business; regulator
          facilityRef; businessName; cacRegNumber
          amountRecovered; recoveryDate; recoverySource
          remainingBalance = newBalance
        return (updated, record)

    -- | The FI formally writes off the residual balance after recovery is
    -- exhausted.
    choice WriteOffContract
        : (ContractId MurabahahContract, ContractId WriteOffRecord)
      with
        writeOffDate         : Date
        writeOffRef          : Text
        totalRecovered       : Decimal
        -- | Senior officer name for audit trail.
        writeOffApprovedBy   : Text
        -- | The RecoveryOfficer who proposes the write-off.
        proposedByOfficerId  : Text
        -- | The RiskOfficer who confirms it (four-eyes).
        confirmedByOfficerId : Text
        -- | The registered AuthorizedOfficer entries for `proposedByOfficerId`
        -- / `confirmedByOfficerId` — caller-supplied, since SDK 3.4.11 /
        -- Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid  : ContractId AuthorizedOfficer
        confirmedByOfficerCid : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "Can only write off a Defaulted contract" (status == Defaulted)
        assertMsg "Write-off reference must not be empty" (writeOffRef /= "")
        assertMsg "Write-off approver must be named" (writeOffApprovedBy /= "")
        assertMsg "Total recovered must be non-negative" (totalRecovered >= 0.0)
        -- Segregation of duties: distinct proposer and confirmer, correct roles.
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId RecoveryOfficer proposedByOfficerCid
        confirmer <- requireActiveOfficer financialInstitution confirmedByOfficerId RiskOfficer confirmedByOfficerCid
        assertMsg "Confirming officer must differ from proposing officer (four-eyes)"
          (proposedByOfficerId /= confirmedByOfficerId)
        assertMsg "writeOffApprovedBy must match the confirming officer's registered name"
          (writeOffApprovedBy == confirmer.officerName)
        let amountWrittenOff = outstandingBalance
        updated <- create this with status = Completed; outstandingBalance = 0.0
        record <- create WriteOffRecord with
          financialInstitution; vetify; regulator
          facilityRef; businessName; cacRegNumber
          totalFinanced    = murabahahTerms.salePrice
          totalRecovered; amountWrittenOff; writeOffDate; writeOffRef
          writeOffApprovedBy
        return (updated, record)

    -- | The FI grants a payment moratorium; future payments before
    -- `moratoriumEnd` will not trigger the `wasLate` flag.
    choice GrantMoratorium
        : (ContractId MurabahahContract, ContractId MoratoriumRecord)
      with
        moratoriumEnd : Date
        reason        : Text
      controller financialInstitution
      do
        assertMsg "Can only grant moratorium on Active or Delinquent contract"
          (status == Active || status == Delinquent)
        assertMsg "A moratorium is already active" (activeMoratorium == None)
        assertMsg "Reason must not be empty" (reason /= "")
        updated <- create this with activeMoratorium = Some moratoriumEnd
        record <- create MoratoriumRecord with
          financialInstitution; vetify; business
          facilityRef; businessName; cacRegNumber; moratoriumEnd; reason
        return (updated, record)

    -- | vetify ends an active moratorium.
    choice EndMoratorium : ContractId MurabahahContract
      with note : Text
      controller vetify
      do
        assertMsg "No active moratorium to end" (activeMoratorium /= None)
        assertMsg "Note must not be empty" (note /= "")
        create this with activeMoratorium = None


-- ─── 6. RepaymentRecord ───────────────────────────────────────────────────

-- | Immutable on-ledger record of each installment payment. `wasLate`
-- drives Sadaqah obligations and Monitoring Agent delinquency scoring.
template RepaymentRecord
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    installmentNo        : Int
    dueDate              : Date
    paymentDate          : Date
    amountPaid           : Decimal
    remainingBalance     : Decimal
    wasLate              : Bool
    -- | Principal/profit/fee breakdown.
    allocation           : Optional PaymentAllocation
    -- | Account used to make this repayment.
    settlementAccount    : Optional SettlementAccount
    -- | mono.co collection ref; `None` = manual FI payment.
    directDebitRef       : Optional Text
  where
    signatory business, financialInstitution
    observer [vetify] ++ optional [] pure regulator


-- | Idempotency guard for RecordPayment: one guard per
-- `(financialInstitution, directDebitRef)` prevents a replayed payment
-- webhook/collection event from creating a duplicate RepaymentRecord under
-- the same external reference. Only created when `directDebitRef` is
-- `Some` — manual/cash payments (`None`) are not deduplicated this way.
template PaymentIdempotencyGuard
  with
    financialInstitution : Party
    directDebitRef        : Text
  where
    signatory financialInstitution
    -- No contract key (Daml-LF 2.1/2.2, SDK 3.4.11, does not support
    -- contract keys): RecordPayment's own duplicate check (below) can no
    -- longer be atomic — see its comment for the accepted residual risk.
    ensure directDebitRef /= ""


-- ─── 7. Ibra' (Early Settlement Rebate) ──────────────────────────────────

-- | The business requests early full repayment. The FI may voluntarily
-- grant a rebate on the remaining profit portion. AAOIFI Std No. 8, §6/1:
-- the rebate is at the FI's absolute discretion and cannot be contractually
-- stipulated upfront.
template IbraRequest
  with
    business                : Party
    vetify                  : Party
    financialInstitution    : Party
    -- | Links to the MurabahahContract key.
    facilityRef             : Text
    businessName            : Text
    cacRegNumber            : Text
    outstandingBalance      : Decimal
    requestedSettlementDate : Date
    settlementType          : IbraSettlementType
    -- | Target partial amount; `None` = full balance.
    requestedAmount         : Optional Decimal
  where
    signatory business
    observer financialInstitution, vetify

    -- | The FI grants a voluntary rebate for full early settlement.
    -- `rebateAmount` reduces what the business must pay to close the
    -- contract. Creates an IbraGrantRecord as immutable on-ledger evidence.
    choice GrantIbra : ContractId IbraGrantRecord
      with
        rebateAmount         : Decimal
        -- | The CreditOfficer who proposes the rebate.
        proposedByOfficerId  : Text
        -- | The RiskOfficer who confirms (four-eyes; P&L impact).
        confirmedByOfficerId : Text
        -- | The registered AuthorizedOfficer entries for `proposedByOfficerId`
        -- / `confirmedByOfficerId` — caller-supplied, since SDK 3.4.11 /
        -- Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid  : ContractId AuthorizedOfficer
        confirmedByOfficerCid : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "GrantIbra is for full settlement; use GrantPartialIbra for partial"
          (settlementType == FullIbra)
        assertMsg "Rebate cannot exceed outstanding balance" (rebateAmount <= outstandingBalance)
        assertMsg "Rebate must be non-negative" (rebateAmount >= 0.0)
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId CreditOfficer proposedByOfficerCid
        _ <- requireActiveOfficer financialInstitution confirmedByOfficerId RiskOfficer confirmedByOfficerCid
        assertMsg "Confirming officer must differ from proposing officer (four-eyes)"
          (proposedByOfficerId /= confirmedByOfficerId)
        t <- getTime
        create IbraGrantRecord with
          financialInstitution; vetify; business
          facilityRef; businessName; cacRegNumber
          outstandingBalance; rebateAmount
          effectiveDate = requestedSettlementDate
          grantedAt     = t

    -- | The FI approves a partial early settlement at a reduced amount.
    -- Creates a PartialIbraGrant as immutable on-ledger evidence.
    choice GrantPartialIbra : ContractId PartialIbraGrant
      with
        rebateAmount             : Decimal
        approvedSettlementAmount : Decimal
        proposedByOfficerId      : Text
        confirmedByOfficerId     : Text
        -- | The registered AuthorizedOfficer entries for `proposedByOfficerId`
        -- / `confirmedByOfficerId` — caller-supplied, since SDK 3.4.11 /
        -- Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid     : ContractId AuthorizedOfficer
        confirmedByOfficerCid    : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "GrantPartialIbra requires PartialIbra settlement type"
          (settlementType == PartialIbra)
        assertMsg "Approved settlement amount must be positive" (approvedSettlementAmount > 0.0)
        assertMsg "Approved settlement must be less than outstanding balance"
          (approvedSettlementAmount < outstandingBalance)
        assertMsg "Rebate must be non-negative" (rebateAmount >= 0.0)
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId CreditOfficer proposedByOfficerCid
        _ <- requireActiveOfficer financialInstitution confirmedByOfficerId RiskOfficer confirmedByOfficerCid
        assertMsg "Confirming officer must differ from proposing officer (four-eyes)"
          (proposedByOfficerId /= confirmedByOfficerId)
        t <- getTime
        create PartialIbraGrant with
          financialInstitution; vetify; business
          facilityRef; businessName; cacRegNumber
          outstandingBalance; rebateAmount; approvedSettlementAmount
          effectiveDate = requestedSettlementDate
          grantedAt     = t

    -- | The FI declines; the business must repay the full outstanding
    -- balance. Creates immutable evidence like every other decline path in
    -- this module (ProposalDeclineRecord, RestructuringRejectionRecord).
    choice DeclineIbra : ContractId IbraDeclineRecord
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Reason must not be empty" (reason /= "")
        t <- getTime
        create IbraDeclineRecord with
          financialInstitution; vetify; business
          facilityRef; businessName; cacRegNumber
          outstandingBalance; reason
          declinedAt = t

    -- | The FI proposes an advisory rebate amount — an internal calculation
    -- tool for the FI's financing team, not vetify. AAOIFI Std No. 8, §6/1:
    -- Ibra' is at the FI's absolute discretion and cannot be contractually
    -- stipulated.
    nonconsuming choice ProposeRebate : ContractId IbraRebateProposal
      with
        suggestedRebate : Decimal
        rationale       : Text
      controller financialInstitution
      do
        assertMsg "Suggested rebate must be non-negative" (suggestedRebate >= 0.0)
        assertMsg "Suggested rebate cannot exceed outstanding balance"
          (suggestedRebate <= outstandingBalance)
        assertMsg "Rationale must not be empty" (rationale /= "")
        create IbraRebateProposal with
          financialInstitution; vetify; business
          facilityRef; businessName; cacRegNumber
          outstandingBalance; suggestedRebate; rationale; settlementType


-- ─── 8. LatePaymentCharity (Sadaqah obligation) ───────────────────────────

-- | AAOIFI Std No. 8, §2/4/20: any penalty charged for late payment must be
-- donated to charity. The FI cannot retain it as income. This contract
-- records the obligation and the business's settlement of it.
template LatePaymentCharity
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    businessName         : Text
    cacRegNumber         : Text
    installmentNo        : Int
    dueDate              : Date
    paymentDate          : Date
    -- | `None` until set by the FI's Shariah committee formula.
    charityAmount        : Optional Decimal
    settled              : Bool
  where
    signatory financialInstitution
    observer business, vetify

    -- | The FI applies their Shariah committee's approved formula to set
    -- the amount.
    choice SetCharityAmount : ContractId LatePaymentCharity
      with amount : Decimal
      controller financialInstitution
      do
        assertMsg "Charity amount must be positive" (amount > 0.0)
        assertMsg "Amount already settled" (not settled)
        create this with charityAmount = Some amount

    -- | The business confirms the charity donation was made; creates an
    -- immutable CharityPaymentRecord with beneficiary and receipt for
    -- regulatory audit.
    choice ConfirmCharityPayment : ContractId CharityPaymentRecord
      with
        -- | Charity receipt or bank transfer reference.
        charityRef          : Text
        -- | Beneficiary organization name.
        charityOrganization : Text
      controller business
      do
        case charityAmount of
          None -> assertFail "Charity amount must be set before settlement"
          Some amt -> do
            assertMsg "Charity organization must not be empty" (charityOrganization /= "")
            t <- getTime
            create CharityPaymentRecord with
              business; vetify; financialInstitution
              businessName; cacRegNumber
              installmentNo
              charityAmount = amt
              charityRef
              charityOrganization
              confirmedAt = t

    -- | Co-signed path: the FI validates `charityOrganization` against
    -- their CharityOrganizationRegistry; the business co-signs to authorize
    -- the CharityPaymentRecord (bilateral signatory). The FI fetches the
    -- registry (the business has no visibility); both parties sign the
    -- resulting record. Submit with `actAs [business, financialInstitution]`.
    choice ConfirmCharityPaymentValidated : ContractId CharityPaymentRecord
      with
        charityRef          : Text
        charityOrganization : Text
        registryCid         : ContractId CharityOrganizationRegistry
      controller business, financialInstitution
      do
        case charityAmount of
          None -> assertFail "Charity amount must be set before settlement"
          Some amt -> do
            assertMsg "Charity organization must not be empty" (charityOrganization /= "")
            registry <- fetch registryCid
            assertMsg "Registry belongs to a different FI"
              (registry.financialInstitution == financialInstitution)
            let approved = any (\(name, _) -> name == charityOrganization)
                               registry.approvedOrganizations
            assertMsg "Organization not in FI's approved charity registry" approved
            t <- getTime
            create CharityPaymentRecord with
              business; vetify; financialInstitution
              businessName; cacRegNumber
              installmentNo
              charityAmount = amt
              charityRef
              charityOrganization
              confirmedAt = t


-- ─── 9. RahnAgreement (Collateral) ────────────────────────────────────────

-- | AAOIFI Std No. 39: the business pledges an asset as security for the
-- financing. Created alongside or just after MurabahahContract. Released on
-- full repayment; enforced on default.
template RahnAgreement
  with
    business              : Party
    vetify                : Party
    financialInstitution  : Party
    -- | CBN oversight of collateral records.
    regulator             : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef           : Text
    businessName          : Text
    cacRegNumber          : Text
    -- | E.g. "Plot 14, Lekki Phase 1, Lagos — C of O No. LG12345".
    collateralDescription : Text
    -- | Estimated market value in NGN.
    collateralValue       : Decimal
    collateralStatus      : CollateralStatus
    -- | Discharge document ref, set on ReleaseCollateral.
    releaseEvidence       : Optional Text
  where
    signatory business, financialInstitution
    observer [vetify] ++ optional [] pure regulator

    ensure collateralValue > 0.0

    -- | The FI releases the pledge on full repayment / contract closure.
    -- Segregation of duties: distinct OperationsOfficer (proposer) and
    -- RiskOfficer (confirmer) required — mirrors EnforceCollateral below.
    choice ReleaseCollateral : ContractId RahnAgreement
      with
        note                 : Text
        -- | Discharge letter or title deed ref.
        releaseDocumentRef   : Optional Text
        proposedByOfficerId  : Text
        confirmedByOfficerId : Text
        -- | The registered AuthorizedOfficer entries for `proposedByOfficerId`
        -- / `confirmedByOfficerId` — caller-supplied, since SDK 3.4.11 /
        -- Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid  : ContractId AuthorizedOfficer
        confirmedByOfficerCid : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "Can only release Active collateral" (collateralStatus == CollateralActive)
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId OperationsOfficer proposedByOfficerCid
        _ <- requireActiveOfficer financialInstitution confirmedByOfficerId RiskOfficer confirmedByOfficerCid
        assertMsg "Confirming officer must differ from proposing officer (four-eyes)"
          (proposedByOfficerId /= confirmedByOfficerId)
        create this with collateralStatus = CollateralReleased; releaseEvidence = releaseDocumentRef

    -- | The FI enforces the pledge on default. Segregation of duties:
    -- distinct RecoveryOfficer (proposer) and RiskOfficer (confirmer)
    -- required, whether called directly or via ProposeEnforceCollateral ->
    -- ConfirmEnforce.
    choice EnforceCollateral : ContractId RahnAgreement
      with
        reason               : Text
        proposedByOfficerId  : Text
        confirmedByOfficerId : Text
        -- | The registered AuthorizedOfficer entries for `proposedByOfficerId`
        -- / `confirmedByOfficerId` — caller-supplied, since SDK 3.4.11 /
        -- Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid  : ContractId AuthorizedOfficer
        confirmedByOfficerCid : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "Can only enforce Active collateral" (collateralStatus == CollateralActive)
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId RecoveryOfficer proposedByOfficerCid
        _ <- requireActiveOfficer financialInstitution confirmedByOfficerId RiskOfficer confirmedByOfficerCid
        assertMsg "Confirming officer must differ from proposing officer (four-eyes)"
          (proposedByOfficerId /= confirmedByOfficerId)
        create this with collateralStatus = CollateralEnforced

    -- | The FI records a formal collateral revaluation; archives the old
    -- record and creates a new RahnAgreement with the updated value plus a
    -- CollateralValuationRecord.
    choice Revalue : (ContractId RahnAgreement, ContractId CollateralValuationRecord)
      with
        newValue      : Decimal
        valuationDate : Date
        -- | Appraiser name or reference.
        valuatorRef   : Text
        notes         : Optional Text
      controller financialInstitution
      do
        assertMsg "Collateral must be Active to revalue" (collateralStatus == CollateralActive)
        assertMsg "New collateral value must be positive" (newValue > 0.0)
        assertMsg "Valuator reference must not be empty" (valuatorRef /= "")
        let reg = regulator
        newRahn <- create this with collateralValue = newValue
        valRecord <- create CollateralValuationRecord with
          financialInstitution
          vetify
          business
          regulator = reg
          businessName
          cacRegNumber
          previousValue   = collateralValue
          valuationAmount = newValue
          valuationDate
          valuatorRef
          notes
        return (newRahn, valRecord)

    -- | The FI records a periodic physical inspection of the pledged asset.
    nonconsuming choice RecordInspection : ContractId CollateralInspectionRecord
      with
        inspectionDate          : Date
        inspectedBy             : Text
        condition               : CollateralCondition
        inspectionNotes         : Optional Text
        nextInspectionDate      : Optional Date
        -- | mono.co mandate status at inspection time.
        mandateStatus           : Optional Text
        -- | Estimated liquid balance recoverable via GSM.
        estimatedGsmRecoverable : Optional Decimal
      controller financialInstitution
      do
        assertMsg "Inspected-by must not be empty" (inspectedBy /= "")
        assertMsg "Can only inspect Active collateral" (collateralStatus == CollateralActive)
        let reg = regulator
        create CollateralInspectionRecord with
          financialInstitution; vetify; business
          regulator = reg
          businessName; cacRegNumber
          inspectionDate; inspectedBy; condition; inspectionNotes; nextInspectionDate
          mandateStatus; estimatedGsmRecoverable

    -- | The FI proposes collateral enforcement; vetify must confirm.
    nonconsuming choice ProposeEnforceCollateral : ContractId PendingCollateralEnforcement
      with
        reason              : Text
        -- | True = GSM was attempted before escalating to Rahn.
        gsmExhausted        : Bool
        -- | mono.co / NIBSS GSM reference, if attempted.
        gsmRef              : Optional Text
        -- | The RecoveryOfficer proposing, carried through to EnforceCollateral.
        proposedByOfficerId : Text
        -- | The registered AuthorizedOfficer entry for `proposedByOfficerId`
        -- — caller-supplied, since SDK 3.4.11 / Daml-LF 2.1/2.2 does not
        -- support contract keys.
        proposedByOfficerCid : ContractId AuthorizedOfficer
      controller financialInstitution
      do
        assertMsg "Can only propose enforcement on Active collateral"
          (collateralStatus == CollateralActive)
        assertMsg "Reason must not be empty" (reason /= "")
        _ <- requireActiveOfficer financialInstitution proposedByOfficerId RecoveryOfficer proposedByOfficerCid
        create PendingCollateralEnforcement with
          financialInstitution; vetify; business
          businessName; cacRegNumber; reason; gsmExhausted; gsmRef; proposedByOfficerId


-- ─── Asset Rejection Record ────────────────────────────────────────────────

-- | On-ledger evidence of a pre-Qabdh rejection. The FI must either replace
-- the asset (new AssetPurchaseRecord) or cancel the transaction.
template AssetRejectionRecord
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    businessName         : Text
    cacRegNumber         : Text
    reason               : Text
    defectDescription    : Text
    rejectedAt           : Time
  where
    signatory business
    observer financialInstitution, vetify


-- ─── Acquisition Cancellation Request ──────────────────────────────────────

-- | The business formally requests deal cancellation after a defect
-- rejection when the FI cannot supply a suitable replacement. The FI either
-- confirms (ConfirmCancellation on AssetPurchaseRecord) or rejects
-- (RejectCancellation here).
template AcquisitionCancellationRequest
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    reason               : Text
  where
    signatory business
    observer financialInstitution, vetify
    ensure reason /= ""

    -- | The FI accepts the cancellation — consuming, archives this request.
    choice AcceptCancellation : ()
      controller financialInstitution
      do return ()

    -- | The FI rejects the cancellation; the AssetPurchaseRecord remains
    -- live.
    choice RejectCancellation : ()
      controller financialInstitution
      do return ()


-- ─── Supplier Payment Record ──────────────────────────────────────────────

-- | Formal proof that the FI (directly or via business-as-Wakil) paid the
-- supplier. AAOIFI Std No. 8, §3/1: FI ownership requires prior payment.
-- Created via nonconsuming RecordSupplierPayment on AssetPurchaseRecord.
template SupplierPaymentRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    supplierDetails      : Optional SupplierDetails
    amountPaid           : Decimal
    paymentDate          : Date
    paymentRef           : Text
    bankConfirmationRef  : Optional Text
    purchasedViaWakala   : Bool
  where
    signatory financialInstitution
    observer business, vetify
    ensure amountPaid > 0.0


-- ─── Restructuring Request ─────────────────────────────────────────────────

-- | The business's on-ledger request to modify the repayment schedule
-- post-origination. The FI responds via ApproveRestructuring or
-- RejectRestructuring on MurabahahContract. AAOIFI note: restructuring must
-- not increase the total outstanding debt.
template RestructuringRequest
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    outstandingBalance   : Decimal
    proposedSchedule     : [PaymentScheduleEntry]
    reason               : Text
    requestDate          : Date
  where
    signatory business
    observer financialInstitution, vetify


-- ─── Shariah Audit Record ──────────────────────────────────────────────────

-- | Periodic on-ledger Shariah review of a Murabahah facility. Created by
-- vetify after each audit cycle; observable by the FI and regulator.
template ShariahAuditRecord
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    -- | Soft link to a specific MurabahahContract key.
    facilityRef          : Optional Text
    businessName         : Text
    cacRegNumber         : Text
    auditDate            : Date
    -- | E.g. "2026-H1", "2026-Q2".
    auditPeriod          : Text
    -- | Auditing body or officer name.
    auditorRef           : Text
    -- | Individual audit findings.
    findings             : [Text]
    overallCompliant     : Bool
    recommendations      : [Text]
    nextAuditDate        : Optional Date
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator


-- ─── Shariah Exception ──────────────────────────────────────────────────────

-- | On-ledger record of a Shariah non-compliance incident. Open until
-- vetify exercises ResolveException.
template ShariahException
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    facilityRef          : Optional Text
    businessName         : Text
    cacRegNumber         : Text
    exceptionType        : Text
    description          : Text
    severity             : ShariahExceptionSeverity
    detectedAt           : Time
    resolutionNote       : Optional Text
    resolvedAt           : Optional Time
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator

    -- | vetify records the resolution; archives and creates a resolved
    -- version.
    choice ResolveException : ContractId ShariahException
      with
        note      : Text
        resolveAt : Time
      controller vetify
      do
        assertMsg "Exception is already resolved" (resolutionNote == None)
        assertMsg "Resolution note must not be empty" (note /= "")
        create this with resolutionNote = Some note; resolvedAt = Some resolveAt


-- ─── Murabahah Statement (Regulatory Reporting) ────────────────────────────

-- | Per-contract periodic statement visible to the regulator, FI, and
-- business. Created by vetify from PQS aggregations; the regulator can
-- query this directly without access to individual RepaymentRecord
-- internals.
template MurabahahStatement
  with
    vetify               : Party
    business             : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    statementDate        : Date
    -- | E.g. "2026-Q2".
    statementPeriod      : Text
    totalFinanced        : Decimal
    totalRepaid          : Decimal
    outstandingBalance   : Decimal
    installmentsPaid     : Int
    totalInstallments    : Int
    contractStatus       : MurabahahStatus
    -- | Reference to the most recent ShariahAuditRecord.
    shariahAuditRef      : Optional Text
  where
    signatory vetify
    observer [business, financialInstitution] ++ optional [] pure regulator
    ensure totalFinanced > 0.0 && totalRepaid >= 0.0 && outstandingBalance >= 0.0


-- ─── Collateral Valuation Record ───────────────────────────────────────────

-- | Immutable evidence of each formal revaluation event on a pledged asset.
-- Created via the Revalue consuming choice on RahnAgreement.
template CollateralValuationRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | CBN oversight of collateral valuation.
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    previousValue        : Decimal
    valuationAmount      : Decimal
    valuationDate        : Date
    -- | Appraiser name or certification reference.
    valuatorRef          : Text
    notes                : Optional Text
  where
    signatory financialInstitution
    observer [business, vetify] ++ optional [] pure regulator
    ensure valuationAmount > 0.0


-- ─── Takaful Policy ─────────────────────────────────────────────────────────

-- | Islamic insurance policy linked to a Murabahah financing facility.
-- AAOIFI Takaful Standard: the FI typically procures asset or credit
-- Takaful.
template TakafulPolicy
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    policyNumber         : Text
    -- | E.g. "Cornerstone Takaful Nigeria".
    takafulOperator      : Text
    -- | "ASSET_TAKAFUL" or "CREDIT_TAKAFUL".
    coverageType         : Text
    -- | Maximum indemnity amount in NGN.
    coverageAmount       : Decimal
    -- | Contribution (Tabarru') paid.
    premiumAmount        : Decimal
    startDate            : Date
    expiryDate           : Date
    -- | Reference to the specific asset covered.
    assetRef             : Optional Text
  where
    signatory financialInstitution
    observer [business, vetify] ++ optional [] pure regulator
    ensure premiumAmount > 0.0 && coverageAmount > 0.0 && expiryDate > startDate


-- ─── Supplier Failure Record ────────────────────────────────────────────────

-- | Documents a supplier cancellation, insolvency, or non-delivery event.
-- Created by the consuming RecordSupplierFailure choice on
-- AssetPurchaseRecord.
template SupplierFailureRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    failureType          : SupplierFailureType
    failureDescription   : Text
    refundAmount         : Optional Decimal
    failedAt             : Time
  where
    signatory financialInstitution
    observer business, vetify
    ensure failureDescription /= ""


-- ─── Dispute Record ─────────────────────────────────────────────────────────

-- | On-ledger dispute raised by the business against an FI action on a
-- contract. Created via nonconsuming RaiseDispute on MurabahahContract.
-- Open until vetify escalates to arbitration or the parties resolve
-- bilaterally.
template DisputeRecord
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    disputeType          : DisputeType
    description          : Text
    -- | Off-ledger evidence reference.
    evidenceRef          : Optional Text
    raisedAt             : Time
  where
    signatory business
    observer [financialInstitution, vetify] ++ optional [] pure regulator
    ensure description /= ""

    -- | vetify escalates an unresolved dispute to a third-party arbitrator.
    choice EscalateToArbitration : ContractId ArbitrationRequest
      with
        arbitrator : Party
      controller vetify
      do
        assertMsg "Arbitrator must differ from the parties" (arbitrator /= business && arbitrator /= financialInstitution)
        t <- getTime
        create ArbitrationRequest with
          vetify; business; financialInstitution; regulator
          arbitrator; businessName; cacRegNumber
          disputeDescription = description
          escalatedAt        = t
          outcome            = None
          resolution         = None


-- ─── Arbitration Request ────────────────────────────────────────────────────

-- | Formal arbitration proceeding arising from an unresolved DisputeRecord.
template ArbitrationRequest
  with
    vetify               : Party
    business             : Party
    financialInstitution : Party
    regulator            : Optional Party
    arbitrator           : Party
    businessName         : Text
    cacRegNumber         : Text
    disputeDescription   : Text
    escalatedAt          : Time
    outcome              : Optional ArbitrationOutcome
    -- | Narrative resolution summary.
    resolution           : Optional Text
  where
    signatory vetify
    observer [business, financialInstitution, arbitrator] ++ optional [] pure regulator
    ensure disputeDescription /= ""

    -- | vetify records the arbitrator's finding and closes the proceeding.
    choice RecordArbitrationOutcome : ContractId ArbitrationRequest
      with
        arbOutcome    : ArbitrationOutcome
        arbResolution : Text
      controller vetify
      do
        assertMsg "Arbitration is already concluded" (outcome == None)
        assertMsg "Resolution must not be empty" (arbResolution /= "")
        create this with outcome = Some arbOutcome; resolution = Some arbResolution


-- ─── Monitoring Alert ───────────────────────────────────────────────────────

-- | The AI Monitoring Agent raises an alert for a specific risk event on a
-- facility. Dismissed by vetify after human review.
template MonitoringAlert
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    -- | Soft link to a specific MurabahahContract key.
    facilityRef          : Optional Text
    businessName         : Text
    cacRegNumber         : Text
    alertType            : MonitoringAlertType
    alertSeverity        : AlertSeverity
    alertDescription     : Text
    detectedAt           : Time
    dismissed            : Bool
    dismissalNote        : Optional Text
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure alertDescription /= ""

    -- | vetify dismisses the alert after review or remediation.
    choice DismissAlert : ContractId MonitoringAlert
      with dismissNote : Text
      controller vetify
      do
        assertMsg "Alert is already dismissed" (not dismissed)
        assertMsg "Dismissal note must not be empty" (dismissNote /= "")
        create this with dismissed = True; dismissalNote = Some dismissNote


-- ─── Portfolio Risk Report ──────────────────────────────────────────────────

-- | Portfolio-level risk metrics (PD, LGD, EL, concentration) produced by
-- the Reporting Agent. Observable by the FI and the regulator for
-- supervisory use.
template PortfolioRiskReport
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    reportDate           : Date
    -- | E.g. "2026-Q3".
    reportPeriod         : Text
    metrics              : PortfolioRiskMetrics
    -- | E.g. "vetify-reporting".
    generatedByAgent     : Text
    modelVersion         : Text
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure metrics.activeContractCount >= 0
        && metrics.exposureAtDefault >= 0.0
        && metrics.expectedLoss >= 0.0


-- ─── Charity Payment Record ─────────────────────────────────────────────────

-- | Immutable confirmation that the business discharged the Sadaqah
-- obligation arising from a late payment. Created by ConfirmCharityPayment
-- on LatePaymentCharity. AAOIFI Std No. 8, §2/4/20: documentation of
-- charity disbursement is required.
template CharityPaymentRecord
  with
    business             : Party
    vetify               : Party
    financialInstitution : Party
    businessName         : Text
    cacRegNumber         : Text
    installmentNo        : Int
    charityAmount        : Decimal
    -- | Charity receipt or bank transfer reference.
    charityRef           : Text
    -- | Beneficiary organization name.
    charityOrganization  : Text
    confirmedAt          : Time
  where
    signatory business, financialInstitution
    observer vetify
    ensure charityAmount > 0.0 && charityRef /= "" && charityOrganization /= ""


-- ─── Delivery Milestone ─────────────────────────────────────────────────────

-- | Records receipt of a partial delivery during the Wakala acquisition
-- phase. Created via nonconsuming RecordDeliveryMilestone on
-- AssetPurchaseRecord. The final full AcknowledgeDelivery still gates
-- OfferMurabahah.
template DeliveryMilestone
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    milestoneDescription : Text
    quantityDelivered    : Decimal
    milestoneDate        : Date
    -- | Delivery note, bill of lading reference.
    evidenceRef          : Optional Text
  where
    signatory financialInstitution
    observer business, vetify
    ensure quantityDelivered > 0.0 && milestoneDescription /= ""


-- ─── Suspicious Activity Report ─────────────────────────────────────────────

-- | On-ledger SAR filed with the regulator (NFIU/CBN) for a suspicious
-- transaction or behavioural pattern. Confidential — the business does not
-- observe this contract.
template SARReport
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    -- | NFIU / EFCC submission reference.
    sarRef               : Text
    -- | Description of the suspicious pattern.
    suspiciousActivity   : Text
    reportDate           : Date
    -- | Officer name or role who filed the SAR.
    reportedByParty      : Text
    -- | True = restricted visibility; the business is excluded.
    confidential         : Bool
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure suspiciousActivity /= "" && sarRef /= ""


-- ─── Supplier Quotation ──────────────────────────────────────────────────────

-- | Formal supplier quotation attached to a MurabahahWad via
-- AttachQuotation. Provides an immutable anchor linking `estimatedCost` to a
-- named supplier offer.
template SupplierQuotation
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    supplierName         : Text
    quotationRef         : Text
    quotedAmount         : Decimal
    assetDescription     : Text
    validUntil           : Optional Date
  where
    signatory financialInstitution
    observer vetify, business
    ensure quotedAmount > 0.0 && quotationRef /= ""


-- ─── Document Entry ─────────────────────────────────────────────────────────

-- | Managed lifecycle record for a single document attached to a facility.
-- Created via RegisterDocument on AssetPurchaseRecord; verified by vetify.
template DocumentEntry
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    documentRef          : DocumentRef
    registeredBy         : Text
    uploadedAt           : Time
    verifiedAt           : Optional Time
    superseded           : Bool
  where
    signatory financialInstitution
    observer vetify, business

    choice VerifyDocument : ContractId DocumentEntry
      with verifyNote : Optional Text
      controller vetify
      do
        assertMsg "Document already verified" (verifiedAt == None)
        assertMsg "Document is superseded" (not superseded)
        t <- getTime
        create this with verifiedAt = Some t

    choice SupersedeDocument : ContractId DocumentEntry
      with
        newDocumentRef : DocumentRef
        reason         : Text
      controller financialInstitution
      do
        assertMsg "Document is already superseded" (not superseded)
        assertMsg "Reason must not be empty" (reason /= "")
        create this with documentRef = newDocumentRef; verifiedAt = None; superseded = False


-- ─── Collateral Inspection Record ───────────────────────────────────────────

-- | Records a periodic physical inspection of pledged collateral. Distinct
-- from revaluation — verifies existence and condition without repricing.
-- Created via nonconsuming RecordInspection on RahnAgreement.
template CollateralInspectionRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | CBN oversight of collateral inspections.
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    inspectionDate              : Date
    inspectedBy                 : Text
    condition                   : CollateralCondition
    inspectionNotes             : Optional Text
    nextInspectionDate          : Optional Date
    -- | mono.co mandate status at inspection time.
    mandateStatus               : Optional Text
    -- | Estimated liquid balance recoverable via GSM.
    estimatedGsmRecoverable     : Optional Decimal
  where
    signatory financialInstitution
    observer [vetify, business] ++ optional [] pure regulator
    ensure inspectedBy /= ""


-- ─── Credit Covenant ─────────────────────────────────────────────────────────

-- | Records a financial covenant (DSCR, leverage ratio, etc.) that the
-- business must satisfy during the active contract. Measurements are
-- recorded via nonconsuming RecordCovenantMeasurement; breaches create a
-- CovenantMeasurementRecord.
template CreditCovenant
  with
    financialInstitution    : Party
    vetify                  : Party
    business                : Party
    -- | CBN oversight of covenant measurements.
    regulator               : Optional Party
    businessName            : Text
    cacRegNumber            : Text
    -- | "DSCR_MINIMUM", "LEVERAGE_RATIO", "CURRENT_RATIO".
    covenantType            : Text
    threshold               : Decimal
    -- | "MONTHLY", "QUARTERLY", "ANNUALLY".
    measurementFrequency    : Text
  where
    signatory financialInstitution
    observer [vetify, business] ++ optional [] pure regulator
    ensure threshold > 0.0

    nonconsuming choice RecordCovenantMeasurement : ContractId CovenantMeasurementRecord
      with
        measuredValue : Decimal
        measureDate   : Date
        measuredBy    : Text
      controller vetify
      do
        assertMsg "Measured-by must not be empty" (measuredBy /= "")
        let reg = regulator
        create CovenantMeasurementRecord with
          financialInstitution; vetify; business
          regulator = reg
          businessName; cacRegNumber
          covenantType; threshold; measuredValue
          measureDate; measuredBy
          breached = measuredValue < threshold


-- ─── Covenant Measurement Record ────────────────────────────────────────────

-- | Immutable snapshot of a single covenant measurement. `breached = True`
-- triggers an off-ledger Monitoring Agent alert.
template CovenantMeasurementRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | CBN oversight of covenant measurements.
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    covenantType         : Text
    threshold            : Decimal
    measuredValue        : Decimal
    measureDate          : Date
    measuredBy           : Text
    breached             : Bool
  where
    signatory financialInstitution
    observer [vetify, business] ++ optional [] pure regulator
    ensure measuredBy /= ""


-- ─── Demand Notice ──────────────────────────────────────────────────────────

-- | Formal written demand issued to a defaulted business. First step of the
-- post-default recovery chain. Created via IssueDemandNotice on
-- MurabahahContract.
template DemandNotice
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    regulator            : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    demandDate           : Date
    outstandingAmount    : Decimal
    demandRef            : Text
    responseDeadline     : Date
    -- | The FI attests that GSM consent exists at demand time.
    gsmEligible          : Bool
  where
    signatory financialInstitution
    observer [vetify, business] ++ optional [] pure regulator
    ensure demandRef /= ""

    choice EscalateToLegal : ContractId LegalEscalation
      with
        escalationDate : Date
        solicitorRef   : Text
        legalAction    : Text
      controller financialInstitution
      do
        assertMsg "Solicitor reference must not be empty" (solicitorRef /= "")
        assertMsg "Legal action description must not be empty" (legalAction /= "")
        create LegalEscalation with
          financialInstitution; vetify; regulator
          businessName; cacRegNumber
          escalationDate; solicitorRef; legalAction
          outstandingAmount
          courtRef   = None
          resolvedAt = None

    choice WithdrawDemand : ()
      with note : Text
      controller financialInstitution
      do
        assertMsg "Note must not be empty" (note /= "")
        return ()


-- ─── Legal Escalation ───────────────────────────────────────────────────────

-- | Formal instruction to solicitors to commence recovery proceedings.
-- Created via EscalateToLegal on DemandNotice.
template LegalEscalation
  with
    financialInstitution : Party
    vetify               : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    escalationDate       : Date
    solicitorRef         : Text
    legalAction          : Text
    outstandingAmount    : Decimal
    courtRef             : Optional Text
    resolvedAt           : Optional Time
  where
    signatory financialInstitution
    observer [vetify] ++ optional [] pure regulator
    ensure solicitorRef /= ""

    choice RecordCourtOrder : ContractId LegalEscalation
      with courtOrderRef : Text
      controller financialInstitution
      do
        assertMsg "Court order reference must not be empty" (courtOrderRef /= "")
        create this with courtRef = Some courtOrderRef

    choice ResolveLegal : ContractId LegalEscalation
      with note : Text
      controller financialInstitution
      do
        assertMsg "Resolution note must not be empty" (note /= "")
        assertMsg "Already resolved" (resolvedAt == None)
        t <- getTime
        create this with resolvedAt = Some t


-- ─── Recovery Payment Record ────────────────────────────────────────────────

-- | Immutable receipt of a partial recovery payment after default. Created
-- via RecordRecoveryPayment on MurabahahContract (status = Defaulted).
template RecoveryPaymentRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    regulator            : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    amountRecovered      : Decimal
    recoveryDate         : Date
    recoverySource       : Text
    remainingBalance     : Decimal
  where
    signatory financialInstitution
    observer [vetify, business] ++ optional [] pure regulator
    ensure amountRecovered > 0.0


-- ─── Audit trail: Default Record ───────────────────────────────────────────

-- | Immutable evidence that a contract was formally defaulted. Created via
-- DefaultContract on MurabahahContract (status = Delinquent -> Defaulted).
template DefaultRecord
  with
    financialInstitution : Party
    vetify                : Party
    business              : Party
    regulator             : Optional Party
    facilityRef           : Text
    businessName          : Text
    cacRegNumber          : Text
    reason                : Text
    defaultedBy           : Text
    defaultedAt           : Time
  where
    signatory financialInstitution
    observer [business, vetify] ++ optional [] pure regulator
    ensure reason /= "" && defaultedBy /= ""


-- ─── Write-Off Record ───────────────────────────────────────────────────────

-- | Final write-off of the residual balance after all recovery is
-- exhausted. Created via WriteOffContract on MurabahahContract
-- (status = Defaulted).
template WriteOffRecord
  with
    financialInstitution : Party
    vetify               : Party
    regulator            : Optional Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    totalFinanced        : Decimal
    totalRecovered       : Decimal
    amountWrittenOff     : Decimal
    writeOffDate         : Date
    writeOffRef          : Text
    -- | Senior officer name for audit trail.
    writeOffApprovedBy   : Text
  where
    signatory financialInstitution
    observer [vetify] ++ optional [] pure regulator
    ensure amountWrittenOff >= 0.0 && writeOffRef /= "" && writeOffApprovedBy /= ""


-- ─── Regulatory Inspection Request ──────────────────────────────────────────

-- | vetify creates this when the CBN/NFIU issues an inspection notice. The
-- FI responds within the deadline; vetify closes via CloseInspection.
template RegulatoryInspectionRequest
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    inspectionRef        : Text
    inspectionScope      : Text
    responseDeadline     : Date
    requestedAt          : Time
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure inspectionRef /= "" && regulator /= None

    choice RespondToInspection : ContractId InspectionResponse
      with
        responseRef     : Text
        documents       : [Text]
        respondedByName : Text
        responseDate    : Date
      controller financialInstitution
      do
        assertMsg "Response reference must not be empty" (responseRef /= "")
        assertMsg "Responded-by name must not be empty" (respondedByName /= "")
        create InspectionResponse with
          vetify; financialInstitution; regulator
          businessName; cacRegNumber
          inspectionRef; responseRef; documents
          respondedByName; responseDate

    choice ExtendDeadline : ContractId RegulatoryInspectionRequest
      with newDeadline : Date
      controller vetify
      do
        assertMsg "New deadline must be later than current" (newDeadline > responseDeadline)
        create this with responseDeadline = newDeadline


-- ─── Inspection Response ────────────────────────────────────────────────────

-- | The FI's formal response to a regulatory inspection request. vetify
-- closes it via CloseInspection once the regulator is satisfied.
template InspectionResponse
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    inspectionRef        : Text
    responseRef          : Text
    documents            : [Text]
    respondedByName      : Text
    responseDate         : Date
  where
    signatory financialInstitution
    observer [vetify] ++ optional [] pure regulator

    choice CloseInspection : ContractId InspectionRecord
      with
        findings       : [Text]
        passed         : Bool
        followUpNeeded : Bool
        closingNote    : Text
      controller vetify
      do
        assertMsg "Closing note must not be empty" (closingNote /= "")
        create InspectionRecord with
          vetify; financialInstitution; regulator
          businessName; cacRegNumber
          inspectionRef; findings; passed; followUpNeeded; closingNote


-- ─── Inspection Record ──────────────────────────────────────────────────────

-- | Immutable outcome of a completed regulatory inspection.
template InspectionRecord
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    inspectionRef        : Text
    findings             : [Text]
    passed               : Bool
    followUpNeeded       : Bool
    closingNote          : Text
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure closingNote /= ""


-- ─── Pending Collateral Enforcement ─────────────────────────────────────────

-- | Maker-checker gate for EnforceCollateral. The FI proposes via
-- ProposeEnforceCollateral; vetify confirms (ConfirmEnforce) or rejects
-- (RejectEnforce).
template PendingCollateralEnforcement
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    reason               : Text
    -- | The FI attests GSM was attempted before Rahn enforcement.
    gsmExhausted         : Bool
    -- | GSM reference for audit trail.
    gsmRef               : Optional Text
    -- | The RecoveryOfficer who proposed enforcement.
    proposedByOfficerId  : Text
  where
    signatory financialInstitution
    observer vetify, business
    ensure reason /= ""

    choice ConfirmEnforce : ContractId RahnAgreement
      with
        rahnCid               : ContractId RahnAgreement
        -- | The RiskOfficer confirming, must differ from the proposer.
        confirmedByOfficerId  : Text
        -- | The registered AuthorizedOfficer entries for
        -- `proposedByOfficerId` / `confirmedByOfficerId` — caller-supplied,
        -- since SDK 3.4.11 / Daml-LF 2.1/2.2 does not support contract keys.
        proposedByOfficerCid  : ContractId AuthorizedOfficer
        confirmedByOfficerCid : ContractId AuthorizedOfficer
      controller vetify
      do
        exercise rahnCid EnforceCollateral with
          reason
          proposedByOfficerId
          confirmedByOfficerId
          proposedByOfficerCid
          confirmedByOfficerCid

    choice RejectEnforce : ()
      controller vetify
      do return ()


-- ─── Audit Event ─────────────────────────────────────────────────────────────

-- | Chronological on-ledger audit log entry for significant lifecycle
-- events. Created by vetify or agents; supplements PQS event history for
-- regulatory review.
template AuditEvent
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    -- | "PAYMENT_RECORDED", "CONTRACT_DEFAULTED", "COLLATERAL_ENFORCED", etc.
    eventType            : Text
    description          : Text
    actedBy              : Text
    occurredAt           : Time
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure description /= "" && eventType /= "" && actedBy /= ""


-- ─── Moratorium Record ──────────────────────────────────────────────────────

-- | Immutable evidence of a granted payment moratorium. Created via
-- GrantMoratorium on MurabahahContract.
template MoratoriumRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    moratoriumEnd        : Date
    reason               : Text
  where
    signatory financialInstitution
    observer vetify, business
    ensure reason /= ""


-- ─── Ibra' Rebate Proposal ──────────────────────────────────────────────────

-- | Advisory rebate calculation produced by the FI's financing team, not
-- vetify. Created via ProposeRebate on IbraRequest. The FI is not obligated
-- to follow it. AAOIFI Std No. 8, §6/1: the rebate is at the FI's absolute
-- discretion and cannot be pre-agreed.
template IbraRebateProposal
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    outstandingBalance   : Decimal
    suggestedRebate      : Decimal
    rationale            : Text
    settlementType       : IbraSettlementType
  where
    signatory financialInstitution
    observer vetify, business
    ensure suggestedRebate >= 0.0 && outstandingBalance > 0.0 && rationale /= ""


-- ─── Ibra' Grant Records ─────────────────────────────────────────────────────

-- | Immutable on-ledger evidence of the FI's decision to grant an Ibra'
-- rebate. AAOIFI Std No. 8, §6/1: Ibra' is at the FI's absolute discretion
-- and cannot be pre-agreed.

-- | Full Ibra' grant: the FI waives part of the remaining profit for early
-- full settlement.
template IbraGrantRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    -- | Links to the MurabahahContract key.
    facilityRef          : Text
    businessName         : Text
    cacRegNumber         : Text
    outstandingBalance   : Decimal
    rebateAmount         : Decimal
    effectiveDate        : Date
    grantedAt            : Time
  where
    signatory financialInstitution
    observer vetify, business
    ensure rebateAmount >= 0.0 && rebateAmount <= outstandingBalance


-- | Partial Ibra' grant: the FI approves a reduced settlement amount with a
-- stated rebate.
template PartialIbraGrant
  with
    financialInstitution     : Party
    vetify                   : Party
    business                 : Party
    -- | Links to the MurabahahContract key.
    facilityRef              : Text
    businessName             : Text
    cacRegNumber             : Text
    outstandingBalance       : Decimal
    rebateAmount             : Decimal
    approvedSettlementAmount : Decimal
    effectiveDate            : Date
    grantedAt                : Time
  where
    signatory financialInstitution
    observer vetify, business
    ensure approvedSettlementAmount > 0.0
        && approvedSettlementAmount < outstandingBalance
        && rebateAmount >= 0.0


-- | Immutable evidence that the FI declined a business's Ibra' (early
-- settlement rebate) request. Closes the same correctness gap the other
-- decline paths in this module close (ProposalDeclineRecord,
-- RestructuringRejectionRecord): every decline is recorded with a reason,
-- not left as a bare stub.
template IbraDeclineRecord
  with
    financialInstitution : Party
    vetify                : Party
    business              : Party
    facilityRef           : Text
    businessName          : Text
    cacRegNumber          : Text
    outstandingBalance    : Decimal
    reason                : Text
    declinedAt            : Time
  where
    signatory financialInstitution
    observer business, vetify
    ensure reason /= ""


-- ─── Guarantee Agreement ────────────────────────────────────────────────────

-- | Personal or corporate guarantee from a business director or third
-- party. Universal in SME Murabahah: covers shortfalls when collateral is
-- insufficient.
template GuaranteeAgreement
  with
    guarantor            : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    -- | "PERSONAL", "CORPORATE", "THIRD_PARTY".
    guaranteeType        : Text
    guaranteedAmount     : Decimal
    -- | Legal name (guarantor is the ledger party; this name is for docs).
    guarantorName        : Text
    -- | NIN, passport number, or company registration.
    guarantorId          : Text
    effectiveDate        : Date
    expiryDate           : Optional Date
    guaranteeStatus      : GuaranteeStatus
  where
    signatory guarantor, financialInstitution
    observer vetify
    ensure guaranteedAmount > 0.0
        && guaranteeType /= ""
        && guarantorName /= ""
        && guarantorId /= ""

    -- | The FI enforces the guarantee after default — triggers the
    -- guarantor's obligation.
    choice EnforceGuarantee : ContractId GuaranteeAgreement
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Can only enforce an Active guarantee" (guaranteeStatus == GuaranteeActive)
        assertMsg "Reason must not be empty" (reason /= "")
        create this with guaranteeStatus = GuaranteeEnforced

    -- | The FI releases the guarantee on full repayment or write-off
    -- closure.
    choice ReleaseGuarantee : ContractId GuaranteeAgreement
      with note : Text
      controller financialInstitution
      do
        assertMsg "Can only release an Active guarantee" (guaranteeStatus == GuaranteeActive)
        assertMsg "Release note must not be empty" (note /= "")
        create this with guaranteeStatus = GuaranteeReleased

-- ─── Wa'd Withdrawal Record ─────────────────────────────────────────────────

-- | Immutable audit record created when a business withdraws a
-- MurabahahWad.
template WadWithdrawalRecord
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    reason               : Text
    withdrawnAt          : Time
  where
    signatory business
    observer financialInstitution, vetify
    ensure reason /= ""

-- ─── Proposal Decline Record ────────────────────────────────────────────────

-- | Immutable audit record created when a business declines a
-- MurabahahProposal.
template ProposalDeclineRecord
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    reason               : Text
    declinedAt           : Time
  where
    signatory business
    observer financialInstitution, vetify
    ensure reason /= ""

-- ─── Agency Withdrawal Record ───────────────────────────────────────────────

-- | Immutable audit record created when a business declines the Wakala
-- appointment.
template AgencyWithdrawalRecord
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    reason               : Text
    declinedAt           : Time
  where
    signatory business
    observer financialInstitution, vetify
    ensure reason /= ""

-- ─── Restructuring Rejection Record ─────────────────────────────────────────

-- | Immutable audit record created when an FI rejects a
-- RestructuringRequest.
template RestructuringRejectionRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    reason               : Text
    rejectedAt           : Time
  where
    signatory financialInstitution
    observer business, vetify
    ensure reason /= ""


-- ─── Direct Debit Mandate ────────────────────────────────────────────────────

-- | Bilateral record of the business's authorisation for automated
-- installment collection via mono.co Direct Debit, and their GSM consent,
-- in a single instrument. Created at Stage 8 alongside or after
-- AcceptProposal.
template DirectDebitMandate
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    -- | mono.co mandate ID from create_direct_debit_mandate.
    monoMandateRef       : Text
    -- | The business's NUBAN (repayment account).
    accountRef           : Text
    bankName             : Text
    -- | Per-installment cap (>= installmentAmount).
    maxCollectionAmount  : Decimal
    -- | "MONTHLY".
    frequency            : Text
    mandateStartDate     : Date
    -- | Mirrors the facility tenure end date.
    mandateEndDate       : Optional Date
    -- | True = the business consents to a cross-bank CBN/NIBSS sweep.
    gsmConsentGiven      : Bool
    -- | Date GSM consent was recorded with CBN/NIBSS.
    gsmConsentDate       : Optional Date
    status               : DirectDebitStatus
  where
    signatory business, financialInstitution
    observer vetify
    ensure monoMandateRef /= "" && maxCollectionAmount > 0.0 && accountRef /= ""

    choice SuspendMandate : ContractId DirectDebitMandate
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Can only suspend an Active mandate" (status == MandateActive)
        assertMsg "Reason must not be empty" (reason /= "")
        create this with status = MandateSuspended

    choice ReinstateMandate : ContractId DirectDebitMandate
      controller financialInstitution
      do
        assertMsg "Can only reinstate a Suspended mandate" (status == MandateSuspended)
        create this with status = MandateActive

    choice CancelMandate : ContractId DirectDebitMandate
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Reason must not be empty" (reason /= "")
        create this with status = MandateCancelled


-- ─── GSM Invocation ──────────────────────────────────────────────────────────

-- | Audit and coordination record created by the FI after DefaultContract +
-- IssueDemandNotice's deadline has passed and `gsmConsentGiven = True`. Does
-- not hold an independent balance — all balance changes route through
-- RecordRecoveryPayment on MurabahahContract.
template GSMInvocation
  with
    financialInstitution : Party
    vetify               : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    -- | BVN submitted to CBN/NIBSS via mono.co.
    businessBvn          : Text
    -- | Outstanding balance at time of invocation.
    invokedAmount        : Decimal
    -- | mono.co / NIBSS reference.
    monoGsmRef           : Text
    invokedAt            : Time
    status               : GSMStatus
    -- | NIBSS reference of the most recent sweep.
    lastSweepRef         : Optional Text
  where
    signatory financialInstitution
    observer [vetify] ++ optional [] pure regulator
    ensure monoGsmRef /= "" && invokedAmount > 0.0 && businessBvn /= ""

    -- | Each NIBSS sweep routes recovery through MurabahahContract (single
    -- source of truth). `contractCid` is passed explicitly — Daml choices
    -- cannot reference their own contract's ContractId.
    choice RecordGSMSweep : GSMSweepResult
      with
        contractCid   : ContractId MurabahahContract
        sweepAmount   : Decimal
        sweepDate     : Date
        nibssSweepRef : Text
      controller financialInstitution
      do
        assertMsg "NIBSS reference must not be empty" (nibssSweepRef /= "")
        assertMsg "Sweep amount must be positive" (sweepAmount > 0.0)
        targetContract <- fetch contractCid
        assertMsg "contractCid must belong to this GSM invocation's facility"
          (targetContract.facilityRef == facilityRef)
        (sweptContract, recoveryRecord) <-
          exercise contractCid RecordRecoveryPayment with
            amountRecovered = sweepAmount
            recoveryDate    = sweepDate
            recoverySource  = "GSM_NIBSS"
        updatedInvocation <- create this with
          lastSweepRef = Some nibssSweepRef
          status       = GSMActive
        return GSMSweepResult with
          updatedInvocation
          sweptContract
          recoveryRecord

    choice CancelGSM : ContractId GSMInvocation
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Reason must not be empty" (reason /= "")
        create this with status = GSMCancelled


-- ─── Direct Debit Collection Attempt ────────────────────────────────────────

-- | Immutable record of each mono.co collection attempt. Provides the
-- Monitoring Agent with retry history and an audit trail for failed
-- collections.
template DirectDebitCollectionAttempt
  with
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    -- | mono.co collection reference.
    monoCollectionRef    : Text
    installmentNo        : Int
    attemptedAmount      : Decimal
    attemptDate          : Date
    succeeded            : Bool
    -- | mono.co failure code, e.g. "INSUFFICIENT_FUNDS".
    failureReason        : Optional Text
    retryCount           : Int
  where
    signatory financialInstitution
    observer vetify
    ensure attemptedAmount > 0.0 && monoCollectionRef /= ""


-- ═══════════════════════════════════════════════════════════════════════════
-- OPTIONAL PRODUCT FEATURES
-- All templates below are conditional lifecycle additions. None are
-- required steps in the standard Murabahah flow. FIs opt in per their own
-- product policy.
-- ═══════════════════════════════════════════════════════════════════════════

-- ─── HamishJiddiyyah (Security Deposit) ─────────────────────────────────────

-- | AAOIFI Std No. 8, §2/3: the FI may require a deposit before executing
-- the Wa'd, to cover actual losses if the business withdraws. This is
-- FI-discretionary and never a required lifecycle step.
template HamishJiddiyyah
  with
    business             : Party
    financialInstitution : Party
    vetify               : Party
    businessName         : Text
    cacRegNumber         : Text
    -- | Links to the associated MurabahahContract key.
    facilityRef          : Text
    depositAmount        : Decimal
    -- | Bank transfer or receipt reference.
    depositRef           : Text
    depositDate          : Date
    -- | If the Wa'd proceeds, the FI must return the deposit by this date.
    returnDeadline       : Date
    -- | Set on forfeiture — must be <= depositAmount.
    actualLossDeducted   : Optional Decimal
    status               : HamishStatus
  where
    signatory financialInstitution
    observer business, vetify
    ensure depositAmount > 0.0 && depositRef /= ""

    -- | The FI returns the full deposit after the Wa'd proceeds and the
    -- asset is delivered.
    choice ReturnDeposit : ContractId HamishJiddiyyah
      with transferRef : Text
      controller financialInstitution
      do
        assertMsg "Can only return a Held deposit" (status == HamishHeld)
        assertMsg "Transfer reference must not be empty" (transferRef /= "")
        create this with status = HamishReturned

    -- | The FI forfeits the deposit (partially or fully) when the business
    -- withdraws the Wa'd, causing the FI actual losses. AAOIFI §2/3: only
    -- actual losses may be retained.
    choice ForfeitDeposit : ContractId HamishJiddiyyah
      with
        actualLoss : Decimal
        reason     : Text
      controller financialInstitution
      do
        assertMsg "Can only forfeit a Held deposit" (status == HamishHeld)
        assertMsg "Forfeited amount cannot exceed deposit" (actualLoss <= depositAmount)
        assertMsg "Forfeited amount must be non-negative" (actualLoss >= 0.0)
        assertMsg "Reason must not be empty" (reason /= "")
        create this with
          status             = HamishForfeited
          actualLossDeducted = Some actualLoss


-- ─── PurchaseOrder ───────────────────────────────────────────────────────────

-- | The FI's formal binding instruction to the supplier. Issued after the
-- FI decides to proceed (either via Wakala or direct purchase path).
-- Provides an on-ledger audit record of the FI-to-supplier transaction.
template PurchaseOrder
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    supplierName         : Text
    supplierDetails      : SupplierDetails
    orderedItems         : [AssetLineItem]
    totalOrderValue      : Decimal
    deliveryDeadline     : Date
    poRef                : Text
    issuedAt             : Time
    status               : POStatus
  where
    signatory financialInstitution
    observer business, vetify
    ensure totalOrderValue > 0.0 && poRef /= "" && not (null orderedItems)

    choice ConfirmPO : ContractId PurchaseOrder
      with confirmationRef : Text
      controller financialInstitution
      do
        assertMsg "Confirmation reference must not be empty" (confirmationRef /= "")
        create this with status = POConfirmed

    choice MarkPartiallyFulfilled : ContractId PurchaseOrder
      with deliveryRef : Text
      controller financialInstitution
      do
        assertMsg "Can only mark Confirmed or Issued PO as partially fulfilled"
          (status == POConfirmed || status == POIssued)
        assertMsg "Delivery reference must not be empty" (deliveryRef /= "")
        create this with status = POPartiallyFulfilled

    choice MarkFulfilled : ContractId PurchaseOrder
      with deliveryRef : Text
      controller financialInstitution
      do
        assertMsg "PO must be Confirmed or PartiallyFulfilled to mark as Fulfilled"
          (status == POConfirmed || status == POPartiallyFulfilled)
        create this with status = POFulfilled

    choice CancelPO : ContractId PurchaseOrder
      with reason : Text
      controller financialInstitution
      do
        assertMsg "Can only cancel an Issued or Confirmed PO"
          (status == POIssued || status == POConfirmed)
        assertMsg "Reason must not be empty" (reason /= "")
        create this with status = POCancelled


-- ─── CapitalCallRecord (Tranche Disbursement) ───────────────────────────────

-- | Immutable record of a single disbursement tranche for multi-draw
-- facilities. Each tranche represents a partial release of the approved
-- financing limit.
template CapitalCallRecord
  with
    financialInstitution : Party
    vetify               : Party
    business             : Party
    regulator            : Optional Party
    businessName         : Text
    cacRegNumber         : Text
    facilityRef          : Text
    trancheNumber        : Int
    trancheAmount        : Decimal
    disbursementDate     : Date
    purposeOfTranche     : Text
    -- | The FI's internal payment reference.
    disbursementRef      : Text
    -- | Total disbursed, including this tranche.
    cumulativeDisbursed  : Decimal
    -- | Facility limit minus cumulativeDisbursed.
    remainingFacility    : Decimal
  where
    signatory financialInstitution
    observer [business, vetify] ++ optional [] pure regulator
    ensure trancheAmount > 0.0 && disbursementRef /= "" && purposeOfTranche /= ""
        && cumulativeDisbursed >= trancheAmount
        && remainingFacility >= 0.0


-- ─── ForceMajeureDeclaration ─────────────────────────────────────────────────

-- | Portfolio-wide payment suspension for systemic events (pandemic, flood,
-- regulatory directive). Allows vetify to declare a moratorium covering all
-- active contracts in an affected region without amending each contract
-- individually. FIs and, optionally, the regulator observe for compliance.
template ForceMajeureDeclaration
  with
    vetify               : Party
    financialInstitution : Party
    regulator            : Optional Party
    -- | Internal vetify reference, e.g. "FMD-2026-CBN-001".
    declarationRef       : Text
    -- | Human-readable summary of the event.
    eventDescription     : Text
    -- | E.g. "North-East Nigeria", "Nationwide".
    affectedRegion       : Text
    suspensionStart      : Date
    suspensionEnd        : Date
    -- | E.g. "CBN Circular FPR/DIR/GEN/CIR/07/004".
    regulatoryBasis      : Text
    isActive             : Bool
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
    ensure suspensionEnd > suspensionStart && declarationRef /= "" && eventDescription /= ""

    -- | vetify lifts the declaration once the force majeure event has
    -- passed.
    choice LiftDeclaration : ContractId ForceMajeureDeclaration
      with note : Text
      controller vetify
      do
        assertMsg "Declaration has already been lifted" isActive
        assertMsg "Lifting note must not be empty" (note /= "")
        create this with isActive = False


-- ─── CharityOrganizationRegistry ─────────────────────────────────────────────

-- | Each FI maintains its own Shariah-board-approved Sadaqah beneficiary
-- list. vetify does not centralize this list — it is a credit governance
-- decision. Used by ConfirmCharityPaymentValidated for on-ledger registry
-- validation.
template CharityOrganizationRegistry
  with
    financialInstitution  : Party
    vetify                : Party
    regulator             : Optional Party
    -- | (orgName, registrationRef).
    approvedOrganizations : [(Text, Text)]
    -- | Shariah board resolution approving this list.
    shariahBoardRef       : Text
    effectiveDate         : Date
    version               : Text
  where
    signatory financialInstitution
    observer [vetify] ++ optional [] pure regulator
    ensure not (null approvedOrganizations) && shariahBoardRef /= "" && version /= ""

    -- | The FI updates the approved list when the Shariah board amends its
    -- resolution.
    choice UpdateRegistry : ContractId CharityOrganizationRegistry
      with
        newOrganizations : [(Text, Text)]
        newVersion       : Text
        updatedBoardRef  : Text
      controller financialInstitution
      do
        assertMsg "Updated list must not be empty" (not (null newOrganizations))
        assertMsg "New version must not be empty" (newVersion /= "")
        assertMsg "Updated board reference must not be empty" (updatedBoardRef /= "")
        create this with
          approvedOrganizations = newOrganizations
          version               = newVersion
          shariahBoardRef       = updatedBoardRef
