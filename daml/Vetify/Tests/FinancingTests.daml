      officerId
      officerName           = "Junior Officer"
      roles                 = [CreditOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = Some 1_000_000.0  -- below sampleFinancingTerms.amount (2,000,000)
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  submitMustFail p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Junior Officer"
