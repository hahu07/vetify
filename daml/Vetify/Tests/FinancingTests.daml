-- | Stage 5–7 tests: financing request invariants, underwriting, FI funding
--   decision, AI governance, maker-checker, human override, withdrawal, and
--   structured explainability (F1–F6, F10–F11, F13–F15, F20–F24).
module Vetify.Tests.FinancingTests where

import Daml.Script
import DA.Time
import Vetify.Types
import Vetify.Financing
import Vetify.FinancingProvider (ApprovedProvider)
import Vetify.Murabahah (MurabahahWad)
import Vetify.Governance
import Vetify.Tests.Fixtures

data FParties = FParties with
  borrower  : Party
  vetify    : Party
  fi        : Party
  regulator : Party

setupFParties : Script FParties
setupFParties = do
  borrower  <- allocateParty "Borrower"
  vetify    <- allocateParty "Vetify"
  fi        <- allocateParty "FI"
  regulator <- allocateParty "Regulator"
  pure FParties with ..

-- F16: setup with an active UnderwritingPolicy (1-hour SLA, 30-day offer window).
setupFPartiesWithPolicy : Script FParties
setupFPartiesWithPolicy = do
  p <- setupFParties
  t <- getTime
  submit p.vetify do
    createCmd UnderwritingPolicy with
      vetify               = p.vetify
      financialInstitution = p.fi
      policyVersion        = "2026-v1"
      autoApproveMin       = 80
      autoRejectMax        = 50
      minDscrRatio         = Some 1.2
      maxLoanAmount        = Some 50_000_000.0
      requestSlaHours      = 1
      offerValidityDays    = 30
      effectiveFrom        = t
      effectiveTo          = None
      writeOffThresholdAmount      = Some 1_000_000.0
      maxRestructuringsPerFacility = Some 3
      permittedSectors             = None
      requiredCollateralTypes      = []
      maxSectorConcentrationPct    = None
      scoringWeights               = sampleUnderwritingScoringWeights
  pure p

-- Creates an ApprovedProvider for the FI, approved for Murabahah + Ijarah.
-- Call this in any test that exercises ApproveFunding.
createApprovedFI : FParties -> Script (ContractId ApprovedProvider)
createApprovedFI p = setupApprovedProvider p.fi p.vetify

-- RBAC (Governance): registers an active CreditOfficer for the FI and returns
-- the officerId to pass as ApproveFunding's approvingOfficerId. officerName
-- must match whatever approvedByName the test supplies (checked on-ledger).
createCreditOfficer : FParties -> Text -> Script Text
createCreditOfficer p officerName = do
  t <- getTime
  let officerId = "CO-" <> officerName
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId
      officerName
      roles                 = [CreditOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  pure officerId

-- RBAC (Governance, Gap F31): registers an active UnderwritingOfficer for the
-- FI and returns the officerId to pass as OverrideUnderwriting's overridingOfficerId.
createUnderwritingOfficer : FParties -> Text -> Script Text
createUnderwritingOfficer p officerName = do
  t <- getTime
  let officerId = "UO-" <> officerName
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId
      officerName
      roles                 = [UnderwritingOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  pure officerId

-- Base helper: creates a FinancingRequest in Submitted status.
submittedRequest : FParties -> Script (ContractId FinancingRequest)
submittedRequest p = submit p.borrower do
  createCmd FinancingRequest with
    borrower             = p.borrower
    vetify               = p.vetify
    financialInstitution = p.fi
    businessName         = sampleProfile.name
    cacRegNumber         = sampleKyc.cacRegNumber
    terms                = sampleFinancingTerms
    status               = Submitted
    financingRef         = "FIN-TEST-001"
    verificationRef      = None
    complianceRef        = None
    submittedAt          = None
    supportingDocuments  = []
    businessSector       = "Food Retail"
    incorporationDate    = sampleProfile.incorporationDate
    expiresAt            = None
    termHistory          = []
    amendmentCount       = 0
    assignedUnderwriterId   = None
    assignedUnderwriterName = None
    assignedAt              = None

-- Advances the request from Submitted → Underwriting; returns both contracts.
beginUnderwriting : FParties -> ContractId FinancingRequest
  -> Script (ContractId FinancingRequest, ContractId UnderwritingResult)
beginUnderwriting p req = submit p.vetify do
  exerciseCmd req BeginUnderwriting with
    assessment        = sampleAssessment
    autoDecided       = True
    aiMetadata        = Some sampleAIMetadata
    agentVersion      = Some "vetify-underwriting-v1.0"
    underwriterName   = Some "vetify-underwriting"
    underwritingRef   = Some "trace-2026-uw-0001"
    decisionDocuments = []

-- ── Pre-existing tests (updated for new field signatures) ────────────────────

-- Review finding F12: a non-positive amount must be rejected at creation.
testRejectsNonPositiveAmount : Script ()
testRejectsNonPositiveAmount = do
  p <- setupFParties
  submitMustFail p.borrower do
    createCmd FinancingRequest with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms with amount = 0.0
      status               = Submitted
      financingRef         = "FIN-TEST-NEG-001"
      verificationRef      = None
      complianceRef        = None
      submittedAt          = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 0
      assignedUnderwriterId   = None
      assignedUnderwriterName = None
      assignedAt              = None
  pure ()

-- Happy path: Submitted → BeginUnderwriting → ApproveFunding → MurabahahWad + FinancingDecision.
testApproveFundingCreatesWad : Script ()
testApproveFundingCreatesWad = do
  p   <- setupFParties
  apCid <- createApprovedFI p
  officerId <- createCreditOfficer p "Aminu Bello"
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  (wad, _decision) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aminu Bello"
      underwriterName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  Some w <- queryContractId p.fi wad
  assertMsg "estimatedCost" (w.assetDetails.estimatedCost == 2_000_000.0)
  assertMsg "businessName" (w.businessName == sampleProfile.name)
  assertMsg "financingRef carried to Wad" (w.financingRef == Some "FIN-TEST-001")
  -- MurabahahWad is NOT visible to the regulator (they observe only the final contract).
  noneForRegulator <- queryContractId @MurabahahWad p.regulator wad
  assertMsg "noneForRegulator" (noneForRegulator == None)

-- Review finding F6: a rejection is recorded on-ledger as a FinancingDecision.
testRejectFundingIsRecorded : Script ()
testRejectFundingIsRecorded = do
  p   <- setupFParties
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  decision <- submit p.fi do
    exerciseCmd updated RejectFunding with
      reason            = "DSCR below policy threshold"
      rejectedByName    = Some "Aminu Bello"
      reasonCode        = Some "DSCR_BELOW_THRESHOLD"
      decisionFactors   = ["DSCR: 0.9", "Sector: Food Retail (Medium Risk)"]
      decisionDocuments = []
  Some d <- queryContractId p.fi decision
  assertMsg "outcome" (d.outcome == FinancingRejected)
  assertMsg "reason" (d.reason == Some "DSCR below policy threshold")

-- Guard: cannot approve funding before underwriting has begun.
testCannotApproveBeforeUnderwriting : Script ()
testCannotApproveBeforeUnderwriting = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  officerId <- createCreditOfficer p "Aminu Bello"
  req   <- submittedRequest p
  submitMustFail p.fi do
    exerciseCmd req ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = None
      underwriterName     = None
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  pure ()

-- ── New gap tests ─────────────────────────────────────────────────────────────

-- F1: traceability refs are carried through to the created contract.
testTraceabilityRefs : Script ()
testTraceabilityRefs = do
  p <- setupFParties
  req <- submit p.borrower do
    createCmd FinancingRequest with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      status               = Submitted
      financingRef         = "FIN-2026-RC123456-001"
      verificationRef      = Some "VER-RESULT-001"
      complianceRef        = Some "APPROVED-BORROWER-001"
      submittedAt          = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 0
      assignedUnderwriterId   = None
      assignedUnderwriterName = None
      assignedAt              = None
  Some r <- queryContractId p.borrower req
  assertMsg "financingRef" (r.financingRef == "FIN-2026-RC123456-001")
  assertMsg "verificationRef" (r.verificationRef == Some "VER-RESULT-001")
  assertMsg "complianceRef" (r.complianceRef == Some "APPROVED-BORROWER-001")

-- F2: BeginUnderwriting sets underwritingStartedAt; ApproveFunding sets decidedAt.
testAuditTimestamps : Script ()
testAuditTimestamps = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  officerId <- createCreditOfficer p "Aminu Bello"
  req   <- submittedRequest p
  (updated, urCid) <- beginUnderwriting p req
  Some ur <- queryContractId p.vetify urCid
  assertMsg "underwritingStartedAt should be set" (ur.underwritingStartedAt /= None)
  (_, decisionCid) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aminu Bello"
      underwriterName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  Some d <- queryContractId p.fi decisionCid
  assertMsg "decidedAt should be set" (d.decidedAt /= None)

-- F3: AI metadata is stored on UnderwritingResult; policySnapshot is None without a policy.
testAiMetadataOnUnderwritingResult : Script ()
testAiMetadataOnUnderwritingResult = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  Some ur <- queryContractId p.vetify urCid
  assertMsg "autoDecided" ur.autoDecided
  assertMsg "agentVersion" (ur.agentVersion == Some "vetify-underwriting-v1.0")
  assertMsg "underwriterName" (ur.underwriterName == Some "vetify-underwriting")
  assertMsg "policySnapshot is None without a policy" (ur.policySnapshot == None)
  assertMsg "underwritingRef" (ur.underwritingRef == Some "trace-2026-uw-0001")
  case ur.aiMetadata of
    None -> assertFail "aiMetadata should be present"
    Some m -> assertMsg "aiMetadata.agentName" (m.agentName == "vetify-verification")

-- Stage 6's five independent scoring engines (agents/src/scoring/underwriting-*.ts) each
-- populate their own sub-score on RiskAssessment; confirm all four flow through onto the
-- created UnderwritingResult, not just the composite score.
testUnderwritingSubScoresPopulated : Script ()
testUnderwritingSubScoresPopulated = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  Some ur <- queryContractId p.vetify urCid
  assertMsg "behaviouralScore (Financial Behaviour engine)" (ur.assessment.behaviouralScore == Some 78)
  assertMsg "cashflowRiskScore (Cashflow Risk engine)" (ur.assessment.cashflowRiskScore == Some 85)
  assertMsg "creditworthinessScore (Creditworthiness engine)" (ur.assessment.creditworthinessScore == Some 72)
  assertMsg "fraudScore (Fraud Detection engine)" (ur.assessment.fraudScore == Some 5)

-- F27's 0-100 bounds check now also covers each per-engine sub-score, not just the composite.
testBeginUnderwritingRejectsOutOfRangeSubScore : Script ()
testBeginUnderwritingRejectsOutOfRangeSubScore = do
  p   <- setupFParties
  req <- submittedRequest p
  let badAssessment = sampleAssessment with fraudScore = Some 150
  submitMustFail p.vetify do
    exerciseCmd req BeginUnderwriting with
      assessment        = badAssessment
      autoDecided       = True
      aiMetadata        = Some sampleAIMetadata
      agentVersion      = Some "vetify-underwriting-v1.0"
      underwriterName   = Some "vetify-underwriting"
      underwritingRef   = Some "trace-2026-uw-0001"
      decisionDocuments = []

-- F5: ApproveFunding creates an immutable FinancingDecision with FinancingApproved outcome.
testApproveFundingCreatesDecisionRecord : Script ()
testApproveFundingCreatesDecisionRecord = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  officerId <- createCreditOfficer p "Aminu Bello"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  (_, decisionCid) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aminu Bello"
      underwriterName     = Some "vetify-underwriting"
      reasonCode          = Some "DSCR_ABOVE_THRESHOLD"
      decisionFactors     = ["DSCR: 1.8", "Sector: Food Retail (Low Risk)"]
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  Some d <- queryContractId p.fi decisionCid
  assertMsg "outcome is FinancingApproved" (d.outcome == FinancingApproved)
  assertMsg "reason is None for approvals" (d.reason == None)
  assertMsg "reasonCode" (d.reasonCode == Some "DSCR_ABOVE_THRESHOLD")
  assertMsg "decisionFactors" (d.decisionFactors == ["DSCR: 1.8", "Sector: Food Retail (Low Risk)"])
  assertMsg "decidedByName" (d.decidedByName == Some "Aminu Bello")

-- F10: FI can override an AI underwriting recommendation.
testOverrideUnderwriting : Script ()
testOverrideUnderwriting = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  officerId <- createUnderwritingOfficer p "Aminu Bello"
  let overriddenAssessment = RiskAssessment with
        score            = 65
        riskCategory     = Medium
        recommendedLimit = 1_500_000.0
        recommendation   = "Manual review: DSCR marginally acceptable given strong sector outlook"
        probabilityOfDefault = None
        lossGivenDefault      = None
        exposureAtDefault     = None
        behaviouralScore      = None
        cashflowRiskScore     = None
        creditworthinessScore = None
        fraudScore            = None
  overriddenCid <- submit p.fi do
    exerciseCmd urCid OverrideUnderwriting with
      overriddenAssessment
      justification       = "Sector growth data not captured by automated model"
      overriddenByName    = "Aminu Bello"
      overrideType        = OverrodeApproval
      overridingOfficerId = officerId
  Some ur <- queryContractId p.fi overriddenCid
  assertMsg "autoDecided is False after override" (not ur.autoDecided)
  assertMsg "overrideJustification" (ur.overrideJustification == Some "Sector growth data not captured by automated model")
  assertMsg "overriddenByName" (ur.overriddenByName == Some "Aminu Bello")
  assertMsg "overrideType" (ur.overrideType == Some OverrodeApproval)
  assertMsg "assessment updated" (ur.assessment.riskCategory == Medium)

-- F11: Maker-checker — approver and underwriter must differ.
testMakerCheckerBlocked : Script ()
testMakerCheckerBlocked = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  aminuId  <- createCreditOfficer p "Aminu Bello"
  fatimaId <- createCreditOfficer p "Fatima Usman"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  -- Same person underwrote and tries to approve → must fail
  submitMustFail p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aminu Bello"
      underwriterName     = Some "Aminu Bello"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = aminuId
  -- Different people → must succeed
  (wad, _) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Fatima Usman"
      underwriterName     = Some "Aminu Bello"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = fatimaId
  Some _ <- queryContractId p.fi wad
  pure ()

-- F13: Borrower withdraws a Submitted request; WithdrawalRecord created on-ledger.
testWithdrawSubmittedRequest : Script ()
testWithdrawSubmittedRequest = do
  p      <- setupFParties
  req    <- submittedRequest p
  wdCid  <- submit p.borrower do
    exerciseCmd req WithdrawRequest with reason = "Supplier price changed"
  Some wd <- queryContractId p.borrower wdCid
  assertMsg "reason" (wd.reason == "Supplier price changed")
  assertMsg "financingRef on record" (wd.financingRef == "FIN-TEST-001")
  -- Original request is archived
  reqs <- query @FinancingRequest p.borrower
  assertMsg "Request archived after withdrawal" (null reqs)

-- F14: Supporting documents are stored on the FinancingRequest.
testSupportingDocuments : Script ()
testSupportingDocuments = do
  p <- setupFParties
  let financialStatement = DocumentRef with
        docType            = "AUDITED_FINANCIALS_2025"
        contentHash        = "sha256:c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2"
        storageRef         = "s3://vetify-docs/RC123456/financials-2025.pdf"
        mimeType           = Some "application/pdf"
        malwareScanStatus  = Some "CLEAN"
        fileSize           = Some 512000
        checksumAlgorithm  = Some "sha256"
        malwareScanAt      = None
        digitalSignature   = None
        signatureAlgorithm = None
        signatoryRef       = None
        signedAt           = None
  req <- submit p.borrower do
    createCmd FinancingRequest with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      status               = Submitted
      financingRef         = "FIN-TEST-DOCS-001"
      verificationRef      = None
      complianceRef        = None
      submittedAt          = None
      supportingDocuments  = [financialStatement, sampleDocRef]
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 0
      assignedUnderwriterId   = None
      assignedUnderwriterName = None
      assignedAt              = None
  Some r <- queryContractId p.borrower req
  assertMsg "two supporting documents" (r.supportingDocuments == [financialStatement, sampleDocRef])

-- F15: Rejection carries structured reason code and decision factors.
testRejectionExplainability : Script ()
testRejectionExplainability = do
  p   <- setupFParties
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  decisionCid <- submit p.fi do
    exerciseCmd updated RejectFunding with
      reason            = "DSCR below minimum policy threshold of 1.2"
      rejectedByName    = Some "Aminu Bello"
      reasonCode        = Some "DSCR_BELOW_THRESHOLD"
      decisionFactors   = ["DSCR: 0.9 (min: 1.2)", "Leverage: High", "Sector: Medium Risk"]
      decisionDocuments = []
  Some d <- queryContractId p.fi decisionCid
  assertMsg "reasonCode" (d.reasonCode == Some "DSCR_BELOW_THRESHOLD")
  assertMsg "decisionFactors count" (d.decisionFactors == ["DSCR: 0.9 (min: 1.2)", "Leverage: High", "Sector: Medium Risk"])
  assertMsg "decidedByName" (d.decidedByName == Some "Aminu Bello")

