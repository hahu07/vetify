-- F26 + F28: policy effective-date validation and loan amount enforcement.
testPolicyGuardsEnforced : Script ()
testPolicyGuardsEnforced = do
  p <- setupFParties
  t <- getTime
  -- Create a policy with maxLoanAmount = ₦1,000,000 (below sample request of ₦2,000,000)
  submit p.vetify do
    createCmd UnderwritingPolicy with
      vetify               = p.vetify
      financialInstitution = p.fi
      policyVersion        = "2026-tight"
      autoApproveMin       = 80
      autoRejectMax        = 50
      minDscrRatio         = Some 1.2
      maxLoanAmount        = Some 1_000_000.0  -- below sampleFinancingTerms.amount (2,000,000)
      requestSlaHours      = 48
      offerValidityDays    = 30
      effectiveFrom        = t
      effectiveTo          = None
      writeOffThresholdAmount      = None
      maxRestructuringsPerFacility = None
      permittedSectors             = None
      requiredCollateralTypes      = []
      maxSectorConcentrationPct    = None
      scoringWeights               = sampleUnderwritingScoringWeights
  req <- submittedRequest p  -- terms.amount = 2,000,000
  -- BeginUnderwriting must fail because amount exceeds maxLoanAmount
  submitMustFail p.vetify do
    exerciseCmd req BeginUnderwriting with
      assessment        = sampleAssessment
      autoDecided       = True
      aiMetadata        = None
      agentVersion      = None
      underwriterName   = None
      underwritingRef   = None
      decisionDocuments = []
  pure ()

