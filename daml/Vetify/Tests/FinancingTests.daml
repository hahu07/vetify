-- ─── Governance review fixes: officer lifecycle (Gaps 3, 4, 5, 9) ────────────

-- Gap 3: Deactivate/Reactivate persist who/when/why, not just discard the reason.
testOfficerDeactivateRecordsAuditTrail : Script ()
testOfficerDeactivateRecordsAuditTrail = do
  p <- setupFParties
  officerId <- createCreditOfficer p "Audited Officer"
  Some (officerCid, _) <- queryByKey @AuthorizedOfficer p.fi (p.fi, officerId)
  deactivatedCid <- submit p.fi do
    exerciseCmd officerCid DeactivateOfficer with
      reason      = "Under investigation"
      performedBy = "FI Compliance Lead"
  Some o <- queryContractId p.fi deactivatedCid
  assertMsg "active is False" (not o.active)
  assertMsg "lastUpdatedBy recorded" (o.lastUpdatedBy == Some "FI Compliance Lead")
  assertMsg "statusReason recorded" (o.statusReason == Some "Under investigation")
  assertMsg "lastUpdatedAt recorded" (o.lastUpdatedAt /= None)
  reactivatedCid <- submit p.fi do
    exerciseCmd deactivatedCid ReactivateOfficer with
      reason      = "Cleared of wrongdoing"
      performedBy = "FI Compliance Lead"
  Some r <- queryContractId p.fi reactivatedCid
  assertMsg "active is True again" r.active
  assertMsg "statusReason updated" (r.statusReason == Some "Cleared of wrongdoing")

-- Gap 9: cannot deactivate an already-inactive officer.
testCannotDeactivateAlreadyInactiveOfficer : Script ()
testCannotDeactivateAlreadyInactiveOfficer = do
  p <- setupFParties
  officerId <- createCreditOfficer p "Double Deactivate Officer"
  Some (officerCid, _) <- queryByKey @AuthorizedOfficer p.fi (p.fi, officerId)
  deactivatedCid <- submit p.fi do
    exerciseCmd officerCid DeactivateOfficer with
      reason = "First deactivation"; performedBy = "FI Compliance"
  submitMustFail p.fi do
    exerciseCmd deactivatedCid DeactivateOfficer with
      reason = "Second deactivation"; performedBy = "FI Compliance"
  pure ()

-- Gap 9: cannot reactivate an already-active officer.
testCannotReactivateAlreadyActiveOfficer : Script ()
testCannotReactivateAlreadyActiveOfficer = do
  p <- setupFParties
  officerId <- createCreditOfficer p "Double Reactivate Officer"
  Some (officerCid, _) <- queryByKey @AuthorizedOfficer p.fi (p.fi, officerId)
  submitMustFail p.fi do
    exerciseCmd officerCid ReactivateOfficer with
      reason = "Already active"; performedBy = "FI Compliance"
  pure ()

-- Gap 5: an expired officer authorization is rejected even though active = True.
testExpiredOfficerAuthorizationBlocked : Script ()
testExpiredOfficerAuthorizationBlocked = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  t <- getTime
  let officerId = "CO-Expired Officer"
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId
      officerName           = "Expired Officer"
      roles                 = [CreditOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = Some t  -- expires immediately
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  passTime (hours 1)  -- now past validUntil
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  submitMustFail p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Expired Officer"
      underwriterName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  pure ()

-- Gap 4: an officer holding multiple roles can act in either capacity.
testOfficerWithMultipleRolesCanActInEitherCapacity : Script ()
testOfficerWithMultipleRolesCanActInEitherCapacity = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  t <- getTime
  let officerId = "CO-Dual Role Officer"
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId
      officerName           = "Dual Role Officer"
      roles                 = [CreditOfficer, UnderwritingOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  req   <- submittedRequest p
  (updated, urCid) <- beginUnderwriting p req
  -- Acts as CreditOfficer for ApproveFunding
  (wad, _) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Dual Role Officer"
      underwriterName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
  Some _ <- queryContractId p.fi wad
  -- Same officer also acts as UnderwritingOfficer for OverrideUnderwriting
  let overriddenAssessment = RiskAssessment with
        score            = 65
        riskCategory     = Medium
        recommendedLimit = 1_500_000.0
        recommendation   = "Manual review"
        probabilityOfDefault = None
        lossGivenDefault      = None
        exposureAtDefault     = None
        behaviouralScore      = None
        cashflowRiskScore     = None
        creditworthinessScore = None
        fraudScore            = None
  overriddenCid <- submit p.fi do
    exerciseCmd urCid OverrideUnderwriting with
      overriddenAssessment
      justification       = "Testing dual-role officer"
      overriddenByName    = "Dual Role Officer"
      overrideType        = OverrodeApproval
      overridingOfficerId = officerId
  Some _ <- queryContractId p.fi overriddenCid
  pure ()

-- ─── Gap F31: OverrideUnderwriting RBAC gating ───────────────────────────────

-- OverrideUnderwriting must fail when the officer is not a registered UnderwritingOfficer.
testOverrideUnderwritingUnregisteredOfficerBlocked : Script ()
testOverrideUnderwritingUnregisteredOfficerBlocked = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  let overriddenAssessment = RiskAssessment with
        score            = 65
        riskCategory     = Medium
        recommendedLimit = 1_500_000.0
        recommendation   = "Manual review"
        probabilityOfDefault = None
        lossGivenDefault      = None
        exposureAtDefault     = None
        behaviouralScore      = None
        cashflowRiskScore     = None
        creditworthinessScore = None
        fraudScore            = None
  submitMustFail p.fi do
    exerciseCmd urCid OverrideUnderwriting with
      overriddenAssessment
      justification       = "Sector growth data not captured by automated model"
      overriddenByName    = "Ghost Officer"
      overrideType        = OverrodeApproval
      overridingOfficerId = "UO-Ghost Officer"
  pure ()

