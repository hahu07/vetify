-- ShariahAssessment stored on ComplianceResult with full structured output.
testShariahAssessmentOnResult : Script ()
testShariahAssessmentOnResult = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (_, result) <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = True
      reviewerParty         = None
      reviewedBy            = None
      agentVersion          = Some "vetify-compliance-v1.0"
      aiMetadata            = Some sampleComplianceAIMetadata
      overrideJustification = None
      reviewNotes           = None
