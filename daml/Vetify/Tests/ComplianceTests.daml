-- ─── Gap 11 (Policy Effective Dates) ─────────────────────────────────────────

-- effectiveTo before effectiveFrom violates ensure → policy creation fails.
testPolicyEffectiveDateRange : Script ()
testPolicyEffectiveDateRange = do
  p <- setupCParties
  t <- getTime
  submitMustFail p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = addRelTime t (hours 24)  -- future
      effectiveTo          = Some t                   -- past (before effectiveFrom) → invalid
      scoringWeights       = sampleComplianceScoringWeights
  pure ()

-- ─── Gap 13 (Reviewer Independence) ──────────────────────────────────────────

-- Borrower cannot be set as the compliance reviewer.
testReviewerCannotBeBorrower : Script ()
testReviewerCannotBeBorrower = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.borrower   -- borrower as reviewer → fails
      reviewedBy            = Some "Borrower"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  pure ()

-- ─── Gap 1 (new): SLA escalation ────────────────────────────────────────────

-- SLA window expired: EscalateOverdue moves UnderReview → ManualReview.
testEscalateOverdue : Script ()
testEscalateOverdue = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  passTime (hours 49)
  escalated <- submit p.vetify do
    exerciseCmd ur EscalateOverdue with fallbackSlaHours = 48
  Some e <- queryContractId p.vetify escalated
  assertMsg "status is ManualReview after escalation" (e.status == ManualReview)
  pure ()

-- SLA window not yet expired: EscalateOverdue is rejected.
testEscalateBeforeSlaExpiry : Script ()
testEscalateBeforeSlaExpiry = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  passTime (hours 24)
  submitMustFail p.vetify do
    exerciseCmd ur EscalateOverdue with fallbackSlaHours = 48
  pure ()

-- ─── Gap 2 (new): AML evidence refs ─────────────────────────────────────────

-- Evidence refs passed to ApproveCompliance are persisted on ComplianceResult.
testAmlEvidenceOnResult : Script ()
testAmlEvidenceOnResult = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (_, result) <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = True
      reviewerParty         = None
      reviewedBy            = None
      agentVersion          = Some "vetify-compliance-v1.0"
      aiMetadata            = Some sampleComplianceAIMetadata
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = Some sampleAmlEvidence
      complianceDocuments   = []
      shariahAssessment     = None
  Some cr <- queryContractId p.vetify result
  assertMsg "amlEvidence stored on result" (cr.amlEvidence == Some sampleAmlEvidence)
  pure ()

-- ─── Gap 4 (new): ApprovedBorrower lifecycle ─────────────────────────────────

-- Suspended borrower cannot request new financing.
testSuspendPreventsFinancing : Script ()
testSuspendPreventsFinancing = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  suspended <- submit p.vetify do
    exerciseCmd approved Suspend with reason = "Suspicious activity detected"
  submitMustFail p.borrower do
    exerciseCmd suspended RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-SUSP-001"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

-- Reinstate restores Active status and financing access.
testSuspendReinstate : Script ()
testSuspendReinstate = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  suspended <- submit p.vetify do
    exerciseCmd approved Suspend with reason = "Monitoring alert"
  reinstated <- submit p.vetify do
    exerciseCmd suspended Reinstate with reason = "Alert cleared — false positive"
  Some r <- queryContractId p.vetify reinstated
  assertMsg "status is Active after reinstate" (r.status == BorrowerActive)
  _ <- submit p.borrower do
    exerciseCmd reinstated RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-REINST-001"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

-- Revoke archives the ApprovedBorrower permanently.
testRevoke : Script ()
testRevoke = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  revRecord <- submit p.vetify do
    exerciseCmd approved Revoke with
      reason    = "Fraudulent application confirmed"
      revokedBy = "Senior Compliance Officer"
  result <- queryContractId p.borrower approved
  assertMsg "ApprovedBorrower archived on revocation" (result == None)
  Some rr <- queryContractId p.vetify revRecord
  assertMsg "reason on RevocationRecord" (rr.reason == "Fraudulent application confirmed")
  assertMsg "cacRegNumber on RevocationRecord" (rr.cacRegNumber == "RC123456")
  pure ()

-- ─── Gap 5 (new): Periodic re-certification ──────────────────────────────────

-- RequestRecertification archives ApprovedBorrower and creates a fresh ComplianceReview.
testRecertification : Script ()
testRecertification = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  newReview <- submit p.vetify do
    exerciseCmd approved RequestRecertification with
      verifier = p.verifier
      newComplianceRef  = "COM-2026-000002"
      reason            = "Annual re-KYC/re-KYB required by CBN NIFI Framework"
  -- Old ApprovedBorrower is archived
  old <- queryContractId p.borrower approved
  assertMsg "Old ApprovedBorrower archived" (old == None)
  -- New ComplianceReview is pending
  Some nr <- queryContractId p.vetify newReview
  assertMsg "New review is Pending" (nr.status == Pending)
  assertMsg "complianceRef is new" (nr.complianceRef == "COM-2026-000002")
  assertMsg "verificationRef carried from original" (nr.verificationRef == "VER-2026-000001")
  pure ()

-- ─── Gap 14 (Four-Eyes Principle) ────────────────────────────────────────────

-- The person who created the review cannot be the same one who approves it.
testFourEyesApproval : Script ()
testFourEyesApproval = do
  p <- setupCParties
  t <- getTime
  -- Create the review with a named creator
  rv <- submit p.vetify do
    createCmd ComplianceReview with
      borrower                = p.borrower
      vetify                  = p.vetify
      verifier                = p.verifier
      businessName            = sampleProfile.name
      cacRegNumber            = sampleKyc.cacRegNumber
      businessSector          = sampleProfile.businessSector
      businessActivity        = sampleProfile.businessActivity
      incorporationDate       = sampleProfile.incorporationDate
      verificationRef         = "VER-2026-000001"
      complianceRef           = "COM-2026-000001"
      status                  = Pending
      checks                  = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
      createdAt               = Some t
      reviewStartedAt         = None
      compliancePolicyVersion = None
      policySnapshot          = None
      createdBy               = Some "Fatima Al-Hassan"  -- same name as reviewer below
      shariahVerdict          = None
  ur <- submit p.vetify do exerciseCmd rv StartReview
  -- Reviewer is the same person as creator → fails (four-eyes violation)
  submitMustFail p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  -- Different reviewer → succeeds
  _ <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Amina Ibrahim"   -- different from createdBy
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  pure ()

-- ─── Gap 15 (Role Authorization) ─────────────────────────────────────────────

-- Deauthorizing the compliance officer prevents further approvals.
testDeauthorizedReviewerBlocked : Script ()
testDeauthorizedReviewerBlocked = do
  p <- setupCParties
  -- Fetch and deauthorize the AuthorizedReviewer created by setupCParties
  Some (authCid, _) <- queryByKey @AuthorizedReviewer p.vetify (p.vetify, p.verifier)
  submit p.vetify do
    exerciseCmd authCid Deauthorize with reason = "Officer resigned"
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  pure ()

-- ─── Gap 16 (Policy Snapshot) ────────────────────────────────────────────────

-- Full policy snapshot (not just version string) is stored on ComplianceResult.
testPolicySnapshotOnResult : Script ()
testPolicySnapshotOnResult = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (_, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  Some cr <- queryContractId p.vetify result
  case cr.policySnapshot of
    None -> assertFail "Expected policySnapshot to be captured at StartReview"
    Some snap -> do
      assertMsg "snapshot.policyVersion matches" (snap.policyVersion == "2026-v3")
      assertMsg "snapshot.autoApproveMin matches" (snap.autoApproveMin == 80)
      assertMsg "snapshot.escalationSlaHours matches" (snap.escalationSlaHours == 48)
  pure ()

-- ─── Gap 20 (Assignment Workflow) ────────────────────────────────────────────

-- AssignReview changes the verifier on a Pending review.
testAssignReview : Script ()
testAssignReview = do
  p <- setupCParties
  -- Allocate a second officer and authorize them
  officer2 <- allocateParty "Verifier2"
  t <- getTime
  submit p.vetify do
    createCmd AuthorizedReviewer with
      vetify            = p.vetify
      verifier = officer2
      authorizedBy      = "Vetify Admin"
      authorizedAt      = t
      role              = "Compliance Officer"
  rv <- pendingReview p
  -- Assign to officer2
  reassigned <- submit p.vetify do
    exerciseCmd rv AssignReview with
      newOfficer     = officer2
      assignedByName = "Head of Compliance"
  Some r <- queryContractId p.vetify reassigned
  assertMsg "verifier updated to officer2" (r.verifier == officer2)
  assertMsg "still Pending after assignment" (r.status == Pending)
  pure ()

-- ─── Gap 21 (Officer Reassignment) ───────────────────────────────────────────

-- ReassignReview changes the officer mid-review; same officer is rejected.
testReassignReview : Script ()
testReassignReview = do
  p <- setupCParties
  officer2 <- allocateParty "Verifier2"
  t <- getTime
  submit p.vetify do
    createCmd AuthorizedReviewer with
      vetify            = p.vetify
      verifier = officer2
      authorizedBy      = "Vetify Admin"
      authorizedAt      = t
      role              = "Compliance Officer"
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  -- Reassign to same officer → fails
  submitMustFail p.vetify do
    exerciseCmd ur ReassignReview with
      newOfficer = p.verifier
      reason     = "No change"
  -- Reassign to different officer → succeeds
  reassigned <- submit p.vetify do
    exerciseCmd ur ReassignReview with
      newOfficer = officer2
      reason     = "Original officer on leave"
  Some r <- queryContractId p.vetify reassigned
  assertMsg "verifier updated" (r.verifier == officer2)
  pure ()

-- ─── Gap 22 (Expiry Lifecycle) ────────────────────────────────────────────────

-- ExpireBorrower transitions Active → BorrowerExpired after expiresAt.
testExpireBorrower : Script ()
testExpireBorrower = do
  p <- setupCParties
  t <- getTime
  ab <- submit p.vetify do
    createCmd ApprovedBorrower with
      borrower         = p.borrower
      vetify           = p.vetify
      businessName      = sampleProfile.name
      cacRegNumber      = sampleKyc.cacRegNumber
      businessSector    = sampleProfile.businessSector
      businessActivity  = sampleProfile.businessActivity
      incorporationDate = sampleProfile.incorporationDate
      verificationRef   = "VER-2026-000001"
      complianceRef     = "COM-2026-000001"
      approvedAt        = t
      status           = BorrowerActive
      expiresAt        = Some t
      suspendedAt      = None
      suspendedReason  = None
      reinstatedAt     = None
      reinstatedReason = None
  -- Cannot expire before the deadline passes
  submitMustFail p.vetify do
    exerciseCmd ab ExpireBorrower with reason = "Annual review"
  passTime (hours 1)
  expired <- submit p.vetify do
    exerciseCmd ab ExpireBorrower with reason = "Annual approval period ended"
  Some e <- queryContractId p.vetify expired
  assertMsg "status is BorrowerExpired" (e.status == BorrowerExpired)
  -- Expired borrower cannot request financing
  submitMustFail p.borrower do
    exerciseCmd expired RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-EXP-002"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

