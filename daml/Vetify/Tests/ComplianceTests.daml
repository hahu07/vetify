-- | Stage 3–4 tests: compliance approve/reject, AI governance, correction workflow,
--   policy version derivation, validation guards, and repeat financing requests.
module Vetify.Tests.ComplianceTests where

import DA.Time (hours, addRelTime)
import Daml.Script
import Vetify.Types
import Vetify.Compliance
import Vetify.Governance
import Vetify.Financing (FinancingRequest)
import Vetify.Tests.Fixtures

data CParties = CParties with
  borrower          : Party
  vetify            : Party
  verifier : Party
  fi                : Party
  riskCommittee     : Party

setupCParties : Script CParties
setupCParties = do
  borrower          <- allocateParty "Borrower"
  vetify            <- allocateParty "Vetify"
  verifier <- allocateParty "Verifier"
  fi                <- allocateParty "FI"
  riskCommittee     <- allocateParty "RiskCommittee"
  -- Gap 15: authorize the compliance officer so ApproveCompliance/RejectCompliance pass
  t <- getTime
  submit vetify do
    createCmd AuthorizedReviewer with
      vetify            = vetify
      verifier = verifier
      authorizedBy      = "Vetify Admin"
      authorizedAt      = t
      role              = "Senior Compliance Officer"
  pure CParties with ..

-- Helper: Pending ComplianceReview with all audit fields populated
pendingReview : CParties -> Script (ContractId ComplianceReview)
pendingReview p = do
  t <- getTime
  submit p.vetify do
    createCmd ComplianceReview with
      borrower                = p.borrower
      vetify                  = p.vetify
      verifier                = p.verifier
      businessName            = sampleProfile.name
      cacRegNumber            = sampleKyc.cacRegNumber
      businessSector          = sampleProfile.businessSector
      businessActivity        = sampleProfile.businessActivity
      incorporationDate       = sampleProfile.incorporationDate
      verificationRef         = "VER-2026-000001"
      complianceRef           = "COM-2026-000001"
      status                  = Pending
      checks                  = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
      createdAt               = Some t
      reviewStartedAt         = None
      compliancePolicyVersion = None
      policySnapshot          = None
      createdBy               = None
      shariahVerdict          = None

-- Helper: agent auto-approves on the happy path
agentApproveCompliance : ContractId ComplianceReview -> ComplianceCheck -> Int -> RiskLevel -> Commands (ContractId ApprovedBorrower, ContractId ComplianceResult)
agentApproveCompliance cid checks score level =
  exerciseCmd cid ApproveCompliance with
    completedChecks       = checks
    riskScore             = score
    riskLevel             = level
    autoDecided           = True
    reviewerParty         = None
    reviewedBy            = None
    agentVersion          = Some "vetify-compliance-v1.0"
    aiMetadata            = Some sampleComplianceAIMetadata
    overrideJustification = None
    reviewNotes           = None
    overrideType          = None
    amlEvidence           = Some sampleAmlEvidence
    complianceDocuments   = []
    shariahAssessment     = None

-- ─── Shariah pre-check decoupling ────────────────────────────────────────────

-- RecordShariahPreCheck persists the decoupled Shariah Agent's verdict on the
-- review without transitioning status — StartReview still runs afterward.
testRecordShariahPreCheck : Script ()
testRecordShariahPreCheck = do
  p  <- setupCParties
  rv <- pendingReview p
  recorded <- submit p.vetify do
    exerciseCmd rv RecordShariahPreCheck with verdict = sampleShariahAssessment
  Some r <- queryContractId p.vetify recorded
  assertMsg "shariahVerdict recorded" (r.shariahVerdict == Some sampleShariahAssessment)
  assertMsg "status still Pending — StartReview not yet run" (r.status == Pending)
  -- StartReview still works normally afterward
  ur <- submit p.vetify do exerciseCmd recorded StartReview
  Some ur' <- queryContractId p.vetify ur
  assertMsg "shariahVerdict carried through StartReview" (ur'.shariahVerdict == Some sampleShariahAssessment)
  assertMsg "status is UnderReview after StartReview" (ur'.status == UnderReview)

-- RecordShariahPreCheck cannot be recorded twice for the same review.
testCannotRecordShariahPreCheckTwice : Script ()
testCannotRecordShariahPreCheckTwice = do
  p  <- setupCParties
  rv <- pendingReview p
  recorded <- submit p.vetify do
    exerciseCmd rv RecordShariahPreCheck with verdict = sampleShariahAssessment
  submitMustFail p.vetify do
    exerciseCmd recorded RecordShariahPreCheck with verdict = sampleShariahAssessment
  pure ()

-- ─── Happy path ──────────────────────────────────────────────────────────────

testApproveCompliance : Script ()
testApproveCompliance = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  Some ab <- queryContractId p.vetify approved
  assertMsg "cacRegNumber on ApprovedBorrower" (ab.cacRegNumber == "RC123456")
  assertMsg "verificationRef on ApprovedBorrower" (ab.verificationRef == "VER-2026-000001")
  assertMsg "complianceRef on ApprovedBorrower" (ab.complianceRef == "COM-2026-000001")
  Some cr <- queryContractId p.vetify result
  assertMsg "outcome is Approved" (cr.outcome == Approved)
  assertMsg "agentVersion on result" (cr.agentVersion == Some "vetify-compliance-v1.0")
  assertMsg "aiMetadata on result" (cr.aiMetadata /= None)
  pure ()

-- Review finding F6: a rejection persists as an on-ledger ComplianceResult.
testRejectComplianceIsRecorded : Script ()
testRejectComplianceIsRecorded = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  result <- submit p.verifier do
    exerciseCmd ur RejectCompliance with
      completedChecks       = passingCompliance with amlCleared = False
      riskScore             = 20
      riskLevel             = High
      autoDecided           = True
      reason                = "Adverse media match — sanctions list"
      reviewerParty         = None
      reviewedBy            = None
      agentVersion          = Some "vetify-compliance-v1.0"
      aiMetadata            = Some sampleComplianceAIMetadata
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = Some sampleAmlEvidence
      complianceDocuments   = []
      shariahAssessment     = None
  Some cr <- queryContractId p.vetify result
  assertMsg "outcome is Rejected" (cr.outcome == Rejected)
  assertMsg "reason on-ledger" (cr.reason == Some "Adverse media match — sanctions list")
  assertMsg "complianceRef carried to result" (cr.complianceRef == "COM-2026-000001")
  pure ()

-- Review finding F3: ApprovedBorrower is nonconsuming — repeat facilities allowed.
testRepeatFinancingRequests : Script ()
testRepeatFinancingRequests = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  _ <- submit p.borrower do
    exerciseCmd approved RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-001-A"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  _ <- submit p.borrower do
    exerciseCmd approved RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms with amount = 500_000.0, purpose = "Working capital"
      financingRef         = "FIN-COMP-001-B"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  reqs <- query @FinancingRequest p.borrower
  assertMsg "two financing requests" (length reqs == 2)
  pure ()

-- Authorization: only the compliance officer can approve
testOnlyOfficerCanApprove : Script ()
testOnlyOfficerCanApprove = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.vetify do
    agentApproveCompliance ur passingCompliance 88 Low
  pure ()

-- ─── Gap 3: Policy version derivation ────────────────────────────────────────

-- When a CompliancePolicy is active, StartReview snapshots its policyVersion.
-- ApproveCompliance uses that snapshot on the result — not a caller parameter.
testPolicyVersionDerivedInStartReview : Script ()
testPolicyVersionDerivedInStartReview = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v2"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  -- Verify the snapshot was stored on the review
  Some ur' <- queryContractId p.vetify ur
  assertMsg "compliancePolicyVersion snapshotted at StartReview"
    (ur'.compliancePolicyVersion == Some "2026-v2")
  (_, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  Some cr <- queryContractId p.vetify result
  assertMsg "ComplianceResult carries the snapshotted policyVersion"
    (cr.compliancePolicyVersion == "2026-v2")
  pure ()

-- ─── Gap 4: Validation ───────────────────────────────────────────────────────

-- All four compliance checks must pass before approval is permitted.
testCannotApproveWithFailedAmlCheck : Script ()
testCannotApproveWithFailedAmlCheck = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.verifier do
    agentApproveCompliance ur (passingCompliance with amlCleared = False) 88 Low
  pure ()

-- Score/level consistency: Low risk must have score >= 80.
testScoreLevelMismatchBlocked : Script ()
testScoreLevelMismatchBlocked = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  -- Score 65 is Medium range (50–79) but riskLevel claims Low
  submitMustFail p.verifier do
    agentApproveCompliance ur passingCompliance 65 Low
  pure ()

-- Human decisions must identify the reviewing party (reviewerParty).
testHumanDecisionRequiresReviewerParty : Script ()
testHumanDecisionRequiresReviewerParty = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False   -- human decision
      reviewerParty         = None    -- but no reviewer party → fails
      reviewedBy            = None
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  pure ()

-- High-risk cannot be auto-approved; must go to human review.
testHighRiskCannotBeAutoApproved : Script ()
testHighRiskCannotBeAutoApproved = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  submitMustFail p.verifier do
    agentApproveCompliance ur passingCompliance 30 High
  pure ()

-- Override justification required when human decides after agent flagged.
testOverrideJustificationRequired : Script ()
testOverrideJustificationRequired = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  flagged <- submit p.vetify do
    exerciseCmd ur FlagComplianceForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-compliance-v1.0"
      note         = "Borderline AML match — refer to human"
  -- Human approves without justification after agent flagged → fails
  submitMustFail p.verifier do
    exerciseCmd flagged ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None   -- missing → fails
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  pure ()

-- ─── Gap 1 + Gap 5: AI governance and manual review audit ────────────────────

-- agentNote and agentVersion are persisted on ComplianceReview at flag time.
testFlagPreservesAgentAudit : Script ()
testFlagPreservesAgentAudit = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  flagged <- submit p.vetify do
    exerciseCmd ur FlagComplianceForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-compliance-v1.0"
      note         = "Borderline NIN match — refer to human"
  Some f <- queryContractId p.vetify flagged
  assertMsg "agentNote persisted" (f.agentNote == Some "Borderline NIN match — refer to human")
  assertMsg "agentVersion persisted" (f.agentVersion == Some "vetify-compliance-v1.0")
  assertMsg "agentScore persisted" (f.agentScore == Some 65)
  pure ()

-- Human approval after agent flag: overrideType and reviewNotes are recorded.
testHumanOverrideAuditTrail : Script ()
testHumanOverrideAuditTrail = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  flagged <- submit p.vetify do
    exerciseCmd ur FlagComplianceForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-compliance-v1.0"
      note         = "Borderline AML match"
  (_, result) <- submit p.verifier do
    exerciseCmd flagged ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = Some "Full manual re-check: AML match was a false positive (name collision)"
      reviewNotes           = Some "Verified against CBN exclusion list; not the same entity"
      overrideType          = Some OverrodeApproval
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  Some cr <- queryContractId p.vetify result
  assertMsg "reviewerParty recorded" (cr.reviewerParty == Some p.verifier)
  assertMsg "reviewedBy recorded" (cr.reviewedBy == Some "Fatima Al-Hassan")
  assertMsg "overrideJustification recorded" (cr.overrideJustification /= None)
  assertMsg "reviewNotes recorded" (cr.reviewNotes /= None)
  assertMsg "overrideType recorded" (cr.overrideType == Some OverrodeApproval)
  pure ()

-- ─── Gap 2: Correction workflow ──────────────────────────────────────────────

-- Supersede creates a ComplianceCorrection leaving the original result intact.
testSupersede : Script ()
testSupersede = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (_, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  -- Vetify supersedes the incorrect Approved result with a Rejected correction
  correction <- submit p.vetify do
    exerciseCmd result Supersede with
      correctionRef    = "COR-2026-000001"
      correctedOutcome = Rejected
      reason           = "Agent misclassified — AML positive on re-run confirmed as true positive"
      correctedBy      = "Compliance Team"
  Some cc <- queryContractId p.vetify correction
  assertMsg "originalComplianceRef" (cc.originalComplianceRef == "COM-2026-000001")
  assertMsg "originalOutcome is Approved" (cc.originalOutcome == Approved)
  assertMsg "correctedOutcome is Rejected" (cc.correctedOutcome == Rejected)
  -- Original result still active
  Some cr <- queryContractId p.vetify result
  assertMsg "original result still active (immutable audit trail)" (cr.outcome == Approved)
  pure ()

-- ─── Gap 2: CompliancePolicy band enforcement ────────────────────────────────

testFlagBandEnforced : Script ()
testFlagBandEnforced = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv1 <- pendingReview p
  ur1 <- submit p.vetify do exerciseCmd rv1 StartReview
  -- Score 85 >= autoApproveMin 80: should have auto-approved, not flagged
  submitMustFail p.vetify do
    exerciseCmd ur1 FlagComplianceForManualReview with
      riskScore = 85, riskLevel = Low, agentVersion = "v1.0", note = "test"
  -- Score 40 < autoRejectMax 50: should have auto-rejected, not flagged
  submitMustFail p.vetify do
    exerciseCmd ur1 FlagComplianceForManualReview with
      riskScore = 40, riskLevel = High, agentVersion = "v1.0", note = "test"
  -- Score 65 in band [50, 80): correct medium risk → succeeds
  flagged <- submit p.vetify do
    exerciseCmd ur1 FlagComplianceForManualReview with
      riskScore = 65, riskLevel = Medium, agentVersion = "vetify-compliance-v1.0"
      note = "Borderline NIN match — refer to human"
  Some f <- queryContractId p.vetify flagged
  assertMsg "status is ManualReview" (f.status == ManualReview)
  assertMsg "agentScore recorded" (f.agentScore == Some 65)
  pure ()

-- ─── Gap 4 + Gap 1: timestamps and review lifecycle ──────────────────────────

testTimestampsAndAuditChain : Script ()
testTimestampsAndAuditChain = do
  p  <- setupCParties
  rv <- pendingReview p
  Some rv' <- queryContractId p.vetify rv
  assertMsg "createdAt is set at creation" (rv'.createdAt /= None)
  ur <- submit p.vetify do exerciseCmd rv StartReview
  Some ur' <- queryContractId p.vetify ur
  assertMsg "reviewStartedAt set by StartReview" (ur'.reviewStartedAt /= None)
  (approved, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  Some cr <- queryContractId p.vetify result
  assertMsg "verificationRef on result" (cr.verificationRef == "VER-2026-000001")
  assertMsg "complianceRef on result" (cr.complianceRef == "COM-2026-000001")
  Some ab <- queryContractId p.vetify approved
  assertMsg "verificationRef on ApprovedBorrower" (ab.verificationRef == "VER-2026-000001")
  assertMsg "complianceRef on ApprovedBorrower" (ab.complianceRef == "COM-2026-000001")
  assertMsg "ApprovedBorrower status is Active" (ab.status == BorrowerActive)
  assertMsg "reviewStartedAt carried to ComplianceResult (gap 3)" (cr.reviewStartedAt /= None)
  pure ()

-- ─── Gap 1 (Maker-Checker) ───────────────────────────────────────────────────

-- Corrector cannot be the same person as the original human reviewer.
testMakerCheckerSupersede : Script ()
testMakerCheckerSupersede = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (_, result) <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
  -- Same person as original reviewer → fails
  submitMustFail p.vetify do
    exerciseCmd result Supersede with
      correctionRef    = "COR-2026-000001"
      correctedOutcome = Rejected
      reason           = "Re-run confirmed positive"
      correctedBy      = "Fatima Al-Hassan"
  -- Different person → succeeds
  _ <- submit p.vetify do
    exerciseCmd result Supersede with
      correctionRef    = "COR-2026-000001"
      correctedOutcome = Rejected
      reason           = "Re-run confirmed positive"
      correctedBy      = "Head of Compliance"
  pure ()

-- ─── Gap 4 (Expiry Enforcement) ──────────────────────────────────────────────

-- RequestFinancing fails when the ApprovedBorrower approval has expired.
testExpiryEnforced : Script ()
testExpiryEnforced = do
  p <- setupCParties
  t <- getTime
  approved <- submit p.vetify do
    createCmd ApprovedBorrower with
      borrower         = p.borrower
      vetify           = p.vetify
      businessName      = sampleProfile.name
      cacRegNumber      = sampleKyc.cacRegNumber
      businessSector    = sampleProfile.businessSector
      businessActivity  = sampleProfile.businessActivity
      incorporationDate = sampleProfile.incorporationDate
      verificationRef   = "VER-2026-000001"
      complianceRef     = "COM-2026-000001"
      approvedAt        = t
      status           = BorrowerActive
      expiresAt        = Some t   -- expires at current ledger time
      suspendedAt      = None
      suspendedReason  = None
      reinstatedAt     = None
      reinstatedReason = None
  passTime (hours 1)
  submitMustFail p.borrower do
    exerciseCmd approved RequestFinancing with
      financialInstitution = p.fi
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-EXP-001"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

-- ─── Gap 5 (Suspension Audit) ────────────────────────────────────────────────

-- Suspend stores suspendedAt and suspendedReason on the contract.
testSuspensionAuditFields : Script ()
testSuspensionAuditFields = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  suspended <- submit p.vetify do
    exerciseCmd approved Suspend with reason = "Monitoring alert — adverse media match"
  Some s <- queryContractId p.vetify suspended
  assertMsg "status is Suspended" (s.status == BorrowerSuspended)
  assertMsg "suspendedReason recorded" (s.suspendedReason == Some "Monitoring alert — adverse media match")
  assertMsg "suspendedAt recorded" (s.suspendedAt /= None)
  pure ()

-- ─── Gap 6 (Reinstatement Audit) ─────────────────────────────────────────────

-- Reinstate stores reinstatedAt and reinstatedReason; suspension data is preserved.
testReinstatementAuditFields : Script ()
testReinstatementAuditFields = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  suspended <- submit p.vetify do
    exerciseCmd approved Suspend with reason = "Monitoring alert"
  reinstated <- submit p.vetify do
    exerciseCmd suspended Reinstate with reason = "Alert cleared — confirmed false positive"
  Some r <- queryContractId p.vetify reinstated
  assertMsg "status restored to Active" (r.status == BorrowerActive)
  assertMsg "reinstatedReason recorded" (r.reinstatedReason == Some "Alert cleared — confirmed false positive")
  assertMsg "reinstatedAt recorded" (r.reinstatedAt /= None)
  assertMsg "suspendedReason preserved for audit" (r.suspendedReason == Some "Monitoring alert")
  pure ()

-- ─── Gap 7 (Revocation Audit) ────────────────────────────────────────────────

-- Revoke creates an immutable RevocationRecord (the testRevoke above covers archival).
testRevocationRecord : Script ()
testRevocationRecord = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low
  revRecord <- submit p.vetify do
    exerciseCmd approved Revoke with
      reason    = "Confirmed fraudulent application"
      revokedBy = "Chief Compliance Officer"
  Some rr <- queryContractId p.vetify revRecord
  assertMsg "revokedBy on record" (rr.revokedBy == "Chief Compliance Officer")
  assertMsg "complianceRef links to original approval" (rr.complianceRef == "COM-2026-000001")
  pure ()

