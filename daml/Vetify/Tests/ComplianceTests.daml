      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with approvedBy = "Bob (Risk Manager)"
  pure ()

-- Layer 2 of the Policy-Approval Security Roadmap: vetify cannot finalize a
-- compliance policy change on its own, even with a validly registered
-- approver, until the Risk Committee's own separately-signed transaction has
-- endorsed it.
testCompliancePolicyChangeFailsWithoutRiskCommitteeEndorsement : Script ()
testCompliancePolicyChangeFailsWithoutRiskCommitteeEndorsement = do
  p <- setupCParties
  t <- getTime
  submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  -- No EndorseByRiskCommittee call — a registered approver alone is not enough.
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with approvedBy = "Bob (Risk Manager)"
  pure ()

-- EndorseByRiskCommittee cannot be exercised twice on the same proposal.
testCompliancePolicyChangeCannotDoubleEndorse : Script ()
testCompliancePolicyChangeCannotDoubleEndorse = do
  p <- setupCParties
  t <- getTime
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  submitMustFail p.riskCommittee do
    exerciseCmd endorsed EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  pure ()
