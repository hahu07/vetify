  req <- submit p.borrower do
    exerciseCmd c RequestIbra with
      requestedSettlementDate = date 2026 Dec 1
      settlementType          = FullIbra
      requestedAmount         = None
  grantCid <- submit p.fi do
    exerciseCmd req GrantIbra with
      rebateAmount         = 75_000.0
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  Some gr <- queryContractId p.fi grantCid
  assertMsg "Grant record: rebate amount" (gr.rebateAmount == 75_000.0)
  assertMsg "Grant record: outstanding balance" (gr.outstandingBalance == 2_300_000.0)
  assertMsg "Grant record visible to borrower" True
  Some _ <- queryContractId p.borrower grantCid
  pure ()

