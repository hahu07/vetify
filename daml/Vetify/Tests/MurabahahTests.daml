-- ─── Payment guards ───────────────────────────────────────────────────────

-- On-time payment reduces balance, creates RepaymentRecord, no charity
testRecordPaymentOnTime : Script ()
testRecordPaymentOnTime = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some uc <- queryContractId p.fi payRes.updatedContract
  assertMsg "installmentsPaid should be 1" (uc.installmentsPaid == 1)
  Some r <- queryContractId p.regulator payRes.repaymentRecord
  assertMsg "Payment should not be late" (not r.wasLate)
  assertMsg "No charity obligation for on-time payment" (payRes.charityObligation == None)

-- Idempotency: replaying the same directDebitRef must be rejected even for a
-- different (subsequent) installment.
testRecordPaymentRejectsDuplicateDirectDebitRef : Script ()
testRecordPaymentRejectsDuplicateDirectDebitRef = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef    = Some "MONO-COLLECT-2026-0001"
  submitMustFail p.fi do
    exerciseCmd payRes.updatedContract RecordPayment with
      paymentDate       = date 2026 Aug 1
      amountPaid        = 191_666.67
      installmentNo     = 2
      allocation        = None
      settlementAccount = None
      directDebitRef    = Some "MONO-COLLECT-2026-0001"  -- replayed reference
  pure ()

-- A different directDebitRef for the next installment succeeds normally.
testRecordPaymentAllowsDistinctDirectDebitRef : Script ()
testRecordPaymentAllowsDistinctDirectDebitRef = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes1 <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef    = Some "MONO-COLLECT-2026-0002"
  payRes2 <- submit p.fi do
    exerciseCmd payRes1.updatedContract RecordPayment with
      paymentDate       = date 2026 Aug 1
      amountPaid        = 191_666.67
      installmentNo     = 2
      allocation        = None
      settlementAccount = None
      directDebitRef    = Some "MONO-COLLECT-2026-0003"
  Some uc <- queryContractId p.fi payRes2.updatedContract
  assertMsg "installmentsPaid should be 2" (uc.installmentsPaid == 2)

-- Overpayment rejected
testRejectsOverpayment : Script ()
testRejectsOverpayment = do
  p <- setupMParties
  c <- activeContractDirect p
  submitMustFail p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Jul 1, amountPaid = 5_000_000.0, installmentNo = 1, allocation = None, settlementAccount = None, directDebitRef = None
  pure ()

