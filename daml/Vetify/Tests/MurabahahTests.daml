  submitMustFail p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Jul 1, amountPaid = 0.0, installmentNo = 1, allocation = None, settlementAccount = None, directDebitRef = None
  pure ()

-- Out-of-sequence installment rejected
testRejectsOutOfSequenceInstallment : Script ()
testRejectsOutOfSequenceInstallment = do
