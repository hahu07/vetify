testCollateralInspection : Script ()
testCollateralInspection = do
  p    <- setupMParties
  rahn <- createRahn p
  inspCid <- submit p.fi do
    exerciseCmd rahn RecordInspection with
      inspectionDate     = date 2026 Sep 15
