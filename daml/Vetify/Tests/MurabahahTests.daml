-- ─── C-1: facilityRef contract key ───────────────────────────────────────────

-- MurabahahContract can be fetched by its (borrower, fi, facilityRef) key.
testFacilityRefKeyLookup : Script ()
testFacilityRefKeyLookup = do
  p  <- setupMParties
  _  <- activeContractViaWakala p
  result <- queryByKey @MurabahahContract p.fi (p.borrower, p.fi, "FAC-2026-RC123456-001")
  case result of
    None         -> assertFail "MurabahahContract not found by facilityRef key"
    Some (_, mc) -> assertMsg "facilityRef matches" (mc.facilityRef == "FAC-2026-RC123456-001")

-- ─── C-2: Full acquisition cost disclosure ───────────────────────────────────

-- ensure clause rejects mismatched totalAcquisitionCost; OfferMurabahah guard
-- requires murabahahTerms.assetCost == totalAcquisitionCost (AAOIFI §3/3).
testFullCostDisclosure : Script ()
testFullCostDisclosure = do
  p <- setupMParties
  -- Ensure clause: direct creation with mismatched totalAcquisitionCost is rejected
  submitMustFail p.fi do
    createCmd AssetPurchaseRecord with
      borrower              = p.borrower
      vetify                = p.vetify
      financialInstitution  = p.fi
      businessName          = sampleProfile.name
      cacRegNumber          = sampleKyc.cacRegNumber
      terms                 = sampleFinancingTerms
      assetDetails          = sampleAssetDetails
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "TEST-001"
      freightCost           = 50_000.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
      totalAcquisitionCost  = 2_000_000.0  -- wrong; should be 2_050_000
      purchasedViaWakala    = False
      deliveryAcknowledged  = False
      ownershipDocuments    = []
      supplierDetails       = None
      additionalAssets      = []
  -- Build an APR via Wakala with non-zero freight cost
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  wakala <- submit p.fi do exerciseCmd wad ProceedWithWakala
  -- actualCost=2_000_000 + freight=50_000 → totalAcquisitionCost=2_050_000
  apr <- submit p.borrower do
    exerciseCmd wakala RecordAssetPurchase with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "LMS-INV-001"
      freightCost           = 50_000.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  Some aprc <- queryContractId p.fi apr
  assertMsg "totalAcquisitionCost = actualCost + freight" (aprc.totalAcquisitionCost == 2_050_000.0)
  aprAcked <- submit p.borrower do exerciseCmd apr AcknowledgeDelivery
  -- OfferMurabahah with assetCost=2_000_000 (raw) fails (≠ totalAcquisitionCost=2_050_000)
  submitMustFail p.fi do
    exerciseCmd aprAcked OfferMurabahah with
      murabahahTerms      = sampleMurabahahTerms  -- assetCost=2_000_000
      paymentSchedule     = samplePaymentSchedule
      regulator           = Some p.regulator
      facilityRef         = "FAC-2026-RC123456-001"
      startDate           = date 2026 Jul 1
      acceptanceExpiresAt = None
  -- OfferMurabahah with assetCost=2_050_000 (total) succeeds
  let disclosedTerms = sampleMurabahahTerms with
        assetCost = 2_050_000.0
        salePrice = 2_350_000.0  -- assetCost + profitAmount (300_000)
  _ <- submit p.fi do
    exerciseCmd aprAcked OfferMurabahah with
      murabahahTerms      = disclosedTerms
      paymentSchedule     = samplePaymentSchedule
      regulator           = Some p.regulator
      facilityRef         = "FAC-2026-RC123456-001"
      startDate           = date 2026 Jul 1
      acceptanceExpiresAt = None
  pure ()

-- ─── C-3: profitRate / effectiveRate stored on contract ──────────────────────

testProfitRateStored : Script ()
testProfitRateStored = do
  p <- setupMParties
  let customTerms = sampleMurabahahTerms with
        profitRate    = Some 0.15
        effectiveRate = Some 0.1605
  schedCid <- createScheduleContract p
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = "FAC-2026-RC123456-001"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = customTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = None
  cid <- submit p.borrower do exerciseCmd proposal AcceptProposal
  Some mc <- queryContractId p.borrower cid
  assertMsg "profitRate stored" (mc.murabahahTerms.profitRate == Some 0.15)
  assertMsg "effectiveRate stored" (mc.murabahahTerms.effectiveRate == Some 0.1605)

-- ─── E-1: PaymentScheduleContract accessible via CID on MurabahahContract ───

-- Schedule created by OfferMurabahah is accessible from the contract's CID field.
testScheduleContractAccessible : Script ()
testScheduleContractAccessible = do
  p <- setupMParties
  cid <- activeContractViaWakala p
  Some mc <- queryContractId p.fi cid
  Some sched <- queryContractId p.fi mc.paymentScheduleCid
  assertMsg "Schedule has 12 entries" (length sched.entries == 12)
  assertMsg "Schedule facilityRef matches contract" (sched.facilityRef == mc.facilityRef)
  assertMsg "FI is signatory on schedule" (sched.financialInstitution == p.fi)
  assertMsg "Regulator observes schedule" (sched.regulator == Some p.regulator)

-- ─── G-5: None regulator path — no visibility leak ───────────────────────────

-- MurabahahContract can be created and operated with regulator = None.
-- Verifies BD-5: deploying without a live CBN regulator party is valid.
testNoneRegulatorPath : Script ()
testNoneRegulatorPath = do
  p <- setupMParties
  schedCid <- submit p.fi do
    createCmd PaymentScheduleContract with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      regulator            = None
      facilityRef          = "FAC-2026-RC123456-NOREG"
      cacRegNumber         = sampleKyc.cacRegNumber
      entries              = samplePaymentSchedule
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = None
      facilityRef          = "FAC-2026-RC123456-NOREG"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = sampleMurabahahTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = None
  cid <- submit p.borrower do exerciseCmd proposal AcceptProposal
  Some mc <- queryContractId p.fi cid
  assertMsg "Contract active with no regulator" (mc.status == Active)
  assertMsg "Regulator field is None" (mc.regulator == None)
  -- Regulator party cannot observe a contract created with regulator = None
  noVisibility <- queryContractId p.regulator cid
  assertMsg "Regulator party has no visibility when regulator = None" (noVisibility == None)

