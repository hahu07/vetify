-- | Stage 7→10 tests: full Wa'd → Wakala → AssetPurchaseRecord → Qabdh →
--   MurabahahProposal → MurabahahContract flow; payment guards; delinquency;
--   Ibra'; LatePaymentCharity; Rahn; default; closure.
module Vetify.Tests.MurabahahTests where

import Daml.Script
import DA.Date
import DA.Time
import Vetify.Types
import Vetify.Murabahah
import Vetify.Governance
import Vetify.Tests.Fixtures

data MParties = MParties with
  borrower  : Party
  vetify    : Party
  fi        : Party
  regulator : Party

setupMParties : Script MParties
setupMParties = do
  borrower  <- allocateParty "Borrower"
  vetify    <- allocateParty "Vetify"
  fi        <- allocateParty "FI"
  regulator <- allocateParty "Regulator"
  pure MParties with ..

-- ─── Helpers ──────────────────────────────────────────────────────────────

-- Full Wa'd → Wakala path to an active MurabahahContract.
activeContractViaWakala : MParties -> Script (ContractId MurabahahContract)
activeContractViaWakala p = do
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  wakala <- submit p.fi do exerciseCmd wad ProceedWithWakala
  apr <- submit p.borrower do
    exerciseCmd wakala RecordAssetPurchase with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "LMS-INV-2026-00441"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  aprAcked <- submit p.borrower do exerciseCmd apr AcknowledgeDelivery
  proposal <- submit p.fi do
    exerciseCmd aprAcked OfferMurabahah with
      murabahahTerms      = sampleMurabahahTerms
      paymentSchedule     = samplePaymentSchedule
      regulator           = Some p.regulator
      facilityRef         = "FAC-2026-RC123456-001"
      startDate           = date 2026 Jul 1
      acceptanceExpiresAt = None
  submit p.borrower do exerciseCmd proposal AcceptProposal

-- Direct helper for unit-testing payment/closure without repeating the
-- full acquisition chain in every test.
activeContractDirect : MParties -> Script (ContractId MurabahahContract)
activeContractDirect p = do
  schedCid <- createScheduleContract p
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = "FAC-2026-RC123456-001"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = sampleMurabahahTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = None
  submit p.borrower do exerciseCmd proposal AcceptProposal

-- RahnAgreement is bilateral so requires both parties to act.
createRahn : MParties -> Script (ContractId RahnAgreement)
createRahn p = submit (actAs [p.borrower, p.fi]) do
  createCmd RahnAgreement with
    borrower              = p.borrower
    vetify                = p.vetify
    financialInstitution  = p.fi
    regulator             = Some p.regulator
    facilityRef           = "FAC-2026-RC123456-001"
    businessName          = sampleProfile.name
    cacRegNumber          = sampleKyc.cacRegNumber
    collateralDescription = "Plot 14, Lekki Phase 1 — C of O No. LG98765"
    collateralValue       = 5_000_000.0
    collateralStatus      = CollateralActive
    releaseEvidence       = None

-- RBAC (Governance Phase A): registers a proposer/confirmer officer pair for a
-- maker-checker choice (WriteOffContract, ReleaseCollateral, EnforceCollateral,
-- GrantIbra, GrantPartialIbra) and returns their officerIds. `label` must be
-- unique per call within a single test to avoid AuthorizedOfficer key clashes.
createOfficerPair : MParties -> Text -> OfficerRole -> Script (Text, Text)
createOfficerPair p label proposerRole = do
  t <- getTime
  let proposerId  = "PROP-" <> label
      confirmerId = "CONF-" <> label
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId             = proposerId
      officerName           = "Proposer Officer " <> label
      roles                 = [proposerRole]
      authorizedBy          = "FI Head Office"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId             = confirmerId
      officerName           = "Confirmer Officer " <> label
      roles                 = [RiskOfficer]
      authorizedBy          = "FI Head Office"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  pure (proposerId, confirmerId)

-- E-1: Create a PaymentScheduleContract with samplePaymentSchedule for the standard facility.
createScheduleContract : MParties -> Script (ContractId PaymentScheduleContract)
createScheduleContract p = submit p.fi do
  createCmd PaymentScheduleContract with
    financialInstitution = p.fi
    vetify               = p.vetify
    borrower             = p.borrower
    regulator            = Some p.regulator
    facilityRef          = "FAC-2026-RC123456-001"
    cacRegNumber         = sampleKyc.cacRegNumber
    entries              = samplePaymentSchedule

-- ─── Wa'd tests ───────────────────────────────────────────────────────────

-- Full Wa'd → Wakala chain produces an Active bilateral contract visible to regulator
testFullWadWakalaFlow : Script ()
testFullWadWakalaFlow = do
  p        <- setupMParties
  contract <- activeContractViaWakala p
  Some c   <- queryContractId p.regulator contract
  assertMsg "Contract should be Active" (c.status == Active)
  assertMsg "Outstanding balance should be salePrice" (c.outstandingBalance == 2_300_000.0)
  -- Regulator observes accepted contract but NOT the proposal
  proposals <- query @MurabahahProposal p.regulator
  assertMsg "Regulator should not see proposals" (null proposals)

-- Borrower can withdraw the Wa'd before FI proceeds
testWithdrawWad : Script ()
testWithdrawWad = do
  p <- setupMParties
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  submit p.borrower do
    exerciseCmd wad WithdrawWad with reason = "Supplier price changed"
  wads <- query @MurabahahWad p.borrower
  assertMsg "Wa'd should be archived after withdrawal" (null wads)

-- FI can buy directly without appointing the borrower as agent
testProceedDirectly : Script ()
testProceedDirectly = do
  p <- setupMParties
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  apr <- submit p.fi do
    exerciseCmd wad ProceedDirectly with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 20
      invoiceRef            = "FI-PO-001"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  Some r <- queryContractId p.fi apr
  assertMsg "Should not be via Wakala" (not r.purchasedViaWakala)
  assertMsg "Delivery not yet acknowledged" (not r.deliveryAcknowledged)

-- ─── Qabdh gate ───────────────────────────────────────────────────────────

-- FI cannot make a sale offer before the borrower acknowledges delivery
testCannotOfferBeforeQabdh : Script ()
testCannotOfferBeforeQabdh = do
  p <- setupMParties
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  apr <- submit p.fi do
    exerciseCmd wad ProceedDirectly with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 20
      invoiceRef            = "FI-PO-001"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  submitMustFail p.fi do
    exerciseCmd apr OfferMurabahah with
      murabahahTerms      = sampleMurabahahTerms
      paymentSchedule     = samplePaymentSchedule
      regulator           = Some p.regulator
      facilityRef         = "FAC-2026-RC123456-001"
      startDate           = date 2026 Jul 1
      acceptanceExpiresAt = None
  pure ()

