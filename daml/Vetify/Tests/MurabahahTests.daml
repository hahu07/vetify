  c <- activeContractDirect p
  submitMustFail p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Jul 1, amountPaid = 191_666.67, installmentNo = 5, allocation = None, settlementAccount = None, directDebitRef = None
