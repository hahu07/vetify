  assertMsg "Regulator sees correct status" (stmt.contractStatus == Active)
  Some _ <- queryContractId p.borrower stmtCid
  pure ()

-- ─── M14: Document integrity ─────────────────────────────────────────────────

-- A DocumentRef with a digital signature is stored and retrievable
testDocumentWithSignature : Script ()
testDocumentWithSignature = do
  p   <- setupMParties
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  wakala <- submit p.fi do exerciseCmd wad ProceedWithWakala
  apr <- submit p.borrower do
    exerciseCmd wakala RecordAssetPurchase with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "LMS-INV-2026-00441"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  let signedDoc = DocumentRef with
        docType            = "ASSET_INVOICE"
        contentHash        = "sha256:d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2"
        storageRef         = "s3://vetify-docs/RC123456/lms-invoice-2026.pdf"
        mimeType           = Some "application/pdf"
        malwareScanStatus  = Some "CLEAN"
        fileSize           = Some 102400
        checksumAlgorithm  = Some "sha256"
        malwareScanAt      = None
        digitalSignature   = Some "3045022100f4c3b2a1...e0d9c8b7"  -- M14
        signatureAlgorithm = Some "ECDSA-P256"                        -- M14
        signatoryRef       = Some "LMS-AUTHORIZED-OFFICER-001"        -- M14
        signedAt           = None                                      -- M14 (None in test; set at runtime)
  assertMsg "Digital signature present" (signedDoc.digitalSignature /= None)
  assertMsg "Signature algorithm recorded" (signedDoc.signatureAlgorithm == Some "ECDSA-P256")

-- ─── R1: Collateral lifecycle ────────────────────────────────────────────────

-- FI revalues collateral; creates CollateralValuationRecord and updates RahnAgreement
testRevalueCollateral : Script ()
testRevalueCollateral = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (newRahnCid, valCid) <- submit p.fi do
    exerciseCmd rahnCid Revalue with
      newValue      = 5_500_000.0
      valuationDate = date 2026 Sep 30
      valuatorRef   = "CBRE-NIGERIA-APPRAISAL-2026-001"
      notes         = Some "Annual desk review — market values up 10%"
  Some newRahn <- queryContractId p.fi newRahnCid
  assertMsg "Collateral value updated" (newRahn.collateralValue == 5_500_000.0)
  assertMsg "Collateral still Active after revaluation" (newRahn.collateralStatus == CollateralActive)
  Some val <- queryContractId p.vetify valCid
  assertMsg "Valuation record has new amount" (val.valuationAmount == 5_500_000.0)
  assertMsg "Previous value recorded" (val.previousValue == 5_000_000.0)

-- ReleaseCollateral stores the discharge document reference on the contract
testReleaseWithDocument : Script ()
testReleaseWithDocument = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "release-with-doc" OperationsOfficer
  released <- submit p.fi do
    exerciseCmd rahnCid ReleaseCollateral with
      note                 = "Contract fully repaid — see discharge letter"
      releaseDocumentRef   = Some "DISCHARGE-LTR-2026-RC123456"
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  Some r <- queryContractId p.fi released
  assertMsg "Collateral released" (r.collateralStatus == CollateralReleased)
  assertMsg "Release evidence stored" (r.releaseEvidence == Some "DISCHARGE-LTR-2026-RC123456")

