-- ─── F-1: HamishJiddiyyah ────────────────────────────────────────────────

testHamishReturnDeposit : Script ()
testHamishReturnDeposit = do
  p <- setupMParties
  hCid <- submit p.fi do
    createCmd HamishJiddiyyah with
      borrower             = p.borrower
      financialInstitution = p.fi
      vetify               = p.vetify
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      depositAmount        = 200_000.0
      depositRef           = "TRF-2026-HAMISH-001"
      depositDate          = date 2026 Jul 1
      returnDeadline       = date 2026 Aug 1
      actualLossDeducted   = None
      status               = HamishHeld
  returned <- submit p.fi do
    exerciseCmd hCid ReturnDeposit with transferRef = "TRF-RETURN-2026-001"
  Some rv <- queryContractId p.fi returned
  assertMsg "Deposit status is Returned" (rv.status == HamishReturned)
  Some bv <- queryContractId p.borrower returned
  assertMsg "Borrower can see returned deposit" (bv.depositAmount == 200_000.0)

