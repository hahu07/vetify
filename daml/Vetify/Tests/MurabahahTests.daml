-- ─── M-CV: Covenant tracking ─────────────────────────────────────────────────

testCovenantTracking : Script ()
testCovenantTracking = do
  p <- setupMParties
  covenantCid <- submit p.fi do
    createCmd CreditCovenant with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      covenantType         = "DSCR_MINIMUM"
      threshold            = 1.2
      measurementFrequency = "QUARTERLY"
  -- Measurement within threshold — not breached
  mOk <- submit p.vetify do
    exerciseCmd covenantCid RecordCovenantMeasurement with
      measuredValue = 1.5
      measureDate   = date 2026 Sep 30
      measuredBy    = "vetify-underwriting"
  Some mOkV <- queryContractId p.fi mOk
  assertMsg "DSCR 1.5 not breached" (not mOkV.breached)
  -- Measurement below threshold — breached
  mBreached <- submit p.vetify do
    exerciseCmd covenantCid RecordCovenantMeasurement with
      measuredValue = 0.9
      measureDate   = date 2026 Dec 31
      measuredBy    = "vetify-underwriting"
  Some mBv <- queryContractId p.fi mBreached
  assertMsg "DSCR 0.9 is breached" mBv.breached

-- ─── M-DR: Document registry ─────────────────────────────────────────────────

testDocumentEntry : Script ()
testDocumentEntry = do
  p <- setupMParties
  -- Create an AssetPurchaseRecord via ProceedDirectly (not acked — stays alive)
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  apr <- submit p.fi do
    exerciseCmd wad ProceedDirectly with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "LMS-INV-2026-00441"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0
  -- Register a bill of lading
  let bolRef = sampleDocRef with docType = "BILL_OF_LADING"; storageRef = "s3://vetify-docs/RC123456/bol-2026.pdf"
  entryCid <- submit p.fi do
    exerciseCmd apr RegisterDocument with
      documentRef  = bolRef
      registeredBy = "Fatima Suleiman, Trade Finance"
  Some entry <- queryContractId p.fi entryCid
  assertMsg "Document not yet verified" (entry.verifiedAt == None)
  assertMsg "Not superseded" (not entry.superseded)
  -- Vetify verifies the document
  verifiedCid <- submit p.vetify do
    exerciseCmd entryCid VerifyDocument with verifyNote = Some "Hash matched; malware scan clean"
  Some vEntry <- queryContractId p.vetify verifiedCid
  assertMsg "Document is now verified" (vEntry.verifiedAt /= None)

