-- ─── R3: Supplier failure workflow ───────────────────────────────────────────

-- FI records a supplier cancellation; AssetPurchaseRecord is archived
testSupplierFailure : Script ()
testSupplierFailure = do
  p      <- setupMParties
  apr    <- assetPurchaseViaWakala p
  failCid <- submit p.fi do
    exerciseCmd apr RecordSupplierFailure with
      failureType        = "SUPPLIER_CANCELLED"
      failureDescription = "Supplier cancelled purchase order citing production shutdown"
      refundAmount       = Some 2_000_000.0
  Some failure <- queryContractId p.vetify failCid
  assertMsg "Failure type recorded" (failure.failureType == "SUPPLIER_CANCELLED")
  assertMsg "Refund amount recorded" (failure.refundAmount == Some 2_000_000.0)
  aprs <- query @AssetPurchaseRecord p.fi
  assertMsg "AssetPurchaseRecord archived after supplier failure" (null aprs)

-- ─── R4: Dispute and arbitration ─────────────────────────────────────────────

-- Borrower raises a dispute; vetify escalates to arbitration; outcome recorded
testArbitration : Script ()
testArbitration = do
  p          <- setupMParties
  c          <- activeContractDirect p
  arbitrator <- allocateParty "Arbitrator"
  -- Borrower raises a payment dispute
  dispCid <- submit p.borrower do
    exerciseCmd c RaiseDispute with
      disputeType = "PAYMENT_DISPUTE"
      disputeDesc = "FI recorded a payment that was already settled"
      evidenceRef = Some "BANK-STMT-2026-07"
  Some disp <- queryContractId p.fi dispCid
  assertMsg "Dispute description captured" (disp.description == "FI recorded a payment that was already settled")
  -- Vetify escalates to arbitration
  arbCid <- submit p.vetify do
    exerciseCmd dispCid EscalateToArbitration with arbitrator
  Some arb <- queryContractId arbitrator arbCid
  assertMsg "Arbitration not yet concluded" (arb.outcome == None)
  -- Vetify records the arbitrator's finding
  concludedCid <- submit p.vetify do
    exerciseCmd arbCid RecordArbitrationOutcome with
      arbOutcome    = "BORROWER_PREVAILS"
      arbResolution = "Duplicate payment entry reversed; borrower credited NGN 191,666.67"
  Some concluded <- queryContractId p.regulator concludedCid
  assertMsg "Outcome recorded" (concluded.outcome == Some "BORROWER_PREVAILS")
  assertMsg "Resolution recorded" (concluded.resolution /= None)

-- ─── R5: Portfolio risk analytics ────────────────────────────────────────────

-- Reporting Agent creates a PortfolioRiskReport visible to FI and regulator
testPortfolioRiskReport : Script ()
testPortfolioRiskReport = do
  p      <- setupMParties
  let riskMetrics = PortfolioRiskMetrics with
        probabilityOfDefault = 0.03
        lossGivenDefault     = 0.45
        expectedLoss         = 31_050_000.0
        exposureAtDefault    = 2_300_000_000.0
        concentrationRisk    = 0.18
        sectorConcentration  = "Retail Trade"
        delinquencyRate      = 0.07
        activeContractCount  = 142
  rptCid <- submit p.vetify do
    createCmd PortfolioRiskReport with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      reportDate           = date 2026 Sep 30
      reportPeriod         = "2026-Q3"
      metrics              = riskMetrics
      generatedByAgent     = "vetify-reporting"
      modelVersion         = "vetify-reporting-v1.0"
  Some rpt <- queryContractId p.regulator rptCid
  assertMsg "Report period correct" (rpt.reportPeriod == "2026-Q3")
  assertMsg "Active contract count correct" (rpt.metrics.activeContractCount == 142)
  assertMsg "PD in expected range" (rpt.metrics.probabilityOfDefault == 0.03)
  Some _ <- queryContractId p.fi rptCid
  pure ()

-- ─── R6: Continuous AI monitoring alerts ─────────────────────────────────────

-- Monitoring Agent raises a delinquency-risk alert; vetify dismisses after review
testMonitoringAlert : Script ()
testMonitoringAlert = do
  p      <- setupMParties
  alertCid <- submit p.vetify do
    createCmd MonitoringAlert with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = None
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      alertType            = DelinquencyRisk
      alertSeverity        = "HIGH"
      alertDescription     = "Installment 3 overdue by 15 days; no payment received"
      detectedAt           = datetime 1970 Jan 1 0 0 0
      dismissed            = False
      dismissalNote        = None
  Some alert <- queryContractId p.fi alertCid
  assertMsg "Alert not yet dismissed" (not alert.dismissed)
  assertMsg "Alert type correct" (alert.alertType == DelinquencyRisk)
  dismissed <- submit p.vetify do
    exerciseCmd alertCid DismissAlert with
      dismissNote = "Borrower confirmed payment — bank transfer delay; installment now cleared"
  Some d <- queryContractId p.fi dismissed
  assertMsg "Alert dismissed" d.dismissed
  assertMsg "Dismissal note stored" (d.dismissalNote /= None)

-- ─── S1: Early settlement after Ibra' ────────────────────────────────────────

-- Full Ibra': FI grants rebate then records early settlement; contract closes at zero
testEarlySettlementFull : Script ()
testEarlySettlementFull = do
  p <- setupMParties
  c <- activeContractDirect p
  (proposerId, confirmerId) <- createOfficerPair p "early-settlement-full" CreditOfficer
  -- Borrower requests full early settlement
  ibraCid <- submit p.borrower do
    exerciseCmd c RequestIbra with
      requestedSettlementDate = date 2026 Dec 1
      settlementType          = FullIbra
      requestedAmount         = None
  -- FI grants a rebate of NGN 100,000 on the remaining profit
  submit p.fi do
    exerciseCmd ibraCid GrantIbra with
      rebateAmount         = 100_000.0
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  -- FI records actual settlement with the net amount (salePrice - rebate)
  (closedCid, repCid) <- submit p.fi do
    exerciseCmd c RecordEarlySettlement with
      settlementType    = FullIbra
      settlementAmount  = 2_200_000.0     -- 2,300,000 − 100,000 rebate
      settlementDate    = date 2026 Dec 1
      settlementAccount = None
  Some closed <- queryContractId p.fi closedCid
  assertMsg "Contract completed after full Ibra'" (closed.status == Completed)
  assertMsg "Outstanding balance zeroed on full settlement" (closed.outstandingBalance == 0.0)
  Some rep <- queryContractId p.regulator repCid
  assertMsg "Settlement recorded as a repayment" (rep.amountPaid == 2_200_000.0)
  assertMsg "Remaining balance is zero" (rep.remainingBalance == 0.0)

-- ─── D1: Delivery milestones ─────────────────────────────────────────────────

-- Borrower records two partial delivery milestones before full Qabdh
testDeliveryMilestone : Script ()
testDeliveryMilestone = do
  p   <- setupMParties
  apr <- assetPurchaseViaWakala p
  -- First delivery batch: 20 MT of 50 MT total
  m1 <- submit p.borrower do
    exerciseCmd apr RecordDeliveryMilestone with
      milestoneDescription = "First batch — 20 MT flour delivered"
      quantityDelivered    = 20.0
      milestoneDate        = date 2026 Jun 10
      evidenceRef          = Some "WH-NOTE-2026-001"
  Some ms1 <- queryContractId p.fi m1
  assertMsg "First milestone quantity correct" (ms1.quantityDelivered == 20.0)
  -- Second delivery batch: remaining 30 MT
  m2 <- submit p.borrower do
    exerciseCmd apr RecordDeliveryMilestone with
      milestoneDescription = "Final batch — 30 MT flour delivered"
      quantityDelivered    = 30.0
      milestoneDate        = date 2026 Jun 14
      evidenceRef          = Some "WH-NOTE-2026-002"
  Some ms2 <- queryContractId p.vetify m2
  assertMsg "Second milestone quantity correct" (ms2.quantityDelivered == 30.0)
  -- APR still active; borrower can now exercise AcknowledgeDelivery
  aprs <- query @AssetPurchaseRecord p.fi
  assertMsg "AssetPurchaseRecord still active after milestones" (not (null aprs))

-- ─── R1: Suspicious activity reporting ───────────────────────────────────────

-- Vetify files a SAR visible to FI and regulator; borrower excluded
testSARReport : Script ()
testSARReport = do
  p      <- setupMParties
  sarCid <- submit p.vetify do
    createCmd SARReport with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      sarRef               = "NFIU-SAR-2026-RC123456-001"
      suspiciousActivity   = "Repayment source changed from declared business account to third-party wire transfers; PEP connection detected on new account"
      reportDate           = date 2026 Sep 15
      reportedByParty      = "vetify-compliance-officer-001"
      confidential         = True
  Some sar <- queryContractId p.regulator sarCid
  assertMsg "SAR reference recorded" (sar.sarRef == "NFIU-SAR-2026-RC123456-001")
  assertMsg "SAR is confidential" sar.confidential
  Some _ <- queryContractId p.fi sarCid
  -- Borrower must NOT see the SAR
  sarsByBorrower <- query @SARReport p.borrower
  assertMsg "Borrower cannot observe SAR" (null sarsByBorrower)

-- ─── M-PI: Sub-installment payment splitting ─────────────────────────────────

-- Paying installment 1 in two partial credits; installmentsPaid advances only
-- when the full due amount is accumulated.
testSubInstallmentPayment : Script ()
testSubInstallmentPayment = do
  p   <- setupMParties
  cid <- activeContractDirect p
  -- First partial: 95,833 < 191,666.67 — installmentsPaid stays at 0
  pay1 <- submit p.fi do
    exerciseCmd cid RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 95_833.0
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some c1v <- queryContractId p.fi pay1.updatedContract
  assertMsg "installmentsPaid should not advance on partial payment" (c1v.installmentsPaid == 0)
  assertMsg "pendingInstallmentPaid accumulates" (c1v.pendingInstallmentPaid == 95_833.0)
  assertMsg "No charity on incomplete installment" (pay1.charityObligation == None)
  -- Second partial: 96,000 completes installment (total 191,833 >= 191,666.67)
  pay2 <- submit p.fi do
    exerciseCmd pay1.updatedContract RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 96_000.0
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some c2v <- queryContractId p.fi pay2.updatedContract
  assertMsg "installmentsPaid advances after completion" (c2v.installmentsPaid == 1)
  assertMsg "pendingInstallmentPaid resets to 0" (c2v.pendingInstallmentPaid == 0.0)

-- ─── M-GP: Moratorium / payment holiday ─────────────────────────────────────

-- Payments within an active moratorium do not trigger the wasLate flag.
testMoratorium : Script ()
testMoratorium = do
  p   <- setupMParties
  cid <- activeContractDirect p
  -- Grant moratorium covering through end of September
  (morCid, morRecordCid) <- submit p.fi do
    exerciseCmd cid GrantMoratorium with
      moratoriumEnd = date 2026 Sep 30
      reason        = "Covid-19 hardship relief — CBN directive"
  Some morV <- queryContractId p.fi morCid
  assertMsg "Moratorium is active" (morV.activeMoratorium == Some (date 2026 Sep 30))
  Some mr <- queryContractId p.fi morRecordCid
  assertMsg "MoratoriumRecord reason recorded" (mr.reason == "Covid-19 hardship relief — CBN directive")
  -- Pay installment 1 on Aug 5 (after Jul 1 due date, but within moratorium)
  payMor <- submit p.fi do
    exerciseCmd morCid RecordPayment with
      paymentDate       = date 2026 Aug 5
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some r <- queryContractId p.fi payMor.repaymentRecord
  assertMsg "Payment within moratorium is NOT late" (not r.wasLate)
  assertMsg "No charity while moratorium is active" (payMor.charityObligation == None)
  -- End moratorium
  c3 <- submit p.vetify do
    exerciseCmd payMor.updatedContract EndMoratorium with note = "Moratorium period expired"
  Some c3v <- queryContractId p.fi c3
  assertMsg "Moratorium cleared" (c3v.activeMoratorium == None)
  -- Pay installment 2 on Oct 15 (after Oct 1 due date, moratorium ended)
  payPostMor <- submit p.fi do
    exerciseCmd c3 RecordPayment with
      paymentDate       = date 2026 Oct 15
      amountPaid        = 191_666.67
      installmentNo     = 2
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some rv2 <- queryContractId p.fi payPostMor.repaymentRecord
  assertMsg "Payment after moratorium ends IS late" rv2.wasLate
  assertMsg "Charity created for late post-moratorium payment" (payPostMor.charityObligation /= None)

-- GrantMoratorium fails when a moratorium is already active
testCannotDoubleGrantMoratorium : Script ()
testCannotDoubleGrantMoratorium = do
  p   <- setupMParties
  cid <- activeContractDirect p
  (morCid, _) <- submit p.fi do
    exerciseCmd cid GrantMoratorium with
      moratoriumEnd = date 2026 Sep 30
      reason        = "Covid-19 hardship relief"
  -- Second grant must fail — a moratorium is already active
  submitMustFail p.fi do
    exerciseCmd morCid GrantMoratorium with
      moratoriumEnd = date 2026 Dec 31
      reason        = "Extension attempt"
  pure ()

-- ─── M-RC: Recovery & collections workflow ───────────────────────────────────

testRecoveryWorkflow : Script ()
testRecoveryWorkflow = do
  p      <- setupMParties
  cid    <- activeContractDirect p
  (delq, _) <- submit p.vetify do exerciseCmd cid FlagDelinquent with reason = "3 missed installments"
  -- FI defaults the contract (direct FI-only credit decision)
  (defaulted, _) <- submit p.fi do
    exerciseCmd delq DefaultContract with
      reason      = "No response to demand within deadline"
      defaultedBy = "Aminu Garba, Credit Officer"
  Some dv <- queryContractId p.fi defaulted
  assertMsg "Contract is Defaulted" (dv.status == Defaulted)
  -- Issue formal demand notice on the Defaulted contract
  dNotice <- submit p.fi do
    exerciseCmd defaulted IssueDemandNotice with
      demandDate       = date 2026 Nov 1
      demandRef        = "DEMAND-2026-RC123456-001"
      responseDeadline = date 2026 Nov 15
      gsmEligible      = False
  Some dn <- queryContractId p.fi dNotice
  assertMsg "Demand amount matches outstanding" (dn.outstandingAmount == 2_300_000.0)
  -- Record a partial recovery
  (afterRec, recRecord) <- submit p.fi do
    exerciseCmd defaulted RecordRecoveryPayment with
      amountRecovered = 500_000.0
      recoveryDate    = date 2026 Dec 1
      recoverySource  = "COLLATERAL_SALE"
  Some rv <- queryContractId p.fi afterRec
  assertMsg "Outstanding balance reduced after recovery" (rv.outstandingBalance == 1_800_000.0)
  -- Escalate to legal on the demand notice
  legalCid <- submit p.fi do
    exerciseCmd dNotice EscalateToLegal with
      escalationDate = date 2026 Dec 5
      solicitorRef   = "TEMPLARS-2026-0042"
      legalAction    = "Civil recovery proceedings — Federal High Court Lagos"
  Some leg <- queryContractId p.fi legalCid
  assertMsg "Legal action recorded" (leg.legalAction == "Civil recovery proceedings — Federal High Court Lagos")
  -- Write off residual balance
  (writeOffProposerId, writeOffConfirmerId) <- createOfficerPair p "recovery-workflow" RecoveryOfficer
  (closed, woRecord) <- submit p.fi do
    exerciseCmd afterRec WriteOffContract with
      writeOffDate         = date 2027 Jan 31
      writeOffRef          = "WO-2027-RC123456-001"
      totalRecovered       = 500_000.0
      writeOffApprovedBy   = "Confirmer Officer recovery-workflow"
      proposedByOfficerId  = writeOffProposerId
      confirmedByOfficerId = writeOffConfirmerId
  Some cv <- queryContractId p.fi closed
  assertMsg "Contract completed after write-off" (cv.status == Completed)
  assertMsg "Outstanding balance zeroed" (cv.outstandingBalance == 0.0)
  Some wo <- queryContractId p.fi woRecord
  assertMsg "Amount written off is correct" (wo.amountWrittenOff == 1_800_000.0)

-- Full recovery to zero balance unlocks CloseDefaultedContract
testCloseAfterFullRecovery : Script ()
testCloseAfterFullRecovery = do
  p      <- setupMParties
  cid    <- activeContractDirect p
  (delq, _) <- submit p.vetify do exerciseCmd cid FlagDelinquent with reason = "Non-payment"
  (dflt, _) <- submit p.fi do
    exerciseCmd delq DefaultContract with
      reason      = "Irrecoverable — borrower insolvent"
      defaultedBy = "Test Officer"
  -- Record full recovery (full 2_300_000.0)
  (afterRec, _) <- submit p.fi do
    exerciseCmd dflt RecordRecoveryPayment with
      amountRecovered = 2_300_000.0
      recoveryDate    = date 2026 Dec 10
      recoverySource  = "GUARANTOR"
  Some rv <- queryContractId p.fi afterRec
  assertMsg "Balance zeroed after full recovery" (rv.outstandingBalance == 0.0)
  -- CloseDefaultedContract should now succeed
  closed <- submit p.fi do
    exerciseCmd afterRec CloseDefaultedContract with closingDate = date 2026 Dec 15
  Some cv <- queryContractId p.fi closed
  assertMsg "Contract completed via CloseDefaultedContract" (cv.status == Completed)

-- CloseDefaultedContract fails when balance is still outstanding
testCloseDefaultedRequiresZeroBalance : Script ()
testCloseDefaultedRequiresZeroBalance = do
  p    <- setupMParties
  cid  <- activeContractDirect p
  (delq, _) <- submit p.vetify do exerciseCmd cid FlagDelinquent with reason = "Non-payment"
  (dflt, _) <- submit p.fi do
    exerciseCmd delq DefaultContract with
      reason      = "Irrecoverable"
      defaultedBy = "Test Officer"
  submitMustFail p.fi do
    exerciseCmd dflt CloseDefaultedContract with closingDate = date 2026 Dec 1
  pure ()

-- ─── M-MK: Maker-checker for collateral enforcement ──────────────────────────

testMakerCheckerCollateral : Script ()
testMakerCheckerCollateral = do
  p    <- setupMParties
  rahn <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "maker-checker-collateral" RecoveryOfficer
  -- FI proposes enforcement (step 1 — maker)
  pending <- submit p.fi do
    exerciseCmd rahn ProposeEnforceCollateral with
      reason              = "Default confirmed; RahnAgreement activated"
      gsmExhausted        = False
      gsmRef              = None
      proposedByOfficerId = proposerId
  Some pd <- queryContractId p.fi pending
  assertMsg "Pending enforcement reason recorded" (pd.reason == "Default confirmed; RahnAgreement activated")
  -- Vetify confirms enforcement (step 2 — checker)
  enforcedRahn <- submit p.vetify do
    exerciseCmd pending ConfirmEnforce with rahnCid = rahn, confirmedByOfficerId = confirmerId
  Some ev <- queryContractId p.fi enforcedRahn
  assertMsg "Collateral is now Enforced" (ev.collateralStatus == CollateralEnforced)

-- ─── M-RI: Regulatory inspection workflow ────────────────────────────────────

testRegulatoryInspection : Script ()
testRegulatoryInspection = do
  p   <- setupMParties
  now <- getTime
  -- Vetify creates the inspection request upon receiving CBN notice
  reqCid <- submit p.vetify do
    createCmd RegulatoryInspectionRequest with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      inspectionRef        = "CBN-NIFI-INSP-2026-0031"
      inspectionScope      = "Murabahah portfolio review Q3 2026"
      responseDeadline     = date 2026 Oct 31
      requestedAt          = now
  -- FI responds with documentation
  respCid <- submit p.fi do
    exerciseCmd reqCid RespondToInspection with
      responseRef     = "FI-RESP-2026-0031"
      documents       = ["PortfolioReport-Q3-2026.pdf", "ShariahAudit-2026-H1.pdf"]
      respondedByName = "Aminu Garba, Head of Operations"
      responseDate    = date 2026 Oct 25
  Some resp <- queryContractId p.vetify respCid
  assertMsg "Response reference recorded" (resp.responseRef == "FI-RESP-2026-0031")
  assertMsg "Documents included" (length resp.documents == 2)
  -- Vetify closes the inspection
  recordCid <- submit p.vetify do
    exerciseCmd respCid CloseInspection with
      findings       = ["All Murabahah contracts carry proper Qabdh evidence", "SAR reporting is timely"]
      passed         = True
      followUpNeeded = False
      closingNote    = "Inspection closed. Portfolio is Shariah-compliant."
  Some rec <- queryContractId p.regulator recordCid
  assertMsg "Inspection passed" rec.passed
  assertMsg "No follow-up needed" (not rec.followUpNeeded)

