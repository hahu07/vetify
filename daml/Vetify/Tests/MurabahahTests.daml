-- Installment not in schedule rejected
testRejectsInstallmentNotInSchedule : Script ()
testRejectsInstallmentNotInSchedule = do
  p <- setupMParties
  c <- activeContractDirect p
  submitMustFail p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Jul 1, amountPaid = 191_666.67, installmentNo = 99, allocation = None, settlementAccount = None, directDebitRef = None
  pure ()

-- ─── Late payment / Sadaqah ───────────────────────────────────────────────

-- Payment after dueDate creates a LatePaymentCharity obligation
testLatePaymentCreatesCharity : Script ()
testLatePaymentCreatesCharity = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Aug 15   -- due Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef     = None
  Some r <- queryContractId p.regulator payRes.repaymentRecord
  assertMsg "Payment should be flagged as late" r.wasLate
  case payRes.charityObligation of
    None -> assertFail "Expected LatePaymentCharity to be created"
    Some cid -> do
      Some ch <- queryContractId p.fi cid
      assertMsg "Charity installment matches" (ch.installmentNo == 1)
      assertMsg "Charity not yet settled" (not ch.settled)

-- FI sets the charity amount; borrower confirms donation
testCharitySettlementFlow : Script ()
testCharitySettlementFlow = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Aug 15, amountPaid = 191_666.67, installmentNo = 1, allocation = None, settlementAccount = None, directDebitRef = None
  let Some charityCid = payRes.charityObligation
  withAmount <- submit p.fi do
    exerciseCmd charityCid SetCharityAmount with amount = 5_000.0
  rcptCid <- submit p.borrower do
    exerciseCmd withAmount ConfirmCharityPayment with
      charityRef          = "CHARITY-RCPT-2026-001"
      charityOrganization = "Islamic Relief Nigeria"
  Some rcpt <- queryContractId p.vetify rcptCid
  assertMsg "Charity amount on receipt" (rcpt.charityAmount == 5_000.0)
  assertMsg "Charity organization recorded" (rcpt.charityOrganization == "Islamic Relief Nigeria")

-- ─── Delinquency lifecycle ────────────────────────────────────────────────

-- A payment does not auto-cure delinquency; ResumeActive does
testDelinquencyLifecycle : Script ()
testDelinquencyLifecycle = do
  p <- setupMParties
  c <- activeContractDirect p
  (delq, delqEvt) <- submit p.vetify do
    exerciseCmd c FlagDelinquent with reason = "Missed 2 installments"
  Some d <- queryContractId p.fi delq
  assertMsg "Should be Delinquent" (d.status == Delinquent)
  Some evt1 <- queryContractId p.fi delqEvt
  assertMsg "AuditEvent recorded for delinquency flag" (evt1.eventType == "DELINQUENCY_FLAGGED")
  payRes <- submit p.fi do
    exerciseCmd delq RecordPayment with
      paymentDate = date 2026 Sep 1, amountPaid = 191_666.67, installmentNo = 1, allocation = None, settlementAccount = None, directDebitRef = None
  Some ap <- queryContractId p.fi payRes.updatedContract
  assertMsg "Partial payment does not cure delinquency" (ap.status == Delinquent)
  (resumed, resumedEvt) <- submit p.vetify do
    exerciseCmd payRes.updatedContract ResumeActive with note = "Arrears cleared"
  Some rs <- queryContractId p.fi resumed
  assertMsg "ResumeActive restores Active status" (rs.status == Active)
  Some evt2 <- queryContractId p.fi resumedEvt
  assertMsg "AuditEvent recorded for resume" (evt2.eventType == "CONTRACT_RESUMED")

-- ─── Default ──────────────────────────────────────────────────────────────

-- FI can write off a delinquent contract
testDefaultContract : Script ()
testDefaultContract = do
  p <- setupMParties
  c <- activeContractDirect p
  (delq, _) <- submit p.vetify do exerciseCmd c FlagDelinquent with reason = "Non-payment"
  (def, defRecord) <- submit p.fi do
    exerciseCmd delq DefaultContract with reason = "Unrecoverable"; defaultedBy = "Test Officer"
  Some df <- queryContractId p.fi def
  assertMsg "Should be Defaulted" (df.status == Defaulted)
  Some dr <- queryContractId p.fi defRecord
  assertMsg "DefaultRecord reason recorded" (dr.reason == "Unrecoverable")
  assertMsg "DefaultRecord defaultedBy recorded" (dr.defaultedBy == "Test Officer")
  Some _ <- queryContractId p.borrower defRecord
  pure ()

-- Cannot default an Active contract
testCannotDefaultActiveContract : Script ()
testCannotDefaultActiveContract = do
  p <- setupMParties
  c <- activeContractDirect p
  submitMustFail p.fi do exerciseCmd c DefaultContract with reason = "Premature"; defaultedBy = "Test Officer"
  pure ()

-- ─── Ibra' (early settlement rebate) ─────────────────────────────────────

testIbraGranted : Script ()
testIbraGranted = do
  p <- setupMParties
  c <- activeContractDirect p
  (proposerId, confirmerId) <- createOfficerPair p "ibra-granted" CreditOfficer
  req <- submit p.borrower do
    exerciseCmd c RequestIbra with requestedSettlementDate = date 2026 Dec 1, settlementType = FullIbra, requestedAmount = None
  submit p.fi do
    exerciseCmd req GrantIbra with
      rebateAmount         = 50_000.0
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  pure ()

testIbraDeclined : Script ()
testIbraDeclined = do
  p <- setupMParties
  c <- activeContractDirect p
  req <- submit p.borrower do
    exerciseCmd c RequestIbra with requestedSettlementDate = date 2026 Dec 1, settlementType = FullIbra, requestedAmount = None
  declineCid <- submit p.fi do exerciseCmd req DeclineIbra with reason = "Insufficient hardship justification"
  Some decline <- queryContractId p.fi declineCid
  assertMsg "reason recorded" (decline.reason == "Insufficient hardship justification")

-- ─── Rahn (collateral) ────────────────────────────────────────────────────

-- Collateral released on full repayment
testRahnReleasedOnClosure : Script ()
testRahnReleasedOnClosure = do
  p      <- setupMParties
  rahnCid <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "release-closure" OperationsOfficer
  released <- submit p.fi do
    exerciseCmd rahnCid ReleaseCollateral with
      note = "Contract fully repaid"
      releaseDocumentRef = None
      proposedByOfficerId = proposerId
      confirmedByOfficerId = confirmerId
  Some r <- queryContractId p.fi released
  assertMsg "Collateral should be Released" (r.collateralStatus == CollateralReleased)

-- Collateral enforced on default
testRahnEnforcedOnDefault : Script ()
testRahnEnforcedOnDefault = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "enforce-default" RecoveryOfficer
  enforced <- submit p.fi do
    exerciseCmd rahnCid EnforceCollateral with
      reason = "Contract defaulted"
      proposedByOfficerId = proposerId
      confirmedByOfficerId = confirmerId
  Some e <- queryContractId p.fi enforced
  assertMsg "Collateral should be Enforced" (e.collateralStatus == CollateralEnforced)

-- Cannot release already-released collateral
testCannotDoubleRelease : Script ()
testCannotDoubleRelease = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "double-release" OperationsOfficer
  released <- submit p.fi do
    exerciseCmd rahnCid ReleaseCollateral with
      note = "First release"
      releaseDocumentRef = None
      proposedByOfficerId = proposerId
      confirmedByOfficerId = confirmerId
  submitMustFail p.fi do
    exerciseCmd released ReleaseCollateral with
      note = "Second release"
      releaseDocumentRef = None
      proposedByOfficerId = proposerId
      confirmedByOfficerId = confirmerId
  pure ()

-- ─── Closure ──────────────────────────────────────────────────────────────

-- Full single-payment repayment enables CloseContract
testCloseWhenFullyRepaid : Script ()
testCloseWhenFullyRepaid = do
  p <- setupMParties
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate = date 2026 Jul 1, amountPaid = 2_300_000.0, installmentNo = 1, allocation = None, settlementAccount = None, directDebitRef = None
  closed <- submit p.fi do
    exerciseCmd payRes.updatedContract CloseContract with closingDate = date 2026 Jul 2
  Some cl <- queryContractId p.fi closed
  assertMsg "Should be Completed" (cl.status == Completed)

-- ─── M4/M3 helper ─────────────────────────────────────────────────────────────

-- Wa'd → Wakala → RecordAssetPurchase; stops before Qabdh so rejection tests
-- can exercise RejectDelivery without AcknowledgeDelivery having been called.
assetPurchaseViaWakala : MParties -> Script (ContractId AssetPurchaseRecord)
assetPurchaseViaWakala p = do
  wad <- submit p.borrower do
    createCmd MurabahahWad with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      financingRef         = None
      offerExpiresAt       = None
  wakala <- submit p.fi do exerciseCmd wad ProceedWithWakala
  submit p.borrower do
    exerciseCmd wakala RecordAssetPurchase with
      actualCost            = 2_000_000.0
      purchaseDate          = date 2026 Jun 15
      invoiceRef            = "LMS-INV-2026-00441"
      freightCost           = 0.0
      customsDuty           = 0.0
      insurancePremium      = 0.0
      otherAcquisitionCosts = 0.0

-- ─── M4: Asset rejection ─────────────────────────────────────────────────────

-- Borrower can reject a defective asset before acknowledging delivery.
-- RejectDelivery is nonconsuming — APR stays live for replacement or cancellation.
testRejectDelivery : Script ()
testRejectDelivery = do
  p      <- setupMParties
  apr    <- assetPurchaseViaWakala p
  rejCid <- submit p.borrower do
    exerciseCmd apr RejectDelivery with
      reason            = "Asset does not match specification"
      defectDescription = "Capacity 30MT, not 50MT as contracted"
  Some rej <- queryContractId p.fi rejCid
  assertMsg "Rejection reason captured" (rej.reason == "Asset does not match specification")
  -- APR must still be active — nonconsuming choice leaves it live for FI to replace
  Some live <- queryContractId p.borrower apr
  assertMsg "AssetPurchaseRecord still active after rejection" (not live.deliveryAcknowledged)

-- Guard: RejectDelivery fails once delivery has been acknowledged
testCannotRejectAfterAcknowledge : Script ()
testCannotRejectAfterAcknowledge = do
  p      <- setupMParties
  apr    <- assetPurchaseViaWakala p
  aprAck <- submit p.borrower do exerciseCmd apr AcknowledgeDelivery
  submitMustFail p.borrower do
    exerciseCmd aprAck RejectDelivery with
      reason            = "Too late"
      defectDescription = "Asset already acknowledged"
  pure ()

-- ─── M3: Supplier payment record ─────────────────────────────────────────────

-- FI records supplier payment proof; AssetPurchaseRecord remains active (nonconsuming)
testRecordSupplierPayment : Script ()
testRecordSupplierPayment = do
  p          <- setupMParties
  apr        <- assetPurchaseViaWakala p
  paymentCid <- submit p.fi do
    exerciseCmd apr RecordSupplierPayment with
      amountPaid          = 2_000_000.0
      paymentDate         = date 2026 Jun 14
      paymentRef          = "FI-PAY-2026-00001"
      bankConfirmationRef = Some "BANK-CONF-2026-001"
  Some payment <- queryContractId p.fi paymentCid
  assertMsg "Supplier payment amount matches" (payment.amountPaid == 2_000_000.0)
  assertMsg "Payment reference captured" (payment.paymentRef == "FI-PAY-2026-00001")
  aprs <- query @AssetPurchaseRecord p.fi
  assertMsg "AssetPurchaseRecord still active after supplier payment record" (not (null aprs))

-- ─── M5: Proposal expiry and withdrawal ──────────────────────────────────────

-- FI can withdraw a proposal before the borrower responds
testWithdrawProposal : Script ()
testWithdrawProposal = do
  p        <- setupMParties
  schedCid <- createScheduleContract p
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = "FAC-2026-RC123456-001"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = sampleMurabahahTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = None
  submit p.fi do
    exerciseCmd proposal WithdrawProposal with reason = "FI credit limit exceeded"
  proposals <- query @MurabahahProposal p.fi
  assertMsg "Proposal archived after withdrawal" (null proposals)

-- vetify can expire a proposal after the acceptance window has elapsed
testExpireProposalAfterWindow : Script ()
testExpireProposalAfterWindow = do
  p <- setupMParties
  -- Test ledger starts at 1970-01-01T00:00:00Z; expiry 30 min after epoch
  let expiry = datetime 1970 Jan 1 0 30 0
  schedCid <- createScheduleContract p
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = "FAC-2026-RC123456-001"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = sampleMurabahahTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = Some expiry
  passTime (hours 1)
  submit p.vetify do exerciseCmd proposal ExpireProposal
  proposals <- query @MurabahahProposal p.vetify
  assertMsg "Proposal archived after expiry" (null proposals)

-- Guard: ExpireProposal fails when the acceptance window has not yet elapsed
testCannotExpireProposalBeforeWindow : Script ()
testCannotExpireProposalBeforeWindow = do
  p <- setupMParties
  -- Expiry 1 hour after epoch; no passTime → current time still at epoch
  let expiry = datetime 1970 Jan 1 1 0 0
  schedCid <- createScheduleContract p
  proposal <- submit p.fi do
    createCmd MurabahahProposal with
      borrower             = p.borrower
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = "FAC-2026-RC123456-001"
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      assetDetails         = sampleAssetDetails
      actualCost           = 2_000_000.0
      murabahahTerms       = sampleMurabahahTerms
      paymentScheduleCid   = schedCid
      startDate            = date 2026 Jul 1
      acceptanceExpiresAt  = Some expiry
  submitMustFail p.vetify do exerciseCmd proposal ExpireProposal
  pure ()

-- ─── M6: Payment allocation ───────────────────────────────────────────────────

-- RecordPayment with a PaymentAllocation breakdown is stored on RepaymentRecord
testPaymentWithAllocation : Script ()
testPaymentWithAllocation = do
  p <- setupMParties
  c <- activeContractDirect p
  let alloc = PaymentAllocation with
        principalComponent = 175_000.0
        profitComponent    = 15_000.0
        feesCharged        = 0.0
        charityProvision   = 1_666.67
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = Some alloc
      settlementAccount = None
      directDebitRef     = None
  Some rep <- queryContractId p.fi payRes.repaymentRecord
  assertMsg "PaymentAllocation stored on RepaymentRecord" (rep.allocation == Some alloc)
  assertMsg "On-time payment not marked late" (not rep.wasLate)

-- ─── Guard: cannot close a contract that still carries a balance
testCannotCloseWithBalance : Script ()
testCannotCloseWithBalance = do
  p <- setupMParties
  c <- activeContractDirect p
  submitMustFail p.fi do
    exerciseCmd c CloseContract with closingDate = date 2026 Jul 1
  pure ()

-- ─── M7: Contract restructuring ──────────────────────────────────────────────

-- Borrower requests restructuring; FI approves with a new schedule
testApproveRestructuring : Script ()
testApproveRestructuring = do
  p <- setupMParties
  c <- activeContractDirect p
  let newSchedule =
        [ PaymentScheduleEntry with installmentNo = 1; dueDate = date 2026 Oct 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 2; dueDate = date 2027 Jan 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 3; dueDate = date 2027 Apr 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        ]
  reqCid <- submit p.borrower do
    exerciseCmd c RequestRestructuring with
      proposedSchedule = newSchedule
      reason           = "Cash flow difficulties due to seasonal downturn"
      requestDate      = date 2026 Aug 1
  Some req <- queryContractId p.fi reqCid
  assertMsg "Request carries outstanding balance" (req.outstandingBalance == 2_300_000.0)
  updated <- submit p.fi do
    exerciseCmd c ApproveRestructuring with
      reqCid            = reqCid
      approvedSchedule  = newSchedule
      restructuringDate = date 2026 Aug 5
      maxRestructurings = None
  Some u <- queryContractId p.borrower updated
  Some sched <- queryContractId p.fi u.paymentScheduleCid
  assertMsg "Payment schedule updated" (length sched.entries == 3)
  assertMsg "scheduleVersion incremented" (u.scheduleVersion == 2)
  assertMsg "restructuringCount incremented" (u.restructuringCount == 1)
  reqs <- query @RestructuringRequest p.fi
  assertMsg "RestructuringRequest archived after approval" (null reqs)

-- Business limit: a second restructuring is blocked once maxRestructurings is reached.
testRestructuringFrequencyLimitEnforced : Script ()
testRestructuringFrequencyLimitEnforced = do
  p <- setupMParties
  c <- activeContractDirect p
  let schedule1 =
        [ PaymentScheduleEntry with installmentNo = 1; dueDate = date 2026 Oct 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 2; dueDate = date 2027 Jan 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 3; dueDate = date 2027 Apr 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        ]
  req1 <- submit p.borrower do
    exerciseCmd c RequestRestructuring with
      proposedSchedule = schedule1
      reason           = "First restructuring — seasonal downturn"
      requestDate      = date 2026 Aug 1
  updated1 <- submit p.fi do
    exerciseCmd c ApproveRestructuring with
      reqCid            = req1
      approvedSchedule  = schedule1
      restructuringDate = date 2026 Aug 5
      maxRestructurings = Some 1
  let schedule2 =
        [ PaymentScheduleEntry with installmentNo = 1; dueDate = date 2027 Feb 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 2; dueDate = date 2027 May 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        , PaymentScheduleEntry with installmentNo = 3; dueDate = date 2027 Aug 1; dueAmount = 115_000.0; principalComponent = None; profitComponent = None
        ]
  req2 <- submit p.borrower do
    exerciseCmd updated1 RequestRestructuring with
      proposedSchedule = schedule2
      reason           = "Second restructuring request"
      requestDate      = date 2026 Dec 1
  submitMustFail p.fi do
    exerciseCmd updated1 ApproveRestructuring with
      reqCid            = req2
      approvedSchedule  = schedule2
      restructuringDate = date 2026 Dec 5
      maxRestructurings = Some 1  -- already at limit (restructuringCount == 1)
  pure ()

-- Guard: FI rejects the restructuring request
testRejectRestructuring : Script ()
testRejectRestructuring = do
  p <- setupMParties
  c <- activeContractDirect p
  let proposedSchedule =
        [ PaymentScheduleEntry with installmentNo = 1; dueDate = date 2027 Jun 1; dueAmount = 2_300_000.0; principalComponent = None; profitComponent = None ]
  reqCid <- submit p.borrower do
    exerciseCmd c RequestRestructuring with
      proposedSchedule
      reason      = "Request extension to single bullet payment"
      requestDate = date 2026 Aug 1
  rejCid <- submit p.fi do
    exerciseCmd c RejectRestructuring with
      reqCid = reqCid
      reason = "Policy does not permit bullet repayment structures"
  reqs <- query @RestructuringRequest p.fi
  assertMsg "RestructuringRequest archived after rejection" (null reqs)
  Some rej <- queryContractId p.fi rejCid
  assertMsg "Rejection reason recorded" (rej.reason == "Policy does not permit bullet repayment structures")

-- ─── M8: Partial Ibra' ───────────────────────────────────────────────────────

-- FI grants a partial early settlement rebate
testPartialIbra : Script ()
testPartialIbra = do
  p <- setupMParties
  c <- activeContractDirect p
  (proposerId, confirmerId) <- createOfficerPair p "partial-ibra" CreditOfficer
  req <- submit p.borrower do
    exerciseCmd c RequestIbra with
      requestedSettlementDate = date 2026 Sep 1
      settlementType          = PartialIbra
      requestedAmount         = Some 1_000_000.0
  submit p.fi do
    exerciseCmd req GrantPartialIbra with
      rebateAmount             = 30_000.0
      approvedSettlementAmount = 970_000.0
      proposedByOfficerId      = proposerId
      confirmedByOfficerId     = confirmerId
  pure ()

-- ─── M9: Multiple assets ─────────────────────────────────────────────────────

-- AssetPurchaseRecord can carry additional assets beyond the primary
testMultipleAssets : Script ()
testMultipleAssets = do
  p   <- setupMParties
  apr <- assetPurchaseViaWakala p
  let extraItem = AssetLineItem with
        description     = "Commercial refrigerator — 500L capacity"
        supplierName    = "CoolTech Equipment Ltd"
        supplierRef     = "CT-INV-2026-00112"
        estimatedCost   = 350_000.0
        actualCost      = Some 340_000.0
        supplierDetails = None
  -- UpdateAdditionalAssets is not a choice — we verify the field exists on APR
  Some a <- queryContractId p.fi apr
  assertMsg "Additional assets list starts empty" (null a.additionalAssets)
  -- A real workflow would archive and recreate (not modelled here);
  -- this test confirms the field is structurally present and typeable.
  let _ = extraItem
  pure ()

-- ─── M10: Settlement accounts ────────────────────────────────────────────────

-- RecordPayment stores the repayment bank account on RepaymentRecord
testRecordPaymentWithSettlementAccount : Script ()
testRecordPaymentWithSettlementAccount = do
