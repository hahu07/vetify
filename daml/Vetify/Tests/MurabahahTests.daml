-- ─── F-2: PurchaseOrder ──────────────────────────────────────────────────

sampleSupplierDetails : SupplierDetails
sampleSupplierDetails = SupplierDetails with
  supplierName      = "Flour Mills of Nigeria PLC"
  supplierAddress   = "2 Old Dock Road, Apapa, Lagos"
  supplierRegNumber = Some "RC001759"
  contactEmail      = Some "sales@flourmillsnigeria.com"
  bankAccountRef    = Some "VETIFY-VENDOR-FMN-001"

sampleOrderedItems : [AssetLineItem]
sampleOrderedItems =
  [ AssetLineItem with
      description     = "50 metric tonnes of white flour (Grade A)"
      supplierName    = "Flour Mills of Nigeria PLC"
      supplierRef     = "FMN-INV-2026-0042"
      estimatedCost   = 2_300_000.0
      actualCost      = None
      supplierDetails = Some sampleSupplierDetails
  ]

testPurchaseOrderLifecycle : Script ()
testPurchaseOrderLifecycle = do
  p   <- setupMParties
  now <- getTime
  poCid <- submit p.fi do
    createCmd PurchaseOrder with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      supplierName         = "Flour Mills of Nigeria PLC"
      supplierDetails      = sampleSupplierDetails
      orderedItems         = sampleOrderedItems
      totalOrderValue      = 2_300_000.0
      deliveryDeadline     = date 2026 Aug 15
      poRef                = "PO-2026-RC123456-001"
      issuedAt             = now
      status               = POIssued
  -- Supplier confirms
  confirmed <- submit p.fi do
    exerciseCmd poCid ConfirmPO with confirmationRef = "FMN-PO-CONF-2026-0042"
  Some cv <- queryContractId p.fi confirmed
  assertMsg "PO status is Confirmed" (cv.status == POConfirmed)
  -- Partial delivery
  partial <- submit p.fi do
    exerciseCmd confirmed MarkPartiallyFulfilled with deliveryRef = "DEL-001"
  Some pv <- queryContractId p.fi partial
  assertMsg "PO status is PartiallyFulfilled" (pv.status == POPartiallyFulfilled)
  -- Full fulfillment
  fulfilled <- submit p.fi do
    exerciseCmd partial MarkFulfilled with deliveryRef = "DEL-002"
  Some fv <- queryContractId p.fi fulfilled
  assertMsg "PO status is Fulfilled" (fv.status == POFulfilled)
  -- Borrower can observe the PO
  Some bv <- queryContractId p.borrower fulfilled
  assertMsg "Borrower sees PO total value" (bv.totalOrderValue == 2_300_000.0)

testPurchaseOrderCancellation : Script ()
testPurchaseOrderCancellation = do
  p   <- setupMParties
  now <- getTime
  poCid <- submit p.fi do
    createCmd PurchaseOrder with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      supplierName         = "Flour Mills of Nigeria PLC"
      supplierDetails      = sampleSupplierDetails
      orderedItems         = sampleOrderedItems
      totalOrderValue      = 2_300_000.0
      deliveryDeadline     = date 2026 Aug 15
      poRef                = "PO-2026-RC123456-002"
      issuedAt             = now
      status               = POIssued
  cancelled <- submit p.fi do
    exerciseCmd poCid CancelPO with reason = "Borrower withdrew Wa'd before supplier confirmation"
  Some cv <- queryContractId p.fi cancelled
  assertMsg "PO status is Cancelled" (cv.status == POCancelled)

testCannotCancelFulfilledPO : Script ()
testCannotCancelFulfilledPO = do
  p   <- setupMParties
  now <- getTime
  poCid <- submit p.fi do
    createCmd PurchaseOrder with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      supplierName         = "Flour Mills of Nigeria PLC"
      supplierDetails      = sampleSupplierDetails
      orderedItems         = sampleOrderedItems
      totalOrderValue      = 2_300_000.0
      deliveryDeadline     = date 2026 Aug 15
      poRef                = "PO-2026-RC123456-003"
      issuedAt             = now
      status               = POIssued
  confirmed  <- submit p.fi do exerciseCmd poCid ConfirmPO with confirmationRef = "CONF-003"
  fulfilled  <- submit p.fi do exerciseCmd confirmed MarkFulfilled with deliveryRef = "DEL-003"
  submitMustFail p.fi do
    exerciseCmd fulfilled CancelPO with reason = "Cannot cancel after fulfillment"
  pure ()

-- ─── F-3: CapitalCallRecord ───────────────────────────────────────────────

testCapitalCallRecord : Script ()
testCapitalCallRecord = do
  p <- setupMParties
  tranche1 <- submit p.fi do
    createCmd CapitalCallRecord with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      trancheNumber        = 1
      trancheAmount        = 1_000_000.0
      disbursementDate     = date 2026 Jul 15
      purposeOfTranche     = "Initial inventory purchase — 25 MT flour"
      disbursementRef      = "DISB-2026-RC123456-001"
      cumulativeDisbursed  = 1_000_000.0
      remainingFacility    = 1_300_000.0
  Some t1 <- queryContractId p.fi tranche1
  assertMsg "Tranche 1 amount correct" (t1.trancheAmount == 1_000_000.0)
  assertMsg "Remaining facility correct" (t1.remainingFacility == 1_300_000.0)
  Some regView <- queryContractId p.regulator tranche1
  assertMsg "Regulator sees tranche disbursement" (regView.trancheNumber == 1)
  tranche2 <- submit p.fi do
    createCmd CapitalCallRecord with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      trancheNumber        = 2
      trancheAmount        = 1_300_000.0
      disbursementDate     = date 2026 Aug 15
      purposeOfTranche     = "Second inventory tranche — 25 MT flour"
      disbursementRef      = "DISB-2026-RC123456-002"
      cumulativeDisbursed  = 2_300_000.0
      remainingFacility    = 0.0
  Some t2 <- queryContractId p.fi tranche2
  assertMsg "Tranche 2 cumulative correct" (t2.cumulativeDisbursed == 2_300_000.0)
  assertMsg "Facility fully drawn" (t2.remainingFacility == 0.0)

testCapitalCallNoRegulator : Script ()
testCapitalCallNoRegulator = do
  p <- setupMParties
  trancheCid <- submit p.fi do
    createCmd CapitalCallRecord with
      financialInstitution = p.fi
      vetify               = p.vetify
      borrower             = p.borrower
      regulator            = None
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      trancheNumber        = 1
      trancheAmount        = 500_000.0
      disbursementDate     = date 2026 Jul 15
      purposeOfTranche     = "Test tranche without regulator"
      disbursementRef      = "DISB-TEST-001"
      cumulativeDisbursed  = 500_000.0
      remainingFacility    = 1_800_000.0
  noVisibility <- queryContractId p.regulator trancheCid
  assertMsg "Regulator has no visibility when regulator = None" (noVisibility == None)
  pure ()

-- ─── F-4: ForceMajeureDeclaration ────────────────────────────────────────

testForceMajeureLifecycle : Script ()
testForceMajeureLifecycle = do
  p <- setupMParties
  decCid <- submit p.vetify do
    createCmd ForceMajeureDeclaration with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      declarationRef       = "FMD-2026-CBN-001"
      eventDescription     = "COVID-19 wave 3 — CBN directive for 90-day payment moratorium"
      affectedRegion       = "Nationwide"
      suspensionStart      = date 2026 Mar 1
      suspensionEnd        = date 2026 May 31
      regulatoryBasis      = "CBN Circular FPR/DIR/GEN/CIR/07/004"
      isActive             = True
  Some dv <- queryContractId p.fi decCid
  assertMsg "Declaration is active" dv.isActive
  assertMsg "Affected region recorded" (dv.affectedRegion == "Nationwide")
  Some rv <- queryContractId p.regulator decCid
  assertMsg "Regulator observes declaration" (rv.declarationRef == "FMD-2026-CBN-001")
  -- Lift after event passes
  lifted <- submit p.vetify do
    exerciseCmd decCid LiftDeclaration with note = "CBN confirmed end of moratorium period"
  Some lv <- queryContractId p.fi lifted
  assertMsg "Declaration is no longer active" (not lv.isActive)

testCannotLiftAlreadyLiftedDeclaration : Script ()
testCannotLiftAlreadyLiftedDeclaration = do
  p <- setupMParties
  decCid <- submit p.vetify do
    createCmd ForceMajeureDeclaration with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = None
      declarationRef       = "FMD-2026-TEST-001"
      eventDescription     = "Test force majeure"
      affectedRegion       = "Lagos"
      suspensionStart      = date 2026 Mar 1
      suspensionEnd        = date 2026 Apr 30
      regulatoryBasis      = "Internal test"
      isActive             = True
  lifted <- submit p.vetify do
    exerciseCmd decCid LiftDeclaration with note = "First lift"
  submitMustFail p.vetify do
    exerciseCmd lifted LiftDeclaration with note = "Cannot lift again"
  pure ()

-- ─── F-5: CharityOrganizationRegistry ────────────────────────────────────

testCharityRegistryLifecycle : Script ()
testCharityRegistryLifecycle = do
  p <- setupMParties
  -- FI creates its approved Shariah board charity list
  regCid <- submit p.fi do
    createCmd CharityOrganizationRegistry with
      financialInstitution  = p.fi
      vetify                = p.vetify
      regulator             = Some p.regulator
      approvedOrganizations =
        [ ("Islamic Relief Nigeria", "IRN-CAC-2024-001")
        , ("Al-Hayat Foundation", "AHF-CAC-2023-117")
        ]
      shariahBoardRef       = "SB-RESOLUTION-2024-03"
      effectiveDate         = date 2024 Jan 1
      version               = "v1.0"
  Some rv <- queryContractId p.fi regCid
  assertMsg "Registry has 2 approved orgs" (length rv.approvedOrganizations == 2)
  Some vv <- queryContractId p.vetify regCid
  assertMsg "Vetify observes registry" (vv.version == "v1.0")
  -- FI updates the list (Shariah board adds a new org)
  updated <- submit p.fi do
    exerciseCmd regCid UpdateRegistry with
      newOrganizations =
        [ ("Islamic Relief Nigeria", "IRN-CAC-2024-001")
        , ("Al-Hayat Foundation", "AHF-CAC-2023-117")
        , ("Mercy Corps Nigeria", "MCN-CAC-2025-044")
        ]
      newVersion       = "v1.1"
      updatedBoardRef  = "SB-RESOLUTION-2025-01"
  Some uv <- queryContractId p.fi updated
  assertMsg "Registry updated to 3 orgs" (length uv.approvedOrganizations == 3)
  assertMsg "Version updated" (uv.version == "v1.1")

testConfirmCharityPaymentWithRegistry : Script ()
testConfirmCharityPaymentWithRegistry = do
  p <- setupMParties
  -- FI creates its charity registry
  regCid <- submit p.fi do
    createCmd CharityOrganizationRegistry with
      financialInstitution  = p.fi
      vetify                = p.vetify
      regulator             = Some p.regulator
      approvedOrganizations = [("Islamic Relief Nigeria", "IRN-CAC-2024-001")]
      shariahBoardRef       = "SB-RESOLUTION-2024-03"
      effectiveDate         = date 2024 Jan 1
      version               = "v1.0"
  -- Create a late payment (triggers charity obligation)
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Aug 15
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef    = None
  Some charityCid <- pure payRes.charityObligation
  withAmount <- submit p.fi do
    exerciseCmd charityCid SetCharityAmount with amount = 5_000.0
  -- Both parties co-sign: FI fetches registry; borrower authorises CharityPaymentRecord
  rcptCid <- submitMulti [p.borrower, p.fi] [] do
    exerciseCmd withAmount ConfirmCharityPaymentValidated with
      charityRef          = "CHARITY-RCPT-REG-001"
      charityOrganization = "Islamic Relief Nigeria"
      registryCid         = regCid
  Some rcpt <- queryContractId p.fi rcptCid
  assertMsg "Registry-validated charity payment recorded" (rcpt.charityAmount == 5_000.0)

testConfirmCharityPaymentRejectsUnapprovedOrg : Script ()
testConfirmCharityPaymentRejectsUnapprovedOrg = do
  p <- setupMParties
  regCid <- submit p.fi do
    createCmd CharityOrganizationRegistry with
      financialInstitution  = p.fi
      vetify                = p.vetify
      regulator             = None
      approvedOrganizations = [("Islamic Relief Nigeria", "IRN-CAC-2024-001")]
      shariahBoardRef       = "SB-RESOLUTION-2024-03"
      effectiveDate         = date 2024 Jan 1
      version               = "v1.0"
  c <- activeContractDirect p
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Aug 15
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = None
      directDebitRef    = None
  Some charityCid <- pure payRes.charityObligation
  withAmount <- submit p.fi do
    exerciseCmd charityCid SetCharityAmount with amount = 5_000.0
  -- Unapproved org fails when using the co-signed validated path
  submitMultiMustFail [p.borrower, p.fi] [] do
    exerciseCmd withAmount ConfirmCharityPaymentValidated with
      charityRef          = "CHARITY-RCPT-BAD-001"
      charityOrganization = "Unknown Charity Organisation"
      registryCid         = regCid
  pure ()

-- ─── Governance Phase A: RBAC / maker-checker negative tests ────────────────

-- WriteOffContract must fail when the proposer and confirmer are the same officer.
testWriteOffSameOfficerBlocked : Script ()
testWriteOffSameOfficerBlocked = do
  p    <- setupMParties
  c    <- activeContractDirect p
  (officerId, _) <- createOfficerPair p "writeoff-same-officer" RecoveryOfficer
  (delq, _) <- submit p.vetify do exerciseCmd c FlagDelinquent with reason = "Non-payment"
  (dflt, _) <- submit p.fi do
    exerciseCmd delq DefaultContract with reason = "Irrecoverable"; defaultedBy = "Test Officer"
  submitMustFail p.fi do
    exerciseCmd dflt WriteOffContract with
      writeOffDate         = date 2027 Jan 1
      writeOffRef          = "WO-SAME-001"
      totalRecovered       = 0.0
      writeOffApprovedBy   = "Proposer Officer writeoff-same-officer"
      proposedByOfficerId  = officerId
      confirmedByOfficerId = officerId  -- same officer as proposer — must be rejected
  pure ()

-- WriteOffContract must fail when the confirming officer does not hold the RiskOfficer role.
testWriteOffWrongRoleBlocked : Script ()
testWriteOffWrongRoleBlocked = do
  p    <- setupMParties
  c    <- activeContractDirect p
  (proposerId, _) <- createOfficerPair p "writeoff-wrong-role" RecoveryOfficer
  t <- getTime
  submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId             = "CONF-writeoff-wrong-role-2"
      officerName           = "Wrong Role Confirmer"
      roles                 = [OperationsOfficer]  -- not RiskOfficer
      authorizedBy          = "FI Head Office"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  (delq, _) <- submit p.vetify do exerciseCmd c FlagDelinquent with reason = "Non-payment"
  (dflt, _) <- submit p.fi do
    exerciseCmd delq DefaultContract with reason = "Irrecoverable"; defaultedBy = "Test Officer"
  submitMustFail p.fi do
    exerciseCmd dflt WriteOffContract with
      writeOffDate         = date 2027 Jan 1
      writeOffRef          = "WO-WRONGROLE-001"
      totalRecovered       = 0.0
      writeOffApprovedBy   = "Wrong Role Confirmer"
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = "CONF-writeoff-wrong-role-2"
  pure ()

-- ReleaseCollateral must fail when the proposer and confirmer are the same officer.
testReleaseCollateralSameOfficerBlocked : Script ()
testReleaseCollateralSameOfficerBlocked = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (officerId, _) <- createOfficerPair p "release-same-officer" OperationsOfficer
  submitMustFail p.fi do
    exerciseCmd rahnCid ReleaseCollateral with
      note                 = "Attempted single-officer release"
      releaseDocumentRef   = None
      proposedByOfficerId  = officerId
      confirmedByOfficerId = officerId
  pure ()

-- EnforceCollateral must fail when the confirming officer is inactive.
testEnforceCollateralDeactivatedOfficerBlocked : Script ()
testEnforceCollateralDeactivatedOfficerBlocked = do
  p       <- setupMParties
  rahnCid <- createRahn p
  (proposerId, confirmerId) <- createOfficerPair p "enforce-deactivated" RecoveryOfficer
  Some (confirmerCid, _) <- queryByKey @AuthorizedOfficer p.fi (p.fi, confirmerId)
  submit p.fi do exerciseCmd confirmerCid DeactivateOfficer with reason = "On leave"; performedBy = "FI HR"
  submitMustFail p.fi do
    exerciseCmd rahnCid EnforceCollateral with
      reason               = "Contract defaulted"
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  pure ()

-- GrantIbra must fail when proposer and confirmer are the same officer.
testGrantIbraSameOfficerBlocked : Script ()
testGrantIbraSameOfficerBlocked = do
  p <- setupMParties
  c <- activeContractDirect p
  (officerId, _) <- createOfficerPair p "ibra-same-officer" CreditOfficer
  req <- submit p.borrower do
    exerciseCmd c RequestIbra with requestedSettlementDate = date 2026 Dec 1, settlementType = FullIbra, requestedAmount = None
  submitMustFail p.fi do
    exerciseCmd req GrantIbra with
      rebateAmount         = 50_000.0
      proposedByOfficerId  = officerId
      confirmedByOfficerId = officerId
  pure ()
