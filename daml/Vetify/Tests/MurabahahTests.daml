  c <- activeContractDirect p
  let acct = SettlementAccount with
        bankName       = "Access Bank"
        accountRef     = "0123456789"
        accountType    = "NUBAN"
        currency       = "NGN"
        beneficiaryRef = Some "VETIFY-BENE-001"
  payRes <- submit p.fi do
    exerciseCmd c RecordPayment with
      paymentDate       = date 2026 Jul 1
      amountPaid        = 191_666.67
      installmentNo     = 1
      allocation        = None
      settlementAccount = Some acct
      directDebitRef     = None
  Some rep <- queryContractId p.fi payRes.repaymentRecord
  assertMsg "Settlement account stored on RepaymentRecord" (rep.settlementAccount == Some acct)

-- ─── M11: Shariah audit ──────────────────────────────────────────────────────

-- Vetify creates a Shariah audit record visible to FI and regulator
testShariahAudit : Script ()
testShariahAudit = do
  p <- setupMParties
  auditCid <- submit p.vetify do
    createCmd ShariahAuditRecord with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = None
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      auditDate            = date 2026 Jun 30
      auditPeriod          = "2026-H1"
      auditorRef           = "AAOIFI-CERT-AUDITOR-001"
      findings             = ["Murabahah profit disclosure confirmed", "Payment schedule matches contract"]
      overallCompliant     = True
      recommendations      = ["Maintain current documentation standards"]
      nextAuditDate        = Some (date 2026 Dec 31)
  Some audit <- queryContractId p.regulator auditCid
  assertMsg "Audit marked as compliant" audit.overallCompliant
  Some _ <- queryContractId p.fi auditCid
  pure ()

-- ─── M12: Shariah exceptions ─────────────────────────────────────────────────

-- Vetify records and then resolves a Shariah exception
testShariahException : Script ()
testShariahException = do
  p <- setupMParties
  excCid <- submit p.vetify do
    createCmd ShariahException with
      vetify               = p.vetify
      financialInstitution = p.fi
      regulator            = Some p.regulator
      facilityRef          = None
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      exceptionType        = "LATE_CHARITY_DISBURSEMENT"
      description          = "Sadaqah obligation from Aug installment not disbursed within 30 days"
      severity             = MinorException
      detectedAt           = datetime 1970 Jan 1 0 0 0
      resolutionNote       = None
      resolvedAt           = None
  Some exc <- queryContractId p.fi excCid
  assertMsg "Exception unresolved on creation" (exc.resolutionNote == None)
  resolved <- submit p.vetify do
    exerciseCmd excCid ResolveException with
      note      = "Sadaqah of NGN 5,000 disbursed to Islamic Relief Nigeria — receipt REF-2026-0087"
      resolveAt = datetime 1970 Jan 1 1 0 0
  Some r <- queryContractId p.fi resolved
  assertMsg "Resolution note stored" (r.resolutionNote /= None)
  assertMsg "Resolved timestamp stored" (r.resolvedAt /= None)

-- ─── M13: Regulatory reporting ────────────────────────────────────────────────

-- Vetify generates a MurabahahStatement observable by the regulator
testMurabahahStatement : Script ()
testMurabahahStatement = do
  p <- setupMParties
  stmtCid <- submit p.vetify do
    createCmd MurabahahStatement with
      vetify               = p.vetify
      borrower             = p.borrower
      financialInstitution = p.fi
      regulator            = Some p.regulator
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      statementDate        = date 2026 Sep 30
      statementPeriod      = "2026-Q3"
      totalFinanced        = 2_300_000.0
      totalRepaid          = 575_000.01
      outstandingBalance   = 1_724_999.99
      installmentsPaid     = 3
      totalInstallments    = 12
      contractStatus       = Active
      shariahAuditRef      = Some "AAOIFI-CERT-AUDITOR-001"
  Some stmt <- queryContractId p.regulator stmtCid
