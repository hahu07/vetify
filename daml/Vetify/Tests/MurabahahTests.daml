-- ─── M-IF: Ibra' rebate proposal ─────────────────────────────────────────────

testIbraRebateProposal : Script ()
testIbraRebateProposal = do
  p   <- setupMParties
  cid <- activeContractDirect p
  -- Borrower requests early full settlement
  ibraCid <- submit p.borrower do
    exerciseCmd cid RequestIbra with
      requestedSettlementDate = date 2026 Dec 1
      settlementType          = FullIbra
      requestedAmount         = None
  -- FI's financing team proposes an advisory rebate (BD-4: FI, not vetify, controls this)
  proposalCid <- submit p.fi do
    exerciseCmd ibraCid ProposeRebate with
      suggestedRebate = 150_000.0   -- FI formula: remaining profit × remaining tenure / total tenure
      rationale       = "12 of 12 instalments remaining; full profit waiver suggested per CBN guidance"
  Some proposal <- queryContractId p.fi proposalCid
  assertMsg "Suggested rebate recorded" (proposal.suggestedRebate == 150_000.0)
  -- FI exercises their own discretion — grants a smaller rebate (not obligated to follow)
  (proposerId, confirmerId) <- createOfficerPair p "ibra-rebate-proposal" CreditOfficer
  submit p.fi do
    exerciseCmd ibraCid GrantIbra with
      rebateAmount         = 100_000.0
      proposedByOfficerId  = proposerId
      confirmedByOfficerId = confirmerId
  -- IbraRequest is consumed; FI now exercises RecordEarlySettlement
  (settled, _rec) <- submit p.fi do
    exerciseCmd cid RecordEarlySettlement with
      settlementType    = FullIbra
      settlementAmount  = 2_300_000.0
      settlementDate    = date 2026 Dec 1
      settlementAccount = None
  Some sv <- queryContractId p.fi settled
  assertMsg "Contract completed after full settlement" (sv.status == Completed)


-- ─── Batch B: new Batch B tests ──────────────────────────────────────────────

-- B-1: Reject delivery → FI replaces asset → acquisition proceeds normally
testRejectAndReplace : Script ()
testRejectAndReplace = do
  p   <- setupMParties
  apr <- assetPurchaseViaWakala p
  -- Borrower rejects the initial delivery (nonconsuming — APR stays live)
  rejCid <- submit p.borrower do
    exerciseCmd apr RejectDelivery with
      reason            = "Wrong model delivered"
      defectDescription = "Model MDDP received instead of contracted MDDQ"
  Some rej <- queryContractId p.fi rejCid
  assertMsg "Rejection recorded" (rej.reason == "Wrong model delivered")
  -- FI ships a replacement — new APR created, old one archived
  newApr <- submit p.fi do
    exerciseCmd apr ProceedWithReplacement with
      newActualCost   = 2_050_000.0
      newPurchaseDate = date 2026 Jul 5
      newInvoiceRef   = "LMS-INV-2026-00442"
      replacementNote = "MDDQ model sourced from alternative supplier"
  Some newA <- queryContractId p.fi newApr
  assertMsg "Replacement cost updated" (newA.actualCost == 2_050_000.0)
  assertMsg "Delivery not yet acknowledged on replacement" (not newA.deliveryAcknowledged)
  -- Borrower acknowledges the replacement delivery
  newAprAcked <- submit p.borrower do exerciseCmd newApr AcknowledgeDelivery
  Some acked <- queryContractId p.fi newAprAcked
  assertMsg "Replacement acknowledged" acked.deliveryAcknowledged

-- B-1: Borrower requests cancellation; FI accepts — both records archived
testCancellationPath : Script ()
testCancellationPath = do
  p   <- setupMParties
  apr <- assetPurchaseViaWakala p
  -- Borrower raises rejection then requests cancellation (FI cannot source replacement)
  _ <- submit p.borrower do
    exerciseCmd apr RejectDelivery with
      reason            = "Supplier cannot deliver"
      defectDescription = "Supplier has gone into administration"
  reqCid <- submit p.borrower do
    exerciseCmd apr RequestCancellation with
      reason = "Supplier insolvent; no alternative source available"
  Some req <- queryContractId p.fi reqCid
  assertMsg "Cancellation reason recorded" (req.reason == "Supplier insolvent; no alternative source available")
  -- FI accepts — archives both the request and the APR
  submit p.fi do
    exerciseCmd apr ConfirmCancellation with reqCid = reqCid
  aprs <- query @AssetPurchaseRecord p.fi
  assertMsg "APR archived after confirmed cancellation" (null aprs)

-- B-1: FI rejects the cancellation request — APR and request archived, deal continues
testCancellationRejected : Script ()
testCancellationRejected = do
  p   <- setupMParties
  apr <- assetPurchaseViaWakala p
  reqCid <- submit p.borrower do
    exerciseCmd apr RequestCancellation with
      reason = "Borrower changed mind"
  -- FI rejects the cancellation
  submit p.fi do exerciseCmd reqCid RejectCancellation
  -- APR is still active
  Some live <- queryContractId p.fi apr
  assertMsg "APR still active after FI rejects cancellation" (not live.deliveryAcknowledged)

-- B-2: GuaranteeAgreement lifecycle — enforce then release paths
testGuaranteeEnforced : Script ()
testGuaranteeEnforced = do
  p   <- setupMParties
  -- Both guarantor and FI are signatories — submitMulti required
  gCid <- submitMulti [p.borrower, p.fi] [] do
    createCmd GuaranteeAgreement with
      guarantor            = p.borrower
      financialInstitution = p.fi
      vetify               = p.vetify
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      guaranteeType        = "PERSONAL"
      guaranteedAmount     = 2_300_000.0
      guarantorName        = "Chukwuemeka Okonkwo"
      guarantorId          = "12345678901"
      effectiveDate        = date 2026 Jul 1
      expiryDate           = None
      guaranteeStatus      = GuaranteeActive
  gCid2 <- submit p.fi do
    exerciseCmd gCid EnforceGuarantee with reason = "Contract defaulted; collateral insufficient"
  Some g <- queryContractId p.fi gCid2
  assertMsg "Guarantee is Enforced" (g.guaranteeStatus == GuaranteeEnforced)
  -- Cannot enforce an already-enforced guarantee
  submitMustFail p.fi do
    exerciseCmd gCid2 EnforceGuarantee with reason = "Double enforcement"
  pure ()

testGuaranteeReleased : Script ()
testGuaranteeReleased = do
  p   <- setupMParties
  gCid <- submitMulti [p.borrower, p.fi] [] do
    createCmd GuaranteeAgreement with
      guarantor            = p.borrower
      financialInstitution = p.fi
      vetify               = p.vetify
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      facilityRef          = "FAC-2026-RC123456-001"
      guaranteeType        = "PERSONAL"
      guaranteedAmount     = 2_300_000.0
      guarantorName        = "Chukwuemeka Okonkwo"
      guarantorId          = "12345678901"
      effectiveDate        = date 2026 Jul 1
      expiryDate           = None
      guaranteeStatus      = GuaranteeActive
  gCid2 <- submit p.fi do
    exerciseCmd gCid ReleaseGuarantee with note = "Full repayment received; guarantee released"
  Some g <- queryContractId p.fi gCid2
  assertMsg "Guarantee is Released" (g.guaranteeStatus == GuaranteeReleased)

-- B-4: GrantIbra creates an IbraGrantRecord on the ledger
testIbraGrantRecord : Script ()
testIbraGrantRecord = do
