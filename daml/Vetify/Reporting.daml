-- | Ongoing regulatory portfolio reporting. Leaf module — depends only on
-- Vetify.Types. Created off-ledger by the Reporting Agent (all metrics
-- computed deterministically from the queried MurabahahContract set; the
-- agent's LLM only writes `summary`), for FI and regulator visibility.
module Vetify.Reporting where

-- | A snapshot of one FI's Murabahah portfolio at `reportDate`. Field set
-- mirrors the backend's `getPortfolioSummary` aggregation.
template PortfolioReport
  with
    vetify               : Party
    financialInstitution : Party
    -- | Read-only supervisory observer; `None` if this FI has none.
    regulator            : Optional Party
    reportDate           : Date
    totalActiveContracts : Int
    totalDisbursed       : Decimal
    totalOutstanding     : Decimal
    delinquentCount      : Int
    completedCount       : Int
    defaultedCount       : Int
    -- | Human-readable narrative, LLM-authored from the pre-computed
    -- metrics above.
    summary              : Text
  where
    signatory vetify
    observer [financialInstitution] ++ optional [] pure regulator
