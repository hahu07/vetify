{
  "name": "vetify-backend",
  "version": "0.1.0",
  "description": "REST API backend for the Vetify financing platform",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "seed:users": "tsx src/scripts/seedUsers.ts",
    "test": "tsx --test test/*.test.ts",
    "loadtest": "tsx loadtest/basic.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^12.0.1",
    "pg": "^8.11.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "autocannon": "^7.15.0",
    "@types/autocannon": "^7.12.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}