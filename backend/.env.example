# Canton Ledger — JSON Ledger API (v2), migrated from the classic v1 HTTP JSON
# API (see CLAUDE.md's Application Architecture section for why).
CANTON_LEDGER_URL=http://localhost:7575
CANTON_USER_ID=vetify-backend

# JWTs authorize *that* this backend may act as a party (Authorization header).
CANTON_BORROWER_JWT=your_borrower_party_jwt_token
CANTON_VETIFY_JWT=your_vetify_party_jwt_token
CANTON_VERIFIER_JWT=your_verifier_party_jwt_token
CANTON_FI_JWT=your_financial_institution_party_jwt_token
CANTON_REGULATOR_JWT=your_regulator_party_jwt_token
# Layer 2 of the Policy-Approval Security Roadmap (docs/deferred-gaps.md): a
# genuinely distinct party from vetify, held by the Risk & Credit Governance
# Committee (docs/risk-governance-charter.md). In a real deployment this JWT
# must be provisioned/held by the Committee's own system — configuring it
# here alongside every other party's JWT is only correct for local dev, where
# one backend process necessarily holds everything; doing the same in
# production defeats the entire point of Layer 2 (see policy.ts's doc comment).
CANTON_RISK_COMMITTEE_JWT=your_risk_committee_party_jwt_token

# Party IDs are the actual on-ledger identity (e.g. "Vetify::1220...") — v2's
# explicit actAs/query-filter model needs these in addition to the JWTs above;
# v1 never did, since it inferred the acting party from the token alone.
# Obtain by allocating each party once against the target participant
# (POST /v2/parties {"partyIdHint": "Vetify"}) and recording the resulting
# `party` string from the response.
CANTON_BORROWER_PARTY_ID=Borrower::...
CANTON_VETIFY_PARTY_ID=Vetify::...
CANTON_VERIFIER_PARTY_ID=Verifier::...
CANTON_FI_PARTY_ID=FinancialInstitution::...
CANTON_REGULATOR_PARTY_ID=Regulator::...
CANTON_RISK_COMMITTEE_PARTY_ID=RiskCommittee::...

# PQS PostgreSQL (read queries — populated by Scribe/PQS sidecar)
PQS_POSTGRES_HOST=localhost
PQS_POSTGRES_PORT=5432
PQS_POSTGRES_USER=vetify
PQS_POSTGRES_PASSWORD=vetify
PQS_POSTGRES_DATABASE=vetify-pqs

# App-owned PostgreSQL (users + audit_log — Layer 3 of the Policy-Approval
# Security Roadmap, see auth.ts/appdb.ts). Same Postgres instance as PQS by
# default (one docker-compose service), just a different database — the
# default "vetify" database (POSTGRES_DB), not "vetify-pqs" (Scribe-managed).
# Override these only if a real deployment splits app state onto its own
# Postgres instance.
APP_POSTGRES_HOST=localhost
APP_POSTGRES_PORT=5432
APP_POSTGRES_USER=vetify
APP_POSTGRES_PASSWORD=vetify
APP_POSTGRES_DATABASE=vetify

# Signs human session tokens (auth.ts) — distinct from every CANTON_*_JWT
# above, which authorize a shared *Canton party*, not an individual person.
# Generate a real random secret for anything beyond local dev.
SESSION_JWT_SECRET=dev-only-insecure-secret-change-me

# Verifies inbound mono.co webhooks (routes/webhooks.ts) against the
# "mono-webhook-secret" header, mirroring mono-server.ts's own "mono-sec-key"
# outbound-auth convention. Optional for local dev — if unset, signature
# verification is skipped entirely (do not leave unset in production).
MONO_WEBHOOK_SECRET=your_mono_webhook_secret

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173
