-- ─── Maker-checker for CompliancePolicy changes ────────────────────────────

-- ApprovePolicyChange with a distinct approver activates the proposal.
testCompliancePolicyChangeApprovedByDifferentPerson : Script ()
testCompliancePolicyChangeApprovedByDifferentPerson = do
  p <- setupCParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights with amlBothClear = 40
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review — raise AML weight"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  activeCid <- submit p.vetify do
    exerciseCmd endorsed ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = None
  Some active <- queryContractId p.vetify activeCid
  assertMsg "activated policy carries the proposed weights" (active.scoringWeights.amlBothClear == 40)
  assertMsg "activated policy carries the proposed version" (active.policyVersion == "2026-v3")

-- The same person cannot both propose and approve.
testCompliancePolicyChangeCannotSelfApprove : Script ()
testCompliancePolicyChangeCannotSelfApprove = do
  p <- setupCParties
  t <- getTime
  -- A real registrant, distinct from the point being tested (self-approval
  -- fails before the approver registry is even consulted) — still needed to
  -- supply a well-typed ContractId PolicyApprover argument.
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Alice (Risk Analyst)"
      role         = "Risk Analyst"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Alice (Risk Analyst)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- Approving a proposal replaces whichever CompliancePolicy was previously
-- active, and the ledger key prevents a second one from coexisting.
testCompliancePolicyChangeReplacesActivePolicy : Script ()
testCompliancePolicyChangeReplacesActivePolicy = do
  p <- setupCParties
  t <- getTime
  policyCid <- submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v2"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights with kybActiveFullMatch = 10
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Lower KYB weight"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  activeCid <- submit p.vetify do
    exerciseCmd endorsed ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = Some policyCid
  Some active <- queryContractId p.vetify activeCid
  assertMsg "the new policy version is active" (active.policyVersion == "2026-v2")
  assertMsg "the old scoringWeights no longer apply" (active.scoringWeights.kybActiveFullMatch == 10)
  -- Not asserted here: that a second CompliancePolicy create would now fail
  -- on the vetify-singleton key — dpm test's in-memory Script interpreter
  -- doesn't enforce ledger-level key uniqueness, only a real Canton
  -- participant does. ApprovePolicyChange's own successful create (asserted
  -- above) already proves the archive-then-create ran cleanly.
  pure ()

-- RejectPolicyChange withdraws a proposal without ever creating a CompliancePolicy.
testCompliancePolicyChangeCanBeRejected : Script ()
testCompliancePolicyChangeCanBeRejected = do
  p <- setupCParties
  t <- getTime
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Experimental change"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submit p.vetify do
    exerciseCmd pending RejectPolicyChange with
      rejectedBy      = "Alice (Risk Analyst)"
      rejectionReason = "Decided against it before anyone else reviewed"
  pure ()

-- Layer 1 of the Policy-Approval Security Roadmap: an unregistered name
-- cannot approve, even though it legitimately differs from proposedBy.
testCompliancePolicyChangeFailsIfApproverNotRegistered : Script ()
testCompliancePolicyChangeFailsIfApproverNotRegistered = do
  p <- setupCParties
  t <- getTime
  -- A real, distinct registrant — "Carol" herself was never registered, so
  -- we prove the identity-mismatch assertion in requireActivePolicyApprover
  -- fires: Bob's ContractId does not name "Carol".
  bobApproverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Carol (Nobody in Particular)"
      approverCid      = bobApproverCid
      currentPolicyCid = None
  pure ()

-- A deactivated approver cannot approve, even though they were once registered.
testCompliancePolicyChangeFailsIfApproverDeactivated : Script ()
testCompliancePolicyChangeFailsIfApproverDeactivated = do
  p <- setupCParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  submit p.vetify do
    exerciseCmd approverCid DeactivatePolicyApprover with
      reason      = "Left the risk committee"
      performedBy = "Vetify Founder"
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- Layer 2 of the Policy-Approval Security Roadmap: vetify cannot finalize a
-- compliance policy change on its own, even with a validly registered
-- approver, until the Risk Committee's own separately-signed transaction has
-- endorsed it.
testCompliancePolicyChangeFailsWithoutRiskCommitteeEndorsement : Script ()
testCompliancePolicyChangeFailsWithoutRiskCommitteeEndorsement = do
  p <- setupCParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  -- No EndorseByRiskCommittee call — a registered approver alone is not enough.
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- EndorseByRiskCommittee cannot be exercised twice on the same proposal.
testCompliancePolicyChangeCannotDoubleEndorse : Script ()
testCompliancePolicyChangeCannotDoubleEndorse = do
  p <- setupCParties
  t <- getTime
  pending <- submit p.vetify do
    createCmd PendingCompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
      proposedBy           = "Alice (Risk Analyst)"
      reason               = "Quarterly rubric review"
      proposedAt           = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  submitMustFail p.riskCommittee do
    exerciseCmd endorsed EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  pure ()

-- ─── G14: Enhanced Due Diligence case (PEP hits) ──────────────────────────────

-- OpenEddCase creates an Open EDDCase linked to this review, with an empty checklist.
testOpenEddCaseCreated : Script ()
testOpenEddCaseCreated = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  eddCid <- submit p.vetify do exerciseCmd ur OpenEddCase with triggerReason = "PEP_HIT"
  Some edd <- queryContractId p.vetify eddCid
  assertMsg "status Open" (edd.status == EddOpen)
  assertMsg "trigger reason stored" (edd.triggerReason == "PEP_HIT")
  assertMsg "checklist starts incomplete" (not edd.checklist.sourceOfWealthVerified)
  assertMsg "linked to this review" (edd.complianceReviewCid == ur)

-- ApproveCompliance must fail while the referenced EDD case is still Open.
testApproveComplianceBlockedByOpenEddCase : Script ()
testApproveComplianceBlockedByOpenEddCase = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  eddCid <- submit p.vetify do exerciseCmd ur OpenEddCase with triggerReason = "PEP_HIT"
  submitMustFail p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = Some sampleAmlEvidence
      complianceDocuments   = []
      shariahAssessment     = None
      eddCaseCid            = Some eddCid
      reviewerAuthCid       = p.reviewerAuthCid
  pure ()

-- CloseEddCase must fail while any checklist item is incomplete.
testCloseEddCaseRequiresCompleteChecklist : Script ()
testCloseEddCaseRequiresCompleteChecklist = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  eddCid <- submit p.vetify do exerciseCmd ur OpenEddCase with triggerReason = "PEP_HIT"
  -- Only partially fill the checklist.
  eddCid1 <- submit p.verifier do
    exerciseCmd eddCid UpdateEddChecklist with
      sourceOfWealthVerified  = Some True
      sourceOfWealthNote      = Some "Business income verified via bank statements"
      enhancedMediaSearchDone = None
      seniorManagementSignoff = None
      monitoringFrequency     = None
  submitMustFail p.verifier do
    exerciseCmd eddCid1 CloseEddCase with closedBy_ = "Fatima Al-Hassan"
  pure ()

-- Full workflow: open → fill checklist → close → ApproveCompliance now succeeds.
testApproveComplianceSucceedsAfterEddClosed : Script ()
testApproveComplianceSucceedsAfterEddClosed = do
  p  <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  eddCid <- submit p.vetify do exerciseCmd ur OpenEddCase with triggerReason = "PEP_HIT"
  eddCid1 <- submit p.verifier do
    exerciseCmd eddCid UpdateEddChecklist with
      sourceOfWealthVerified  = Some True
      sourceOfWealthNote      = Some "Business income verified via bank statements"
      enhancedMediaSearchDone = Some True
      seniorManagementSignoff = Some "Chief Compliance Officer — Amina Bello"
      monitoringFrequency     = Some "quarterly"
  eddCid2 <- submit p.verifier do
    exerciseCmd eddCid1 CloseEddCase with closedBy_ = "Fatima Al-Hassan"
  Some closedCase <- queryContractId p.vetify eddCid2
  assertMsg "status Closed" (closedCase.status == EddClosed)
  (_, result) <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = Some sampleAmlEvidence
      complianceDocuments   = []
      shariahAssessment     = None
      eddCaseCid            = Some eddCid2
      reviewerAuthCid       = p.reviewerAuthCid
  Some res <- queryContractId p.verifier result
  assertMsg "approved" (res.outcome == Approved)

-- An EDD case tied to a different ComplianceReview cannot gate this one's approval.
testEddCaseForWrongReviewBlocked : Script ()
testEddCaseForWrongReviewBlocked = do
  p   <- setupCParties
  rv1 <- pendingReview p
  ur1 <- submit p.vetify do exerciseCmd rv1 StartReview with policyCid = None
  eddCid <- submit p.vetify do exerciseCmd ur1 OpenEddCase with triggerReason = "PEP_HIT"
  eddCid1 <- submit p.verifier do
    exerciseCmd eddCid UpdateEddChecklist with
      sourceOfWealthVerified  = Some True
      sourceOfWealthNote      = None
      enhancedMediaSearchDone = Some True
      seniorManagementSignoff = Some "CCO"
      monitoringFrequency     = Some "quarterly"
  eddCid2 <- submit p.verifier do
    exerciseCmd eddCid1 CloseEddCase with closedBy_ = "Fatima Al-Hassan"
  -- A second, unrelated review — the closed EDD case above belongs to the FIRST review.
  rv2 <- submit p.vetify do
    createCmd ComplianceReview with
      business                = p.business
      vetify                  = p.vetify
      verifier                = p.verifier
      businessName            = sampleProfile.name
      cacRegNumber            = sampleKyc.cacRegNumber <> "-2"
      businessSector          = sampleProfile.businessSector
      businessActivity        = sampleProfile.businessActivity
      incorporationDate       = sampleProfile.incorporationDate
      verificationRef         = "VER-2026-000002"
      complianceRef           = "COM-2026-000002"
      status                  = Pending
      checks                  = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
      createdAt               = None
      reviewStartedAt         = None
      compliancePolicyVersion = None
      policySnapshot          = None
      createdBy               = None
      shariahVerdict          = None
      advisor                 = p.advisor
  ur2 <- submit p.vetify do exerciseCmd rv2 StartReview with policyCid = None
  submitMustFail p.verifier do
    exerciseCmd ur2 ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = Some sampleAmlEvidence
      complianceDocuments   = []
      shariahAssessment     = None
      eddCaseCid            = Some eddCid2
      reviewerAuthCid       = p.reviewerAuthCid
  pure ()
