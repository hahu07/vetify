      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

-- Revoke archives the ApprovedBusiness permanently.
testRevoke : Script ()
testRevoke = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low p.reviewerAuthCid
  revRecord <- submit p.vetify do
    exerciseCmd approved Revoke with
      reason    = "Fraudulent application confirmed"
      revokedBy = "Senior Compliance Officer"
  result <- queryContractId p.business approved
  assertMsg "ApprovedBusiness archived on revocation" (result == None)
  Some rr <- queryContractId p.vetify revRecord
  assertMsg "reason on RevocationRecord" (rr.reason == "Fraudulent application confirmed")
  assertMsg "cacRegNumber on RevocationRecord" (rr.cacRegNumber == "RC123456")
  pure ()

-- ─── Gap 5 (new): Periodic re-certification ──────────────────────────────────

-- RequestRecertification archives ApprovedBusiness and creates a fresh ComplianceReview.
testRecertification : Script ()
testRecertification = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low p.reviewerAuthCid
  newReview <- submit p.vetify do
    exerciseCmd approved RequestRecertification with
      verifier = p.verifier
      advisor = p.advisor
      newComplianceRef  = "COM-2026-000002"
      reason            = "Annual re-KYC/re-KYB required by CBN NIFI Framework"
  -- Old ApprovedBusiness is archived
  old <- queryContractId p.business approved
  assertMsg "Old ApprovedBusiness archived" (old == None)
  -- New ComplianceReview is pending
  Some nr <- queryContractId p.vetify newReview
  assertMsg "New review is Pending" (nr.status == Pending)
  assertMsg "complianceRef is new" (nr.complianceRef == "COM-2026-000002")
  assertMsg "verificationRef carried from original" (nr.verificationRef == "VER-2026-000001")
  pure ()

-- ─── Gap 14 (Four-Eyes Principle) ────────────────────────────────────────────

-- The person who created the review cannot be the same one who approves it.
testFourEyesApproval : Script ()
testFourEyesApproval = do
  p <- setupCParties
  t <- getTime
  -- Create the review with a named creator
  rv <- submit p.vetify do
    createCmd ComplianceReview with
      business                = p.business
      vetify                  = p.vetify
      verifier                = p.verifier
      businessName            = sampleProfile.name
      cacRegNumber            = sampleKyc.cacRegNumber
      businessSector          = sampleProfile.businessSector
      businessActivity        = sampleProfile.businessActivity
      incorporationDate       = sampleProfile.incorporationDate
      verificationRef         = "VER-2026-000001"
      complianceRef           = "COM-2026-000001"
      status                  = Pending
      checks                  = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
      createdAt               = Some t
      reviewStartedAt         = None
      compliancePolicyVersion = None
      policySnapshot          = None
      createdBy               = Some "Fatima Al-Hassan"  -- same name as reviewer below
      shariahVerdict          = None
      advisor            = p.advisor
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  -- Reviewer is the same person as creator → fails (four-eyes violation)
  submitMustFail p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Fatima Al-Hassan"
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
      eddCaseCid            = None
      reviewerAuthCid       = p.reviewerAuthCid
  -- Different reviewer → succeeds
  _ <- submit p.verifier do
    exerciseCmd ur ApproveCompliance with
      completedChecks       = passingCompliance
      riskScore             = 88
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "Amina Ibrahim"   -- different from createdBy
      agentVersion          = None
      aiMetadata            = None
      overrideJustification = None
      reviewNotes           = None
      overrideType          = None
      amlEvidence           = None
      complianceDocuments   = []
      shariahAssessment     = None
      eddCaseCid            = None
      reviewerAuthCid       = p.reviewerAuthCid
  pure ()

-- ─── Gap 15 (Role Authorization) ─────────────────────────────────────────────

-- Deauthorizing the compliance officer prevents further approvals.
testDeauthorizedReviewerBlocked : Script ()
testDeauthorizedReviewerBlocked = do
  p <- setupCParties
  -- Deauthorize the AuthorizedReviewer created by setupCParties. No contract
  -- keys on SDK 3.4.11 / Daml-LF 2.1/2.2, so there is no queryByKey/lookupByKey
  -- to resolve it — CParties already carries the ContractId from setup.
  submit p.vetify do
    exerciseCmd p.reviewerAuthCid Deauthorize with reason = "Officer resigned"
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  submitMustFail p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low p.reviewerAuthCid
  pure ()

-- ─── Gap 16 (Policy Snapshot) ────────────────────────────────────────────────

-- Full policy snapshot (not just version string) is stored on ComplianceResult.
testPolicySnapshotOnResult : Script ()
testPolicySnapshotOnResult = do
  p <- setupCParties
  t <- getTime
  policyCid <- submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v3"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = Some policyCid
  (_, result) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low p.reviewerAuthCid
  Some cr <- queryContractId p.vetify result
  case cr.policySnapshot of
    None -> assertFail "Expected policySnapshot to be captured at StartReview"
    Some snap -> do
      assertMsg "snapshot.policyVersion matches" (snap.policyVersion == "2026-v3")
      assertMsg "snapshot.autoApproveMin matches" (snap.autoApproveMin == 80)
      assertMsg "snapshot.escalationSlaHours matches" (snap.escalationSlaHours == 48)
  pure ()

-- ─── Gap 20 (Assignment Workflow) ────────────────────────────────────────────

-- AssignReview changes the verifier on a Pending review.
testAssignReview : Script ()
testAssignReview = do
  p <- setupCParties
  -- Allocate a second officer and authorize them
  officer2 <- allocateParty "Verifier2"
  t <- getTime
  submit p.vetify do
    createCmd AuthorizedReviewer with
      vetify            = p.vetify
      verifier = officer2
      authorizedBy      = "Vetify Admin"
      authorizedAt      = t
      role              = "Compliance Officer"
  rv <- pendingReview p
  -- Assign to officer2
  reassigned <- submit p.vetify do
    exerciseCmd rv AssignReview with
      newOfficer     = officer2
      assignedByName = "Head of Compliance"
  Some r <- queryContractId p.vetify reassigned
  assertMsg "verifier updated to officer2" (r.verifier == officer2)
  assertMsg "still Pending after assignment" (r.status == Pending)
  pure ()

-- ─── Gap 21 (Officer Reassignment) ───────────────────────────────────────────

-- ReassignReview changes the officer mid-review; same officer is rejected.
testReassignReview : Script ()
testReassignReview = do
  p <- setupCParties
  officer2 <- allocateParty "Verifier2"
  t <- getTime
  submit p.vetify do
    createCmd AuthorizedReviewer with
      vetify            = p.vetify
      verifier = officer2
      authorizedBy      = "Vetify Admin"
      authorizedAt      = t
      role              = "Compliance Officer"
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  -- Reassign to same officer → fails
  submitMustFail p.vetify do
    exerciseCmd ur ReassignReview with
      newOfficer = p.verifier
      reason     = "No change"
  -- Reassign to different officer → succeeds
  reassigned <- submit p.vetify do
    exerciseCmd ur ReassignReview with
      newOfficer = officer2
      reason     = "Original officer on leave"
  Some r <- queryContractId p.vetify reassigned
  assertMsg "verifier updated" (r.verifier == officer2)
  pure ()

-- ─── Gap 22 (Expiry Lifecycle) ────────────────────────────────────────────────

-- ExpireBusiness transitions Active → BusinessExpired after expiresAt.
testExpireBusiness : Script ()
testExpireBusiness = do
  p <- setupCParties
  t <- getTime
  ab <- submit p.vetify do
    createCmd ApprovedBusiness with
      business         = p.business
      vetify           = p.vetify
      businessName      = sampleProfile.name
      cacRegNumber      = sampleKyc.cacRegNumber
      businessSector    = sampleProfile.businessSector
      businessActivity  = sampleProfile.businessActivity
      incorporationDate = sampleProfile.incorporationDate
      verificationRef   = "VER-2026-000001"
      complianceRef     = "COM-2026-000001"
      approvedAt        = t
      status           = BusinessActive
      expiresAt        = Some t
      suspendedAt      = None
      suspendedReason  = None
      reinstatedAt     = None
      reinstatedReason = None
  -- Cannot expire before the deadline passes
  submitMustFail p.vetify do
    exerciseCmd ab ExpireBusiness with reason = "Annual review"
  passTime (hours 1)
  expired <- submit p.vetify do
    exerciseCmd ab ExpireBusiness with reason = "Annual approval period ended"
  Some e <- queryContractId p.vetify expired
  assertMsg "status is BusinessExpired" (e.status == BusinessExpired)
  -- Expired business cannot request financing
  submitMustFail p.business do
    exerciseCmd expired RequestFinancing with
      financialInstitution = p.fi
      assessor          = p.assessor
      terms                = sampleFinancingTerms
      financingRef         = "FIN-COMP-EXP-002"
      verificationRef      = None
      complianceRef        = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
  pure ()

