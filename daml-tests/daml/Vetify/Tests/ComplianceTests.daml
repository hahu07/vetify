-- ─── Gap 4 (new): ApprovedBusiness lifecycle ─────────────────────────────────

-- Suspended business cannot request new financing.
testSuspendPreventsFinancing : Script ()
testSuspendPreventsFinancing = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  (approved, _) <- submit p.verifier do
