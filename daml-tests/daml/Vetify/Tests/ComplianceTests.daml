  pure ()

-- ─── Gap 1 (new): SLA escalation ────────────────────────────────────────────

-- SLA window expired: EscalateOverdue moves UnderReview → ManualReview.
testEscalateOverdue : Script ()
testEscalateOverdue = do
  p <- setupCParties
  t <- getTime
  policyCid <- submit p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = t
      effectiveTo          = None
      scoringWeights       = sampleComplianceScoringWeights
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = Some policyCid
  passTime (hours 49)
  escalated <- submit p.vetify do
    exerciseCmd ur EscalateOverdue with fallbackSlaHours = 48, policyCid = Some policyCid
  Some e <- queryContractId p.vetify escalated
  assertMsg "status is ManualReview after escalation" (e.status == ManualReview)
  pure ()

-- SLA window not yet expired: EscalateOverdue is rejected.
testEscalateBeforeSlaExpiry : Script ()
testEscalateBeforeSlaExpiry = do
  p <- setupCParties
  t <- getTime
  policyCid <- submit p.vetify do
    createCmd CompliancePolicy with
