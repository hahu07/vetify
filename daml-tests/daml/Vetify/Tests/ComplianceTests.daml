-- ─── Gap 11 (Policy Effective Dates) ─────────────────────────────────────────

-- effectiveTo before effectiveFrom violates ensure → policy creation fails.
testPolicyEffectiveDateRange : Script ()
testPolicyEffectiveDateRange = do
  p <- setupCParties
  t <- getTime
  submitMustFail p.vetify do
    createCmd CompliancePolicy with
      vetify               = p.vetify
      autoApproveMin       = 80
      autoRejectMax        = 50
      escalationSlaHours   = 48
      shariahPolicyVersion = "AAOIFI-2023-Std8"
      policyVersion        = "2026-v1"
      effectiveFrom        = addRelTime t (hours 24)  -- future
      effectiveTo          = Some t                   -- past (before effectiveFrom) → invalid
      scoringWeights       = sampleComplianceScoringWeights
  pure ()

