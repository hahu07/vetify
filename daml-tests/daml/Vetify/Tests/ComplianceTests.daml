-- Reinstate restores Active status and financing access.
testSuspendReinstate : Script ()
testSuspendReinstate = do
  p <- setupCParties
  rv <- pendingReview p
  ur <- submit p.vetify do exerciseCmd rv StartReview with policyCid = None
  (approved, _) <- submit p.verifier do
    agentApproveCompliance ur passingCompliance 88 Low p.reviewerAuthCid
  suspended <- submit p.vetify do
    exerciseCmd approved Suspend with reason = "Monitoring alert"
  reinstated <- submit p.vetify do
