-- Script helper: creates a FinancingProviderOnboarding, submits it, and has
-- Vetify approve it with Murabahah + Ijarah instruments. Returns the
-- ContractId ApprovedProvider for use in ApproveFunding calls.
setupApprovedProvider : Party -> Party -> Script (ContractId ApprovedProvider)
setupApprovedProvider fi vetifyP = do
  onbCid <- submit fi do
    createCmd FinancingProviderOnboarding with
      financialInstitution = fi
      vetify               = vetifyP
      providerName         = "Wema Islamic Finance Ltd"
      address              = "22 Marina, Lagos Island, Lagos"
      cacRegNumber         = "RC1234567"
      providerType         = CBNLicensedNIFI
      regulatoryBody       = Some CBN
      licenseNumber        = Some "NIFI-2024-001"
      governingDocRef      = sampleGoverningDocRef
      declaredInstruments  = [Murabahah, Ijarah, QardHasan]
      status               = Draft
      submittedAt          = None
      amendmentCount       = 0
      agentScore           = None
      agentRisk            = None
      agentNote            = None
      agentVersion         = None
  submitted <- submit fi do
    exerciseCmd onbCid SubmitProviderForReview
  submit vetifyP do
    exerciseCmd submitted ApproveProvider with
      approvedInstruments = [Murabahah, Ijarah]
      regulator           = None
