-- F35: offerExpiresAt in the past is rejected by ApproveFunding.
testOfferExpiryInPastRejected : Script ()
testOfferExpiryInPastRejected = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Fatima Usman"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  t <- getTime
  -- Advance time so that a previously-computed expiry is now in the past
  passTime (hours 1)
  submitMustFail p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Fatima Usman"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = Some t  -- t is now in the past
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  pure ()

-- F34: AcceptAmendment is blocked once the amendment cap is reached.
-- We simulate a request already at the cap rather than cycling 10 times.
testAmendmentCapEnforced : Script ()
testAmendmentCapEnforced = do
  p <- setupFParties
  -- Create a request already at the cap
  cappedReq <- submit p.business do
    createCmd FinancingRequest with
      business             = p.business
      vetify               = p.vetify
      assessor          = p.assessor
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      status               = Submitted
      financingRef         = "FIN-TEST-CAP-001"
      verificationRef      = None
      complianceRef        = None
      submittedAt          = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 10  -- already at the cap
      assignedAssessorId   = None
      assignedAssessorName = None
      assignedAt              = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
  amendCid <- submit p.fi do
    exerciseCmd cappedReq ProposeAmendment with
      proposedTerms = sampleFinancingTerms with amount = 1_200_000.0
      proposalNote  = None
  -- AcceptAmendment must fail because amendmentCount == 10
  submitMustFail p.business do
    exerciseCmd amendCid AcceptAmendment with requestCid = cappedReq
  pure ()

-- ─── U1: Underwriting expiry blocks ApproveFunding ───────────────────────────

-- ApproveFunding fails after the underwriting SLA has elapsed (policy-backed expiry)
testExpiredUnderwritingBlocksApproval : Script ()
testExpiredUnderwritingBlocksApproval = do
  p     <- setupFPartiesWithPolicy  -- 1-hour SLA policy
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Aisha Yusuf"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req   -- expiresAt = now + 1h
  passTime (hours 2)                         -- advance past SLA
  submitMustFail p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aisha Yusuf"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  pure ()

-- ─── U2: AI governance record on funding decision ────────────────────────────

-- FI records AI alignment after approval; governance contract visible to vetify
testAIGovernanceRecord : Script ()
testAIGovernanceRecord = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Usman Bello"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  (_, decisionCid) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Usman Bello"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = Some "DSCR_ADEQUATE"
      decisionFactors     = ["DSCR: 1.8", "Sector: Low Risk", "Credit history: Clean"]
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  govCid <- submit p.fi do
    exerciseCmd decisionCid RecordGovernanceAssessment with
      aiRecommendationFollowed = True
      governanceNote           = Some "AI score 82 — Low risk auto-approve threshold met; FI concurs"
      assessedBy               = "Usman Bello"
  Some gov <- queryContractId p.vetify govCid
  assertMsg "AI recommendation followed recorded" gov.aiRecommendationFollowed
  assertMsg "Financing ref matches" (gov.financingRef == "FIN-TEST-001")
  assertMsg "Decision outcome is approved" (gov.decisionOutcome == FinancingApproved)
  Some _ <- queryContractId p.business govCid
  pure ()

