        storageRef         = "s3://vetify-docs/RC123456/financials-2025.pdf"
        mimeType           = Some "application/pdf"
        malwareScanStatus  = Some "CLEAN"
        fileSize           = Some 512000
        checksumAlgorithm  = Some "sha256"
        malwareScanAt      = None
        digitalSignature   = None
        signatureAlgorithm = None
        signatoryRef       = None
        signedAt           = None
  req <- submit p.business do
    createCmd FinancingRequest with
      business             = p.business
      vetify               = p.vetify
      assessor          = p.assessor
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      status               = Submitted
      financingRef         = "FIN-TEST-DOCS-001"
      verificationRef      = None
      complianceRef        = None
      submittedAt          = None
      supportingDocuments  = [financialStatement, sampleDocRef]
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 0
      assignedAssessorId   = None
      assignedAssessorName = None
      assignedAt              = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
  Some r <- queryContractId p.business req
  assertMsg "two supporting documents" (r.supportingDocuments == [financialStatement, sampleDocRef])

-- F15: Rejection carries structured reason code and decision factors.
testRejectionExplainability : Script ()
testRejectionExplainability = do
  p   <- setupFParties
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  decisionCid <- submit p.fi do
    exerciseCmd updated RejectFunding with
      reason            = "DSCR below minimum policy threshold of 1.2"
      rejectedByName    = Some "Aminu Bello"
      reasonCode        = Some "DSCR_BELOW_THRESHOLD"
      decisionFactors   = ["DSCR: 0.9 (min: 1.2)", "Leverage: High", "Sector: Medium Risk"]
      decisionDocuments = []
  Some d <- queryContractId p.fi decisionCid
  assertMsg "reasonCode" (d.reasonCode == Some "DSCR_BELOW_THRESHOLD")
  assertMsg "decisionFactors count" (d.decisionFactors == ["DSCR: 0.9 (min: 1.2)", "Leverage: High", "Sector: Medium Risk"])
  assertMsg "decidedByName" (d.decidedByName == Some "Aminu Bello")

-- F20: financingRef is carried into the MurabahahWad.
testFinancingRefCarriedToWad : Script ()
testFinancingRefCarriedToWad = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Fatima Usman"
  req <- submit p.business do
    createCmd FinancingRequest with
      business             = p.business
      vetify               = p.vetify
      assessor          = p.assessor
      financialInstitution = p.fi
      businessName         = sampleProfile.name
      cacRegNumber         = sampleKyc.cacRegNumber
      terms                = sampleFinancingTerms
      status               = Submitted
      financingRef         = "FIN-2026-RC123456-001"
      verificationRef      = None
      complianceRef        = None
      submittedAt          = None
      supportingDocuments  = []
      businessSector       = "Food Retail"
      incorporationDate    = sampleProfile.incorporationDate
      expiresAt            = None
      termHistory          = []
      amendmentCount       = 0
      assignedAssessorId   = None
      assignedAssessorName = None
      assignedAt              = None
      agentScore              = None
      agentRisk               = None
      agentNote               = None
      agentVersion            = None
  (updated, _) <- beginUnderwriting p req
  (wadCid, _) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Fatima Usman"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  Some wad <- queryContractId p.fi wadCid
  assertMsg "financingRef propagated to MurabahahWad"
    (wad.financingRef == Some "FIN-2026-RC123456-001")

-- F16: UnderwritingPolicy snapshot is captured on UnderwritingResult when a policy exists.
testPolicySnapshotCaptured : Script ()
testPolicySnapshotCaptured = do
  p   <- setupFPartiesWithPolicy
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  Some ur <- queryContractId p.vetify urCid
  assertMsg "policySnapshot present when policy exists" (ur.policySnapshot /= None)
  case ur.policySnapshot of
    None -> assertFail "policySnapshot should be present"
    Some ps -> do
      assertMsg "policyVersion" (ps.policyVersion == "2026-v1")
      assertMsg "autoApproveMin" (ps.autoApproveMin == 80)
      assertMsg "autoRejectMax" (ps.autoRejectMax == 50)
      assertMsg "offerValidityDays" (ps.offerValidityDays == 30)

-- F16: UpdatePolicy replaces the active policy with a new version.
testUpdatePolicy : Script ()
testUpdatePolicy = do
  p <- setupFPartiesWithPolicy
  let Some policyCid = p.policyCid  -- set by setupFPartiesWithPolicy
  t <- getTime
  newPolicyCid <- submit p.vetify do
    exerciseCmd policyCid UpdatePolicy with
      newPolicyVersion     = "2026-v2"
      newAutoApproveMin    = 85
      newAutoRejectMax     = 55
      newMinDscrRatio      = Some 1.3
      newMinLoanAmount     = Some 200_000.0
      newMaxLoanAmount     = Some 100_000_000.0
      newIndicativeProfitMarginPct = Some 12.0
      newRequestSlaHours   = 48
      newOfferValidityDays = 14
      newEffectiveFrom     = t
      newScoringWeights    = sampleUnderwritingScoringWeights
  Some np <- queryContractId p.vetify newPolicyCid
  assertMsg "new version" (np.policyVersion == "2026-v2")
  assertMsg "new autoApproveMin" (np.autoApproveMin == 85)
  policies <- query @UnderwritingPolicy p.vetify
  assertMsg "exactly one active policy after update" (length policies == 1)

-- F17: a FinancingRequest can be found by its (business, financingRef) reference.
-- FinancingRequest no longer carries a contract key (SDK 3.4.11 / Daml-LF
-- 2.1/2.2 does not support contract keys), so this is now a plain `query` +
-- filter on financingRef rather than ledger-enforced key resolution — the
-- test's intent (the reference genuinely identifies the request) is
-- preserved, just without the ledger-side uniqueness guarantee a key used to
-- give.
testContractKeyLookup : Script ()
testContractKeyLookup = do
  p   <- setupFParties
  _   <- submittedRequest p
  reqs <- query @FinancingRequest p.business
  let found = [cid | (cid, r) <- reqs, r.financingRef == "FIN-TEST-001"]
  assertMsg "contract found by financingRef" (not (null found))

-- F18: BeginUnderwriting sets expiresAt from policy SLA; ExpireRequest succeeds after expiry.
testExpireRequest : Script ()
testExpireRequest = do
  p   <- setupFPartiesWithPolicy
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  Some r <- queryContractId p.business updated
  assertMsg "expiresAt set after BeginUnderwriting" (r.expiresAt /= None)
  -- Advance time past the 1-hour SLA configured in setupFPartiesWithPolicy
  passTime (hours 2)
  closureCid <- submit p.vetify do
    exerciseCmd updated ExpireRequest with reason = "SLA elapsed — no FI response"
  Some closure <- queryContractId p.vetify closureCid
  assertMsg "outcome is Expired" (closure.outcome == Expired)
  assertMsg "financingRef on closure" (closure.financingRef == "FIN-TEST-001")
  reqs <- query @FinancingRequest p.business
  assertMsg "request archived after expiry" (null reqs)

-- F18: ExpireRequest fails if the SLA has not yet elapsed.
testExpireRequestTooEarly : Script ()
testExpireRequestTooEarly = do
  p   <- setupFPartiesWithPolicy
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  -- Do NOT advance time — SLA has not elapsed
  submitMustFail p.vetify do
    exerciseCmd updated ExpireRequest with reason = "Premature expiry attempt"
  pure ()

-- F18: CancelRequest archives the request and creates a RequestClosureRecord.
testCancelRequest : Script ()
testCancelRequest = do
  p      <- setupFParties
  req    <- submittedRequest p
  closureCid <- submit p.vetify do
    exerciseCmd req CancelRequest with reason = "Business insolvency event"
  Some closure <- queryContractId p.vetify closureCid
  assertMsg "outcome is Cancelled" (closure.outcome == Cancelled)
  assertMsg "reason" (closure.reason == "Business insolvency event")
  assertMsg "financingRef" (closure.financingRef == "FIN-TEST-001")
  reqs <- query @FinancingRequest p.business
  assertMsg "request archived after cancellation" (null reqs)

-- F19: offerExpiresAt is stored on the MurabahahWad when the FI provides it.
testOfferExpiresAtOnWad : Script ()
testOfferExpiresAtOnWad = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Fatima Usman"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  t <- getTime
  let expiry = addRelTime t (days 30)
  (wadCid, _) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Fatima Usman"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = Some expiry
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  Some wad <- queryContractId p.fi wadCid
  assertMsg "offerExpiresAt stored on Wad" (wad.offerExpiresAt == Some expiry)

-- F21: IssueCorrection creates an UnderwritingCorrection linked to the original result.
testIssueCorrection : Script ()
testIssueCorrection = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, urCid) <- beginUnderwriting p req
  let correctedAssessment = RiskAssessment with
        score            = 72
        riskCategory     = Medium
        recommendedLimit = 1_800_000.0
        recommendation   = "Corrected: data entry error in DSCR calculation"
        probabilityOfDefault = None
        lossGivenDefault      = None
        exposureAtDefault     = None
        behaviouralScore      = None
        cashflowRiskScore     = None
        creditworthinessScore = None
        fraudScore            = None
  corrCid <- submit p.vetify do
    exerciseCmd urCid IssueCorrection with
      correctedAssessment
      correctionRef    = "CORR-2026-001"
      correctedOutcome = "APPROVED_WITH_CONDITION"
      reason           = "DSCR numerator entered incorrectly; correct DSCR is 1.44"
      correctedBy      = "vetify-underwriting-supervisor"
  Some corr <- queryContractId p.vetify corrCid
  assertMsg "financingRef" (corr.financingRef == "FIN-TEST-001")
  assertMsg "correctionRef" (corr.correctionRef == "CORR-2026-001")
  assertMsg "correctedAssessment.riskCategory" (corr.correctedAssessment.riskCategory == Medium)
  assertMsg "originalAssessment preserved" (corr.originalAssessment.riskCategory == Low)
  assertMsg "previousAutoDecided" corr.previousAutoDecided
  -- Original UnderwritingResult is preserved (nonconsuming)
  Some _ <- queryContractId p.vetify urCid
  pure ()

-- F22: approvalSignature is stored on FinancingDecision.
testApprovalSignatureOnDecision : Script ()
testApprovalSignatureOnDecision = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  (officerId, officerCid) <- createCreditOfficer p "Aminu Bello"
  req   <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  let sig = ApprovalSignature with
        digitalSignature = "MEQCIBx...base64encoded...signature"
        certificateId    = "CERT-FI-AMINU-2026-001"
        signedAt         = None
        signedByName     = "Aminu Bello"
  (_, decisionCid) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Aminu Bello"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = Some sig
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  Some d <- queryContractId p.fi decisionCid
  case d.approvalSignature of
    None -> assertFail "approvalSignature should be present"
    Some s -> do
      assertMsg "certificateId" (s.certificateId == "CERT-FI-AMINU-2026-001")
      assertMsg "signedByName" (s.signedByName == "Aminu Bello")

-- F23: decisionDocuments are stored on UnderwritingResult.
testDecisionDocuments : Script ()
testDecisionDocuments = do
  p   <- setupFParties
  req <- submittedRequest p
  let creditReport = DocumentRef with
        docType            = "CREDIT_BUREAU_REPORT"
        contentHash        = "sha256:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890"
        storageRef         = "s3://vetify-docs/RC123456/credit-report.pdf"
        mimeType           = Some "application/pdf"
        malwareScanStatus  = Some "CLEAN"
        fileSize           = Some 204800
        checksumAlgorithm  = Some "sha256"
        malwareScanAt      = None
        digitalSignature   = None
        signatureAlgorithm = None
        signatoryRef       = None
        signedAt           = None
  (_, urCid) <- submit (actAs [p.assessor, p.vetify]) do
    exerciseCmd req BeginUnderwriting with
      assessment        = sampleAssessment
      autoDecided       = True
      aiMetadata        = Some sampleAIMetadata
      agentVersion      = Some "vetify-underwriting-v1.0"
      assessorName   = Some "vetify-underwriting"
      underwritingRef   = Some "trace-2026-uw-0001"
      decisionDocuments = [creditReport]
      assessorCid       = p.assessorCid
      policyCid         = p.policyCid
  Some ur <- queryContractId p.vetify urCid
  assertMsg "decisionDocuments on UnderwritingResult" (length ur.decisionDocuments == 1)
  case ur.decisionDocuments of
    doc :: _ -> assertMsg "doc type" (doc.docType == "CREDIT_BUREAU_REPORT")
    []       -> assertFail "expected at least one decision document"

-- F24: FI proposes amendment; business accepts; terms and history updated.
testAmendmentAccepted : Script ()
testAmendmentAccepted = do
  p   <- setupFParties
  req <- submittedRequest p
  amendCid <- submit p.fi do
    exerciseCmd req ProposeAmendment with
      proposedTerms = sampleFinancingTerms with amount = 1_500_000.0, tenureMonths = 18
      proposalNote  = Some "Revised down based on DSCR analysis"
  Some amend <- queryContractId p.fi amendCid
  assertMsg "originalTerms preserved" (amend.originalTerms.amount == sampleFinancingTerms.amount)
  assertMsg "proposedTerms" (amend.proposedTerms.amount == 1_500_000.0)
  -- Business accepts the amendment
  newReqCid <- submit p.business do
    exerciseCmd amendCid AcceptAmendment with requestCid = req
  Some newReq <- queryContractId p.business newReqCid
  assertMsg "terms updated" (newReq.terms.amount == 1_500_000.0)
  assertMsg "termHistory has original terms" (length newReq.termHistory == 1)
  case newReq.termHistory of
    orig :: _ -> assertMsg "original amount in history" (orig.amount == sampleFinancingTerms.amount)
    []        -> assertFail "expected term history entry"
  assertMsg "amendmentCount incremented" (newReq.amendmentCount == 1)
  assertMsg "status reset to Submitted" (newReq.status == Submitted)
  assertMsg "expiresAt cleared" (newReq.expiresAt == None)

-- F24: Business declines amendment; original request untouched.
testAmendmentDeclined : Script ()
testAmendmentDeclined = do
  p   <- setupFParties
  req <- submittedRequest p
  amendCid <- submit p.fi do
    exerciseCmd req ProposeAmendment with
      proposedTerms = sampleFinancingTerms with amount = 800_000.0
      proposalNote  = None
  submit p.business do
    exerciseCmd amendCid DeclineAmendment with reason = "Amount too low for project scope"
  -- Original request still active and unchanged
  Some r <- queryContractId p.business req
  assertMsg "original terms unchanged" (r.terms.amount == sampleFinancingTerms.amount)
  assertMsg "amendmentCount still 0" (r.amendmentCount == 0)

-- ─── Gap F9: assessor assignment workflow ─────────────────────────────────

-- AssignAssessor records the assigned officer for task-management/SLA tracking.
testAssignAssessor : Script ()
testAssignAssessor = do
  p   <- setupFParties
  req <- submittedRequest p
  (officerId, officerCid) <- createUnderwritingOfficer p "Ngozi Adeyemi"
  assigned <- submit p.fi do
    exerciseCmd req AssignAssessor with
      assignedOfficerId = officerId
      officerCid        = officerCid
      assignedByName    = "vetify-ops"
  Some r <- queryContractId p.fi assigned
  assertMsg "assignedAssessorId recorded" (r.assignedAssessorId == Some officerId)
  assertMsg "assignedAssessorName recorded" (r.assignedAssessorName == Some "Ngozi Adeyemi")
  assertMsg "assignedAt recorded" (r.assignedAt /= None)

-- AssignAssessor must fail when the officer is not a registered UnderwritingOfficer.
-- No ContractId can be constructed for a truly nonexistent registry entry
-- (SDK 3.4.11 / Daml-LF 2.1/2.2 has no lookupByKey), so a real, differently-
-- scoped officer's ContractId is supplied instead — the officerId mismatch
-- still trips requireActiveOfficer's identity-match assertion.
testAssignAssessorUnregisteredOfficerBlocked : Script ()
testAssignAssessorUnregisteredOfficerBlocked = do
  p   <- setupFParties
  req <- submittedRequest p
  (_, decoyOfficerCid) <- createUnderwritingOfficer p "Decoy Officer"
  submitMustFail p.fi do
    exerciseCmd req AssignAssessor with
      assignedOfficerId = "UO-Ghost Officer"
      officerCid        = decoyOfficerCid
      assignedByName    = "vetify-ops"
  pure ()

-- AssignAssessor must fail when the registered officer holds the wrong role.
testAssignAssessorWrongRoleBlocked : Script ()
testAssignAssessorWrongRoleBlocked = do
  p   <- setupFParties
  req <- submittedRequest p
  (officerId, officerCid) <- createCreditOfficer p "Credit Officer Not Assessor 2"  -- CreditOfficer, not UnderwritingOfficer
  submitMustFail p.fi do
    exerciseCmd req AssignAssessor with
      assignedOfficerId = officerId
      officerCid        = officerCid
      assignedByName    = "vetify-ops"
  pure ()

-- AssignAssessor can be called again after BeginUnderwriting (status Underwriting).
testAssignAssessorAfterBeginUnderwriting : Script ()
testAssignAssessorAfterBeginUnderwriting = do
  p   <- setupFParties
  req <- submittedRequest p
  (updated, _) <- beginUnderwriting p req
  (officerId, officerCid) <- createUnderwritingOfficer p "Ngozi Adeyemi 2"
  assigned <- submit p.fi do
    exerciseCmd updated AssignAssessor with
      assignedOfficerId = officerId
      officerCid        = officerCid
      assignedByName    = "vetify-ops"
  Some r <- queryContractId p.fi assigned
  assertMsg "assignedAssessorId recorded" (r.assignedAssessorId == Some officerId)

-- F27: score outside 0–100 is rejected.
testInvalidScoreRejected : Script ()
testInvalidScoreRejected = do
  p   <- setupFParties
  req <- submittedRequest p
  submitMustFail (actAs [p.assessor, p.vetify]) do
    exerciseCmd req BeginUnderwriting with
      assessment        = sampleAssessment with score = 101
      autoDecided       = True
      aiMetadata        = None
      agentVersion      = None
      assessorName   = None
      underwritingRef   = None
      decisionDocuments = []
      assessorCid       = p.assessorCid
      policyCid         = p.policyCid
  pure ()

-- F26 + F28: policy effective-date validation and loan amount enforcement.
testPolicyGuardsEnforced : Script ()
testPolicyGuardsEnforced = do
  p <- setupFParties
  t <- getTime
  -- Create a policy with maxLoanAmount = ₦1,000,000 (below sample request of ₦2,000,000)
  policyCid <- submit p.vetify do
    createCmd UnderwritingPolicy with
      vetify               = p.vetify
      financialInstitution = p.fi
      policyVersion        = "2026-tight"
      autoApproveMin       = 80
      autoRejectMax        = 50
      minDscrRatio         = Some 1.2
      maxLoanAmount        = Some 1_000_000.0  -- below sampleFinancingTerms.amount (2,000,000)
      minLoanAmount        = None
      indicativeProfitMarginPct    = None
      requestSlaHours      = 48
      offerValidityDays    = 30
      effectiveFrom        = t
      effectiveTo          = None
      writeOffThresholdAmount      = None
      maxRestructuringsPerFacility = None
      permittedSectors             = None
      requiredCollateralTypes      = []
      maxSectorConcentrationPct    = None
      scoringWeights               = sampleUnderwritingScoringWeights
  req <- submittedRequest p  -- terms.amount = 2,000,000
  -- BeginUnderwriting must fail because amount exceeds maxLoanAmount
  submitMustFail (actAs [p.assessor, p.vetify]) do
    exerciseCmd req BeginUnderwriting with
      assessment        = sampleAssessment
      autoDecided       = True
      aiMetadata        = None
      agentVersion      = None
      assessorName   = None
      underwritingRef   = None
      decisionDocuments = []
      assessorCid       = p.assessorCid
      policyCid         = Some policyCid
  pure ()

