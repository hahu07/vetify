-- Gap 4: an officer holding multiple roles can act in either capacity.
testOfficerWithMultipleRolesCanActInEitherCapacity : Script ()
testOfficerWithMultipleRolesCanActInEitherCapacity = do
  p     <- setupFParties
  apCid <- createApprovedFI p
  t <- getTime
  let officerId = "CO-Dual Role Officer"
  officerCid <- submit p.fi do
    createCmd AuthorizedOfficer with
      financialInstitution = p.fi
      vetify                = p.vetify
      officerId
      officerName           = "Dual Role Officer"
      roles                 = [CreditOfficer, UnderwritingOfficer]
      authorizedBy          = "FI Head of Credit"
      authorizedAt          = t
      active                = True
      approvalLimit         = None
      validUntil            = None
      lastUpdatedBy         = None
      lastUpdatedAt         = None
      statusReason          = None
      department            = None
      branch                = None
      employeeId            = None
      email                 = None
  req   <- submittedRequest p
  (updated, urCid) <- beginUnderwriting p req
  -- Acts as CreditOfficer for ApproveFunding
  (wad, _) <- submit p.fi do
    exerciseCmd updated ApproveFunding with
      approvedProviderCid = apCid
      assetDetails        = sampleAssetDetails
      approvedByName      = Some "Dual Role Officer"
      assessorName     = Some "vetify-underwriting"
      reasonCode          = None
      decisionFactors     = []
      approvalSignature   = None
      decisionDocuments   = []
      offerExpiresAt      = None
      approvingOfficerId  = officerId
      approvingOfficerCid = officerCid
  Some _ <- queryContractId p.fi wad
  -- Same officer also acts as UnderwritingOfficer for OverrideUnderwriting
  let overriddenAssessment = RiskAssessment with
        score            = 65
        riskCategory     = Medium
        recommendedLimit = 1_500_000.0
        recommendation   = "Manual review"
        probabilityOfDefault = None
        lossGivenDefault      = None
        exposureAtDefault     = None
        behaviouralScore      = None
        cashflowRiskScore     = None
        creditworthinessScore = None
        fraudScore            = None
  overriddenCid <- submit p.fi do
    exerciseCmd urCid OverrideUnderwriting with
      overriddenAssessment
      justification       = "Testing dual-role officer"
      overriddenByName    = "Dual Role Officer"
      overrideType        = OverrodeApproval
      overridingOfficerId = officerId
      overridingOfficerCid = officerCid
  Some _ <- queryContractId p.fi overriddenCid
  pure ()

