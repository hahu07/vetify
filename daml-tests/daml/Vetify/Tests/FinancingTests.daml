-- ─── Governance review fixes: officer lifecycle (Gaps 3, 4, 5, 9) ────────────

-- Gap 3: Deactivate/Reactivate persist who/when/why, not just discard the reason.
testOfficerDeactivateRecordsAuditTrail : Script ()
testOfficerDeactivateRecordsAuditTrail = do
  p <- setupFParties
  (officerId, officerCid) <- createCreditOfficer p "Audited Officer"
  deactivatedCid <- submit p.fi do
    exerciseCmd officerCid DeactivateOfficer with
      reason      = "Under investigation"
      performedBy = "FI Compliance Lead"
  Some o <- queryContractId p.fi deactivatedCid
  assertMsg "active is False" (not o.active)
  assertMsg "lastUpdatedBy recorded" (o.lastUpdatedBy == Some "FI Compliance Lead")
  assertMsg "statusReason recorded" (o.statusReason == Some "Under investigation")
  assertMsg "lastUpdatedAt recorded" (o.lastUpdatedAt /= None)
  reactivatedCid <- submit p.fi do
    exerciseCmd deactivatedCid ReactivateOfficer with
      reason      = "Cleared of wrongdoing"
      performedBy = "FI Compliance Lead"
  Some r <- queryContractId p.fi reactivatedCid
  assertMsg "active is True again" r.active
  assertMsg "statusReason updated" (r.statusReason == Some "Cleared of wrongdoing")

-- Gap 9: cannot deactivate an already-inactive officer.
testCannotDeactivateAlreadyInactiveOfficer : Script ()
testCannotDeactivateAlreadyInactiveOfficer = do
  p <- setupFParties
  (officerId, officerCid) <- createCreditOfficer p "Double Deactivate Officer"
  deactivatedCid <- submit p.fi do
    exerciseCmd officerCid DeactivateOfficer with
      reason = "First deactivation"; performedBy = "FI Compliance"
  submitMustFail p.fi do
    exerciseCmd deactivatedCid DeactivateOfficer with
      reason = "Second deactivation"; performedBy = "FI Compliance"
  pure ()

