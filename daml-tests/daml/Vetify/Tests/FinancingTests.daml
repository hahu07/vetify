-- ── Assessor party: hard veto, manual review, and registry gating ─────────

-- RejectUnderwriting is a hard veto — the business never reaches FinancingApproved
-- or even ApproveFunding; the request is archived and an UnderwritingRejection
-- is the only downstream record, mirroring RejectCompliance's screening authority.
testRejectUnderwritingIsHardVeto : Script ()
testRejectUnderwritingIsHardVeto = do
  p   <- setupFParties
  req <- submittedRequest p
  rejection <- submit (actAs [p.assessor, p.vetify]) do
    exerciseCmd req RejectUnderwriting with
      reason        = "Composite risk score 35/100 falls in the High-risk band."
      autoDecided   = True
      reviewerParty = None
      reviewedBy    = None
      assessment    = Some (sampleAssessment with score = 35; riskCategory = High)
      assessorCid   = p.assessorCid
  Some rj <- queryContractId p.assessor rejection
  assertMsg "reason recorded" (rj.reason == "Composite risk score 35/100 falls in the High-risk band.")
  assertMsg "financialInstitution observes the rejection" (rj.financialInstitution == p.fi)
  -- The original FinancingRequest is gone — never reaches ApproveFunding/RejectFunding.
  None <- queryContractId p.business req
  pure ()

-- Mirrors testBeginUnderwritingRejectsAutoDecidedHighRisk's guard on the
-- opposite side: an auto-decided rejection must be backed by a High-risk
-- assessment — a Low-risk assessment can't justify an unreviewed auto-reject.
testRejectUnderwritingRequiresHighRiskWhenAutoDecided : Script ()
testRejectUnderwritingRequiresHighRiskWhenAutoDecided = do
  p   <- setupFParties
  req <- submittedRequest p
  submitMustFail (actAs [p.assessor, p.vetify]) do
    exerciseCmd req RejectUnderwriting with
      reason        = "Should be blocked: Low-risk assessment cannot justify an auto-reject"
      autoDecided   = True
      reviewerParty = None
      reviewedBy    = None
      assessment    = Some sampleAssessment  -- score 82, riskCategory Low
      assessorCid   = p.assessorCid

-- A human decision (autoDecided = False) may still reject on qualitative
-- grounds even when the attached assessment is Low-risk — the guard above
-- only constrains the auto-decided path.
testRejectUnderwritingAllowsHumanOverrideOnLowRiskAssessment : Script ()
testRejectUnderwritingAllowsHumanOverrideOnLowRiskAssessment = do
  p   <- setupFParties
  req <- submittedRequest p
  rejection <- submit (actAs [p.assessor, p.vetify]) do
    exerciseCmd req RejectUnderwriting with
      reason        = "Undisclosed related-party transaction discovered during manual review"
      autoDecided   = False
      reviewerParty = Some p.assessor
      reviewedBy    = Some "Senior Assessor"
      assessment    = Some sampleAssessment  -- score 82, riskCategory Low — human overrides anyway
      assessorCid   = p.assessorCid
  Some rj <- queryContractId p.assessor rejection
  assertMsg "human override reason recorded" (rj.autoDecided == False)

-- FlagUnderwritingForManualReview moves the request to UnderwritingManualReview;
-- BeginUnderwriting can then succeed from that status (the human-approved-after-flag
-- path), mirroring Onboarding.Approve accepting UnderReview or ManualReview.
testFlagUnderwritingThenBeginUnderwritingSucceeds : Script ()
testFlagUnderwritingThenBeginUnderwritingSucceeds = do
  p   <- setupFPartiesWithPolicy  -- autoApproveMin 80, autoRejectMax 50
  req <- submittedRequest p
  flagged <- submit p.vetify do
    exerciseCmd req FlagUnderwritingForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-underwriting-v1.0"
      note         = "Composite score 65/100 falls in the Medium band."
      policyCid    = p.policyCid
  Some fr <- queryContractId p.vetify flagged
  assertMsg "status is UnderwritingManualReview" (fr.status == UnderwritingManualReview)
  assertMsg "agentScore recorded" (fr.agentScore == Some 65)
  (updated, _) <- submit (actAs [p.assessor, p.vetify]) do
    exerciseCmd flagged BeginUnderwriting with
      assessment        = sampleAssessment
      autoDecided       = False
      aiMetadata        = None
      agentVersion      = Some "vetify-underwriting-v1.0"
      assessorName   = Some "Underwriting Officer"
      underwritingRef   = None
      decisionDocuments = []
      assessorCid       = p.assessorCid
      policyCid         = p.policyCid
  Some ur <- queryContractId p.business updated
  assertMsg "status is Underwriting" (ur.status == Underwriting)

-- Neither BeginUnderwriting nor RejectUnderwriting can be exercised without a
-- registered, active AuthorizedAssessor — mirrors ApproveCompliance/
-- RejectCompliance's AuthorizedReviewer gate. No ContractId can be
-- constructed for a truly nonexistent registry entry (SDK 3.4.11 / Daml-LF
-- 2.1/2.2 has no lookupByKey), so a real AuthorizedAssessor registered for a
-- *different* assessor party is supplied instead — requireActiveAssessor's
-- "does not match party" assertion still correctly rejects the unregistered
-- `unregisteredUw`.
testBeginUnderwritingBlockedWithoutRegisteredAssessor : Script ()
testBeginUnderwritingBlockedWithoutRegisteredAssessor = do
  business       <- allocateParty "Business2"
  vetify         <- allocateParty "Vetify2"
  unregisteredUw <- allocateParty "UnregisteredAssessor"
  registeredUw   <- allocateParty "RegisteredButDifferentAssessor"
  fi             <- allocateParty "FI2"
  t <- getTime
  otherAssessorCid <- submit vetify do
    createCmd AuthorizedAssessor with
      vetify
      assessor     = registeredUw
      role         = "Senior Assessor"
      authorizedBy = "Vetify Head of Risk"
      authorizedAt = t
      active       = True
  let p = FParties with
        business
        vetify
        assessor    = unregisteredUw
        fi
        regulator   = fi
        assessorCid = otherAssessorCid
        policyCid   = None
  req <- submittedRequest p
  submitMustFail (actAs [p.assessor, p.vetify]) do
    exerciseCmd req BeginUnderwriting with
      assessment        = sampleAssessment
      autoDecided       = True
      aiMetadata        = Some sampleAIMetadata
      agentVersion      = Some "vetify-underwriting-v1.0"
      assessorName   = Some "vetify-underwriting"
      underwritingRef   = None
      decisionDocuments = []
      assessorCid       = p.assessorCid
      policyCid         = p.policyCid
  submitMustFail (actAs [p.assessor, p.vetify]) do
    exerciseCmd req RejectUnderwriting with
      reason        = "High risk"
      autoDecided   = True
      reviewerParty = None
      reviewedBy    = None
      assessment    = None
      assessorCid   = p.assessorCid
