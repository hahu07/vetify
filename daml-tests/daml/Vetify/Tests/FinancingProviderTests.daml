-- | Stage 0 tests: financing provider self-registration, instrument gating,
--   amendment flow, and rejection.
module Vetify.Tests.FinancingProviderTests where

import Daml.Script
import Vetify.Types
import Vetify.FinancingProvider
import Vetify.Tests.Fixtures

data FPParties = FPParties with
  fi        : Party
  vetify    : Party
  regulator : Party

setupFPParties : Script FPParties
setupFPParties = do
  fi        <- allocateParty "FI"
  vetify    <- allocateParty "Vetify"
  regulator <- allocateParty "Regulator"
  pure FPParties with ..

-- Base helper: creates a Draft FinancingProviderOnboarding.
draftOnboarding : FPParties -> [FinancingInstrument] -> Script (ContractId FinancingProviderOnboarding)
draftOnboarding p instruments = submit p.fi do
  createCmd FinancingProviderOnboarding with
    financialInstitution = p.fi
    vetify               = p.vetify
    providerName         = "Wema Islamic Finance Ltd"
    address              = "22 Marina, Lagos Island, Lagos"
    cacRegNumber         = "RC1234567"
    providerType         = CBNLicensedNIFI
    regulatoryBody       = Some CBN
    licenseNumber        = Some "NIFI-2024-001"
    governingDocRef      = sampleGoverningDocRef
    declaredInstruments  = instruments
    status               = Draft
    submittedAt          = None
    amendmentCount       = 0
    agentScore           = None
    agentRisk            = None
    agentNote            = None
    agentVersion         = None

-- Happy path: Draft → UnderReview → ApprovedProvider with approved instruments.
testHappyPathApproval : Script ()
testHappyPathApproval = do
  p    <- setupFPParties
  onb  <- draftOnboarding p [Murabahah, Ijarah, QardHasan]
  submitted <- submit p.fi do
    exerciseCmd onb SubmitProviderForReview
  Some s <- queryContractId p.vetify submitted
  assertMsg "status is UnderReview" (s.status == UnderReview)
  assertMsg "submittedAt is set" (s.submittedAt /= None)
  apCid <- submit p.vetify do
    exerciseCmd submitted ApproveProvider with
      approvedInstruments = [Murabahah, Ijarah]
      regulator           = Some p.regulator
  Some ap <- queryContractId p.fi apCid
  assertMsg "providerName" (ap.providerName == "Wema Islamic Finance Ltd")
  assertMsg "providerType" (ap.providerType == CBNLicensedNIFI)
  assertMsg "Murabahah approved" (Murabahah `elem` ap.approvedInstruments)
  assertMsg "Ijarah approved" (Ijarah `elem` ap.approvedInstruments)
  assertMsg "QardHasan not approved (subset)" (not (QardHasan `elem` ap.approvedInstruments))
  -- Regulator can observe ApprovedProvider
  Some _ <- queryContractId p.regulator apCid
  -- FinancingProviderOnboarding is archived after approval
  onbs <- query @FinancingProviderOnboarding p.fi
  assertMsg "onboarding archived" (null onbs)
  pure ()

-- Unlicensed provider (Waqf fund) with no license number or regulatory body.
testUnlicensedProviderOnboarding : Script ()
testUnlicensedProviderOnboarding = do
  p   <- setupFPParties
  onb <- submit p.fi do
    createCmd FinancingProviderOnboarding with
      financialInstitution = p.fi
      vetify               = p.vetify
      providerName         = "Al-Baraka Waqf Fund"
      address              = "14 Wuse Zone 5, Abuja"
      cacRegNumber         = "RC7654321"
      providerType         = WaqfFund
      regulatoryBody       = None
      licenseNumber        = None
      governingDocRef      = sampleGoverningDocRef
      declaredInstruments  = [Murabahah, QardHasan]
      status               = Draft
      submittedAt          = None
      amendmentCount       = 0
      agentScore           = None
      agentRisk            = None
      agentNote            = None
      agentVersion         = None
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  apCid <- submit p.vetify do
    exerciseCmd submitted ApproveProvider with
      approvedInstruments = [Murabahah, QardHasan]
      regulator           = None
  Some ap <- queryContractId p.fi apCid
  assertMsg "WaqfFund type" (ap.providerType == WaqfFund)
  assertMsg "licenseNumber is None" (ap.licenseNumber == None)
  assertMsg "regulatoryBody is None" (ap.regulatoryBody == None)
  assertMsg "Murabahah approved for investment Waqf" (Murabahah `elem` ap.approvedInstruments)
  assertMsg "QardHasan approved" (QardHasan `elem` ap.approvedInstruments)
  pure ()

-- Vetify approves only QardHasan for a pure philanthropy (not Murabahah).
testPhilanthropyGetQardHasanOnly : Script ()
testPhilanthropyGetQardHasanOnly = do
  p   <- setupFPParties
  onb <- submit p.fi do
    createCmd FinancingProviderOnboarding with
      financialInstitution = p.fi
      vetify               = p.vetify
      providerName         = "Sadaqah Foundation Nigeria"
      address              = "Kano, Nigeria"
      cacRegNumber         = "RC2468135"
      providerType         = Philanthropy
      regulatoryBody       = None
      licenseNumber        = None
      governingDocRef      = sampleGoverningDocRef
      declaredInstruments  = [Murabahah, QardHasan]
      status               = Draft
      submittedAt          = None
      amendmentCount       = 0
      agentScore           = None
      agentRisk            = None
      agentNote            = None
      agentVersion         = None
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  apCid <- submit p.vetify do
    exerciseCmd submitted ApproveProvider with
      approvedInstruments = [QardHasan]   -- Vetify only permits interest-free lending
      regulator           = None
  Some ap <- queryContractId p.fi apCid
  assertMsg "only QardHasan approved" (ap.approvedInstruments == [QardHasan])
  assertMsg "Murabahah not approved for pure charity" (not (Murabahah `elem` ap.approvedInstruments))
  pure ()

-- Amendment flow: Vetify requests amendment; FI amends; Vetify approves.
testAmendmentFlow : Script ()
testAmendmentFlow = do
  p        <- setupFPParties
  onb      <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  amended  <- submit p.vetify do
    exerciseCmd submitted RequestProviderAmendment with
      note = "Please provide updated governing document reference"
  Some a <- queryContractId p.fi amended
  assertMsg "status is PendingAmendment" (a.status == PendingAmendment)
  redrafted <- submit p.fi do
    exerciseCmd amended AmendProvider with
      updatedProviderName        = "Wema Islamic Finance Ltd"
      updatedAddress             = "22 Marina, Lagos Island, Lagos"
      updatedCacRegNumber        = "RC1234567"
      updatedLicenseNumber       = Some "NIFI-2024-001-UPDATED"
      updatedGoverningDocRef     = sampleGoverningDocRef
      updatedDeclaredInstruments = [Murabahah, Ijarah]
  Some r <- queryContractId p.vetify redrafted
  assertMsg "back to Draft after amendment" (r.status == Draft)
  assertMsg "amendmentCount incremented" (r.amendmentCount == 1)
  assertMsg "new license number stored" (r.licenseNumber == Some "NIFI-2024-001-UPDATED")
  assertMsg "updated instruments declared" (Ijarah `elem` r.declaredInstruments)
  pure ()

-- Rejection archives the onboarding; FI may re-register.
testRejectionArchivesOnboarding : Script ()
testRejectionArchivesOnboarding = do
  p        <- setupFPParties
  onb      <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submit p.vetify do
    exerciseCmd submitted RejectProvider with
      reason       = "License number not verifiable in CBN NIFI registry"
      agentScore   = None
      agentRisk    = None
      agentVersion = None
      policyCid    = None
  -- Contract archived; no active onboarding remains
  onbs <- query @FinancingProviderOnboarding p.fi
  assertMsg "onboarding archived after rejection" (null onbs)
  pure ()

-- Guard: cannot submit from a non-Draft status.
testCannotResubmitFromUnderReview : Script ()
testCannotResubmitFromUnderReview = do
  p        <- setupFPParties
  onb      <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submitMustFail p.fi do
    exerciseCmd submitted SubmitProviderForReview
  pure ()

