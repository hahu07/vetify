-- Guard: amendment cap of 5 is enforced.
testAmendmentCapEnforced : Script ()
testAmendmentCapEnforced = do
  p <- setupFPParties
  -- Create onboarding already at the cap
  atCap <- submit p.fi do
    createCmd FinancingProviderOnboarding with
      financialInstitution = p.fi
      vetify               = p.vetify
      providerName         = "Wema Islamic Finance Ltd"
      address              = "22 Marina, Lagos Island, Lagos"
      cacRegNumber         = "RC1234567"
      providerType         = CBNLicensedNIFI
      regulatoryBody       = Some CBN
      licenseNumber        = Some "NIFI-2024-001"
      governingDocRef      = sampleGoverningDocRef
      declaredInstruments  = [Murabahah]
      status               = PendingAmendment
      submittedAt          = None
      amendmentCount       = 5
      agentScore           = None
      agentRisk            = None
      agentNote            = None
      agentVersion         = None
  submitMustFail p.fi do
    exerciseCmd atCap AmendProvider with
      updatedProviderName        = "Wema Islamic Finance Ltd"
      updatedAddress             = "22 Marina, Lagos Island, Lagos"
      updatedCacRegNumber        = "RC1234567"
      updatedLicenseNumber       = Some "NIFI-2024-001"
      updatedGoverningDocRef     = sampleGoverningDocRef
      updatedDeclaredInstruments = [Murabahah]
  pure ()

-- ─── G-Provider: deterministic Stage 0 scoring (RecordProviderScore /
--     FlagProviderForManualReview / RejectProvider's self-consistency guard) ──

setupProviderPolicy : FPParties -> Script (ContractId ProviderVerificationPolicy)
setupProviderPolicy p = do
  t <- getTime
  submit p.vetify do
    createCmd ProviderVerificationPolicy with
      vetify         = p.vetify
      policyVersion  = "2026-v1"
      autoRejectMax  = 49
      effectiveFrom  = t
      scoringWeights = sampleProviderVerificationScoringWeights

-- RecordProviderScore leaves status at UnderReview (no auto-approve — instrument
-- selection stays a manual governing-document judgment call) but does store the
-- computed score/risk for Vetify to see instead of raw fields alone.
testRecordProviderScoreStoresScoreWithoutStatusChange : Script ()
testRecordProviderScoreStoresScoreWithoutStatusChange = do
  p         <- setupFPParties
  policyCid <- setupProviderPolicy p
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  scored <- submit p.vetify do
    exerciseCmd submitted RecordProviderScore with
      score = 100, risk = Low, note = None, version = "scoring-engine-default-2026-v1"
      policyCid = Some policyCid
  Some s <- queryContractId p.vetify scored
  assertMsg "status stays UnderReview" (s.status == UnderReview)
  assertMsg "agentScore recorded" (s.agentScore == Some 100)
  assertMsg "agentRisk recorded" (s.agentRisk == Some Low)

-- Self-consistency guard: a score at or below the active policy's autoRejectMax
-- cannot be recorded via RecordProviderScore — that band belongs to RejectProvider.
testRecordProviderScoreFailsAtOrBelowRejectThreshold : Script ()
testRecordProviderScoreFailsAtOrBelowRejectThreshold = do
  p         <- setupFPParties
  policyCid <- setupProviderPolicy p
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submitMustFail p.vetify do
    exerciseCmd submitted RecordProviderScore with
      score = 49, risk = High, note = None, version = "scoring-engine-default-2026-v1"
      policyCid = Some policyCid
  pure ()

-- With no active policy (policyCid = None, caller-supplied since SDK 3.4.11 /
-- Daml-LF 2.1/2.2 does not support contract keys), the guard is skipped
-- entirely — RecordProviderScore succeeds regardless of score, same fallback
-- behaviour as every other policy-gated choice in this codebase.
testRecordProviderScoreSucceedsWithNoActivePolicy : Script ()
testRecordProviderScoreSucceedsWithNoActivePolicy = do
  p   <- setupFPParties
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  scored <- submit p.vetify do
    exerciseCmd submitted RecordProviderScore with
      score = 5, risk = High, note = None, version = "scoring-engine-default-2026-v1"
      policyCid = None
  Some s <- queryContractId p.vetify scored
  assertMsg "agentScore recorded even without a policy" (s.agentScore == Some 5)

-- FlagProviderForManualReview transitions to ManualReview and stores the
-- scorer's reasoning — mirrors FlagForManualReview on BusinessOnboarding.
testFlagProviderForManualReviewTransitionsStatus : Script ()
testFlagProviderForManualReviewTransitionsStatus = do
  p   <- setupFPParties
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  flagged <- submit p.vetify do
    exerciseCmd submitted FlagProviderForManualReview with
      score = 65, risk = Medium
      note = "CAC-registered legal name does not match the submitted provider name."
      version = "scoring-engine-default-2026-v1"
  Some f <- queryContractId p.vetify flagged
  assertMsg "status is ManualReview" (f.status == ManualReview)
  assertMsg "agentScore recorded" (f.agentScore == Some 65)
  assertMsg "agentNote recorded" (f.agentNote /= None)
  -- ApproveProvider still works from ManualReview, same as the pre-existing guard.
  apCid <- submit p.vetify do
    exerciseCmd flagged ApproveProvider with
      approvedInstruments = [Murabahah]
      regulator           = None
  Some _ <- queryContractId p.fi apCid
  pure ()

-- Self-consistency guard on the automated-rejection path: an agentScore above
-- the active policy's autoRejectMax is not a genuine "reject" outcome.
testRejectProviderAutoGuardFailsAboveThreshold : Script ()
testRejectProviderAutoGuardFailsAboveThreshold = do
  p         <- setupFPParties
  policyCid <- setupProviderPolicy p
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submitMustFail p.vetify do
    exerciseCmd submitted RejectProvider with
      reason = "Risk score falls in the High-risk band."
      agentScore = Some 80, agentRisk = Some Low, agentVersion = Some "scoring-engine-default-2026-v1"
      policyCid = Some policyCid
  pure ()

-- The matching success case: a genuinely low score auto-rejects cleanly.
testRejectProviderAutoGuardSucceedsAtOrBelowThreshold : Script ()
testRejectProviderAutoGuardSucceedsAtOrBelowThreshold = do
  p         <- setupFPParties
  policyCid <- setupProviderPolicy p
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submit p.vetify do
    exerciseCmd submitted RejectProvider with
      reason = "CAC registration number not found."
      agentScore = Some 0, agentRisk = Some High, agentVersion = Some "scoring-engine-default-2026-v1"
      policyCid = Some policyCid
  onbs <- query @FinancingProviderOnboarding p.fi
  assertMsg "onboarding archived after auto-reject" (null onbs)

-- A human rejection from ManualReview carries no agentScore — the guard is
-- skipped entirely (case None), same as no-policy-active.
testRejectProviderHumanRejectionSkipsGuard : Script ()
testRejectProviderHumanRejectionSkipsGuard = do
  p         <- setupFPParties
  policyCid <- setupProviderPolicy p
  onb <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submit p.vetify do
    exerciseCmd submitted RejectProvider with
      reason = "License number not verifiable in CBN NIFI registry."
      agentScore = None, agentRisk = None, agentVersion = None
      policyCid = Some policyCid
  onbs <- query @FinancingProviderOnboarding p.fi
  assertMsg "onboarding archived after human rejection" (null onbs)
