-- Guard: ApproveProvider with empty instrument list is rejected.
testApproveWithNoInstrumentsRejected : Script ()
testApproveWithNoInstrumentsRejected = do
  p        <- setupFPParties
  onb      <- draftOnboarding p [Murabahah]
  submitted <- submit p.fi do exerciseCmd onb SubmitProviderForReview
  submitMustFail p.vetify do
