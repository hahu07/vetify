  submitMustFail p.business do
    createCmd BusinessOnboarding with
      business = p.business; vetify = p.vetify; verifier = p.verifier
      profile = sampleProfile with
        directors = [sampleDirector, sampleDirector with ninNumber = "99999999999"]
      kyc = sampleKyc; status = Draft
      agentScore = None; agentRisk = None; submittedAt = None; amendmentCount = 0
      documents = [sampleDocRef]; documentHistory = []; agentNote = None; agentVersion = None
      onboardingRef = None; schemaVersion = 1; workflowVersion = 1
  pure ()

-- ─── Risk score range and consistency guards ──────────────────────────────

testRejectsScoreAbove100 : Script ()
testRejectsScoreAbove100 = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur (agentApprove passingVerification 101 Low)
  pure ()

testAgentScoreLevelMismatchRejected : Script ()
testAgentScoreLevelMismatchRejected = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  -- Gap 6 blocks auto-approve High; even if it passed, VerificationResult.ensure
  -- would reject because 85 is not < 50 (required for High by Model C)
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur (agentApprove passingVerification 85 High)
  pure ()

-- ─── Verification check gate ─────────────────────────────────────────────

testCannotApproveWithFailedIdentityCheck : Script ()
testCannotApproveWithFailedIdentityCheck = do
