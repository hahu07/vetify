-- | Stage 1–2 tests: onboarding submission, verification approve/reject,
--   amendment cycle, authorization guards, audit-metadata, and gap coverage.
--   Tests are numbered below by the gap they exercise where applicable.
module Vetify.Tests.OnboardingTests where

import Daml.Script
import DA.Time (hours)
import Vetify.Types
import Vetify.Onboarding
import Vetify.Governance
import Vetify.Tests.Fixtures

data OnboardingParties = OnboardingParties with
  business      : Party
  vetify        : Party
  verifier      : Party
  riskCommittee : Party

setupParties : Script OnboardingParties
setupParties = do
  -- Advance past epoch so `incorporationDate 2015-03-20` is not "in the future".
  -- The sandbox starts at 1970-01-01T00:00:00Z; advancing 56 years puts us in ~2026.
  passTime (hours (56 * 365 * 24))
  business      <- allocateParty "Business"
  vetify        <- allocateParty "Vetify"
  verifier      <- allocateParty "Verifier"
  riskCommittee <- allocateParty "RiskCommittee"
  pure OnboardingParties with ..

-- ─── Helpers ──────────────────────────────────────────────────────────────

draftOnboarding : OnboardingParties -> Script (ContractId BusinessOnboarding)
draftOnboarding p = submit p.business do
  createCmd BusinessOnboarding with
    business        = p.business
    vetify          = p.vetify
    verifier        = p.verifier
    profile        = sampleProfile
    kyc             = sampleKyc
    status          = Draft
    agentScore      = None
    agentRisk       = None
    submittedAt     = None
    amendmentCount  = 0
    documents       = [sampleDocRef]
    documentHistory = []
    agentNote       = None
    agentVersion    = None
    onboardingRef   = Some "ONB-2026-000001"
    schemaVersion   = 1
    workflowVersion = 1

-- Agent auto-path: autoDecided=True, aiMetadata set, reviewerParty None.
-- Model C Low risk: score must be >= 80 for riskLevel Low.
agentApprove : VerificationChecks -> Int -> RiskLevel -> Approve
agentApprove c s l = Approve with
  checks                = c
  checkScores           = Some sampleCheckScores
  riskScore             = s
  riskLevel             = l
  autoDecided           = True
  reviewerParty         = None
  reviewedBy            = None
  agentVersion          = Some "vetify-verification-v1.0"
  aiMetadata            = Some sampleAIMetadata
  verificationRef       = "VER-2026-000001"
  overrideJustification = None
  policyVersion         = "2026-v1"
  overrideType          = None
  reviewNotes           = None
  policyCid             = None

-- Human review path: autoDecided=False, reviewerParty set, aiMetadata None.
-- Gap 7: overrideJustification required because the human decides after agent review.
-- Gap 5: overrideType=OverrodeApproval — human is approving after the agent flagged.
-- Gap 9: reviewNotes captured for human decision audit trail.
humanApprove : Party -> VerificationChecks -> Int -> RiskLevel -> Approve
humanApprove reviewer c s l = Approve with
  checks                = c
  checkScores           = None
  riskScore             = s
  riskLevel             = l
  autoDecided           = False
  reviewerParty         = Some reviewer
  reviewedBy            = Some "officer-001"
  agentVersion          = None
  aiMetadata            = None
  verificationRef       = "VER-2026-000001"
  overrideJustification = Some "Manual review completed — risk assessed as acceptable"
  policyVersion         = "2026-v1"
  overrideType          = Some OverrodeApproval
  reviewNotes           = Some "Reviewed all evidence; consistent with acceptable risk profile"
  policyCid             = None

-- ─── Gap 1 (formerly LF 2.3 contract key uniqueness; SDK 3.4.11 / LF 2.2 has
-- no contract keys, so lookup is now a plain query filtered on business +
-- CAC number instead of a ledger-side key resolution) ─────────────────────

-- Active contract is findable by scanning business's active BusinessOnboarding
-- contracts and filtering on the CAC number — useful for agents querying for
-- pending applications now that ledger-side key lookup is unavailable.
testKeyLookupByBusinessAndCac : Script ()
testKeyLookupByBusinessAndCac = do
  p       <- setupParties
  _       <- draftOnboarding p
  results <- query @BusinessOnboarding p.business
  let found = filter (\(_, c) -> c.business == p.business && c.kyc.cacRegNumber == sampleKyc.cacRegNumber) results
  assertMsg "Contract must be findable by (business, CAC) via query" (not (null found))

-- Gap 1 (SLA): EscalateOverdue is blocked before the SLA window expires.
testEscalateBlockedBeforeDeadline : Script ()
testEscalateBlockedBeforeDeadline = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  -- Just submitted; 48-hour SLA window has not passed yet
  submitMustFail p.vetify do exerciseCmd ur EscalateOverdue with slaHours = 48; policyCid = None
  pure ()

-- Gap 1 (SLA): EscalateOverdue succeeds after the SLA window expires.
testEscalateSucceedsAfterDeadline : Script ()
testEscalateSucceedsAfterDeadline = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  passTime (hours 49)
  escalated <- submit p.vetify do exerciseCmd ur EscalateOverdue with slaHours = 48; policyCid = None
  Some e <- queryContractId p.vetify escalated
  assertMsg "Should be ManualReview after SLA escalation" (e.status == ManualReview)

-- ─── Gap 2 (Decision lifecycle / correction) ─────────────────────────────

-- An erroneous VerificationResult can be superseded; the correction is recorded
-- as an immutable VerificationCorrection contract with full audit detail.
testSupersedeFlow : Script ()
testSupersedeFlow = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  res <- submit (actAs [p.verifier, p.vetify]) do exerciseCmd ur (agentApprove passingVerification 85 Low)
  correction <- submit p.vetify do
    exerciseCmd res Supersede with
      correctionRef    = "COR-2026-000001"
      correctedOutcome = Rejected
      reason           = "Post-decision fraud discovery: synthetic CAC certificate"
      correctedBy      = p.vetify
  Some c <- queryContractId p.vetify correction
  assertMsg "Original ref preserved in correction" (c.originalRef == "VER-2026-000001")
  assertMsg "Original outcome was Approved" (c.originalOutcome == Approved)
  assertMsg "Corrected outcome is Rejected" (c.correctedOutcome == Rejected)
  assertMsg "Reason recorded" (c.reason /= "")
  -- The original VerificationResult is archived after Supersede
  archived <- queryContractId @VerificationResult p.vetify res
  assertMsg "Original VerificationResult archived by Supersede" (archived == None)

-- ─── Gap 3 (Reviewer identity) ───────────────────────────────────────────

-- Human decisions (autoDecided=False) must include a reviewer party.
testReviewerRequiredForHumanDecision : Script ()
testReviewerRequiredForHumanDecision = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur Approve with
      checks                = passingVerification
      checkScores           = None
      riskScore             = 85
      riskLevel             = Low
      autoDecided           = False
      reviewerParty         = None    -- missing: human decisions must set this
      reviewedBy            = None
      agentVersion          = None
      aiMetadata            = None
      verificationRef       = "VER-2026-TEST-001"
      overrideJustification = None
      policyVersion         = "2026-v1"
      overrideType          = None
      reviewNotes           = None
      policyCid             = None
  pure ()

-- ─── Gap 6 (Approval business rules) ─────────────────────────────────────

-- High-risk applications cannot be auto-approved by the agent.
testCannotAutoApproveHighRisk : Script ()
testCannotAutoApproveHighRisk = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur (agentApprove passingVerification 30 High)
  pure ()

-- ─── Gap 7 (Override justification) ─────────────────────────────────────

-- When a human decides after the agent flagged the application, they must
-- provide an override justification even if they agree with the agent.
testOverrideRequiresJustification : Script ()
testOverrideRequiresJustification = do
  p       <- setupParties
  cid     <- draftOnboarding p
  ur      <- submit p.business do exerciseCmd cid SubmitForReview
  flagged <- submit p.verifier do
    exerciseCmd ur FlagForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-verification-v1.0"
      note         = "Borderline NIN match — refer to human"
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd flagged Approve with
      checks                = passingVerification
      checkScores           = None
      riskScore             = 65
      riskLevel             = Medium
      autoDecided           = False
      reviewerParty         = Some p.verifier
      reviewedBy            = Some "officer-001"
      agentVersion          = None
      aiMetadata            = None
      verificationRef       = "VER-2026-TEST-001"
      overrideJustification = None    -- missing: must provide justification
      policyVersion         = "2026-v1"
      overrideType          = None
      reviewNotes           = None
      policyCid             = None
  pure ()

-- ─── Gap 8 (verificationRef uniqueness) ──────────────────────────────────

-- VerificationResult is findable by scanning verifier's active
-- VerificationResult contracts and filtering on verificationRef — SDK 3.4.11 /
-- LF 2.2 has no contract keys, so duplicate-ref prevention is no longer
-- ledger-enforced (application-layer concern now), but the record should
-- still be locatable via a plain query.
testVerificationRefKeyLookup : Script ()
testVerificationRefKeyLookup = do
  p       <- setupParties
  cid     <- draftOnboarding p
  ur      <- submit p.business do exerciseCmd cid SubmitForReview
  res     <- submit (actAs [p.verifier, p.vetify]) do exerciseCmd ur (agentApprove passingVerification 85 Low)
  results <- query @VerificationResult p.vetify
  let found = filter (\(_, r) -> r.verifier == p.verifier && r.verificationRef == "VER-2026-000001") results
  assertMsg "VerificationResult findable by (verifier, verificationRef) via query" (not (null found))

-- ─── Gap 9 (Onboarding reference mandatory on submit) ─────────────────────

-- SubmitForReview must fail when onboardingRef has not been set.
testOnboardingRefRequiredOnSubmit : Script ()
testOnboardingRefRequiredOnSubmit = do
  p <- setupParties
  -- Create a draft WITHOUT onboardingRef (allowed at draft stage)
  cid <- submit p.business do
    createCmd BusinessOnboarding with
      business = p.business; vetify = p.vetify; verifier = p.verifier
      profile = sampleProfile; kyc = sampleKyc; status = Draft
      agentScore = None; agentRisk = None; submittedAt = None; amendmentCount = 0
      documents = [sampleDocRef]; documentHistory = []; agentNote = None; agentVersion = None
      onboardingRef = None   -- not set
      schemaVersion = 1; workflowVersion = 1
  -- Submission must fail until the onboardingRef is populated
  submitMustFail p.business do exerciseCmd cid SubmitForReview
  pure ()

-- ─── Gap 12 (Document lifecycle preservation) ─────────────────────────────

-- Prior document set is preserved in documentHistory when a new set is submitted.
testDocumentHistoryPreserved : Script ()
testDocumentHistoryPreserved = do
  p    <- setupParties
  cid  <- draftOnboarding p       -- documents = [sampleDocRef], documentHistory = []
  ur   <- submit p.business do exerciseCmd cid SubmitForReview
  pend <- submit p.vetify do exerciseCmd ur RequestAmendment with note = "Add utility bill"
  let utilityBill = DocumentRef with
        docType            = "UTILITY_BILL"
        contentHash        = "sha256:b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5"
        storageRef         = "s3://vetify-docs/RC123456/utility-bill.pdf"
        mimeType           = Some "application/pdf"
        malwareScanStatus  = Some "CLEAN"
        fileSize           = Some 153600
        checksumAlgorithm  = Some "sha256"
        malwareScanAt      = None
        digitalSignature   = None
        signatureAlgorithm = None
        signatoryRef       = None
        signedAt           = None
  amended <- submit p.business do
    exerciseCmd pend Amend with
      updatedProfile      = sampleProfile
      updatedKyc          = sampleKyc
      updatedDocuments    = [utilityBill]
      policyMaxAmendments = None
  Some a <- queryContractId p.business amended
  assertMsg "New documents applied" (a.documents == [utilityBill])
  assertMsg "Original documents preserved in history" (a.documentHistory == [[sampleDocRef]])
  assertMsg "amendmentCount incremented to 1" (a.amendmentCount == 1)

-- ─── Gap 13/14 (Identity and CAC numeric format) ─────────────────────────

