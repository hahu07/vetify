-- Document types must be unique within a single submission.
testDuplicateDocTypesRejected : Script ()
testDuplicateDocTypesRejected = do
  p <- setupParties
  submitMustFail p.business do
    createCmd BusinessOnboarding with
      business = p.business; vetify = p.vetify; verifier = p.verifier
