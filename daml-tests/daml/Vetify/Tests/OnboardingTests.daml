      documentHistory = []; agentNote = None; agentVersion = None
      onboardingRef = None; schemaVersion = 1; workflowVersion = 1
  pure ()

-- ─── Happy path ───────────────────────────────────────────────────────────

-- Draft → SubmitForReview records submittedAt; Approve produces VerificationResult
-- with all new fields (policyVersion, submittedAt, overrideJustification) preserved.
testApproveFlow : Script ()
testApproveFlow = do
  p   <- setupParties
  cid <- draftOnboarding p
  Some draft <- queryContractId p.business cid
  assertMsg "submittedAt should be None before submission" (draft.submittedAt == None)
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  Some underReview <- queryContractId p.business ur
  assertMsg "submittedAt should be set after submission" (underReview.submittedAt /= None)
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur (agentApprove passingVerification 85 Low)
  Some r <- queryContractId p.vetify res
  assertMsg "outcome should be Approved" (r.outcome == Approved)
  assertMsg "cacRegNumber preserved" (r.cacRegNumber == "RC123456")
  assertMsg "autoDecided true for agent path" r.autoDecided
  assertMsg "verificationRef recorded" (r.verificationRef == "VER-2026-000001")
  assertMsg "agentVersion recorded" (r.agentVersion == Some "vetify-verification-v1.0")
  assertMsg "reviewerParty None for agent path" (r.reviewerParty == None)
  assertMsg "checkScores recorded" (r.checkScores == Some sampleCheckScores)
  assertMsg "aiMetadata recorded" (r.aiMetadata /= None)
  assertMsg "policyVersion recorded" (r.policyVersion == "2026-v1")
  assertMsg "submittedAt carried to result" (r.submittedAt /= None)
  assertMsg "overrideJustification None for agent path" (r.overrideJustification == None)
  -- After approval no active BusinessOnboarding remains for this CAC number —
  -- a fresh onboarding cycle can begin (SDK 3.4.11 / LF 2.2 has no contract
  -- keys, so this is now a plain query rather than a key-release check).
  res2 <- query @BusinessOnboarding p.business
  let stillActive = filter (\(_, c) -> c.business == p.business && c.kyc.cacRegNumber == sampleKyc.cacRegNumber) res2
  assertMsg "No active BusinessOnboarding remains after approval" (null stillActive)

-- Rejected decision preserved on-ledger with reason and provenance.
testRejectFlow : Script ()
testRejectFlow = do
  p   <- setupParties
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur Reject with
      checks                = passingVerification with cacRegistered = False
      checkScores           = Some sampleCheckScores
      riskScore             = 30
      riskLevel             = High
      autoDecided           = True
      reviewerParty         = None
      reviewedBy            = None
      agentVersion          = Some "vetify-verification-v1.0"
      aiMetadata            = Some sampleAIMetadata
      verificationRef       = "VER-2026-000001"
      reason                = "CAC registration could not be verified"
      overrideJustification = None
      policyVersion         = "2026-v1"
      overrideType          = None
      reviewNotes           = None
      policyCid             = None
  Some r <- queryContractId p.vetify res
  assertMsg "outcome should be Rejected" (r.outcome == Rejected)
  assertMsg "reason preserved" (r.note == Some "CAC registration could not be verified")
  assertMsg "policyVersion recorded on rejection" (r.policyVersion == "2026-v1")

-- Human review path: reviewerParty set, checkScores None, autoDecided False.
-- overrideJustification required because the agent previously flagged the application.
testHumanReviewPath : Script ()
testHumanReviewPath = do
  p       <- setupParties
  cid     <- draftOnboarding p
  ur      <- submit p.business do exerciseCmd cid SubmitForReview
  flagged <- submit p.verifier do
    exerciseCmd ur FlagForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-verification-v1.0"
      note         = "Borderline NIN match — refer to human"
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd flagged (humanApprove p.verifier passingVerification 65 Medium)
  Some r <- queryContractId p.vetify res
  assertMsg "autoDecided false for human path" (not r.autoDecided)
  assertMsg "reviewerParty set for human path" (r.reviewerParty == Some p.verifier)
  assertMsg "reviewedBy set for human path" (r.reviewedBy == Some "officer-001")
  assertMsg "checkScores None for human path" (r.checkScores == None)
  assertMsg "aiMetadata None for human path" (r.aiMetadata == None)
  assertMsg "overrideJustification recorded" (r.overrideJustification /= None)

-- ─── Amendment cycle ──────────────────────────────────────────────────────

-- UnderReview → PendingAmendment → Draft → UnderReview → Approved.
-- Key is preserved atomically across all transitions.
testAmendmentFlow : Script ()
testAmendmentFlow = do
  p    <- setupParties
  cid  <- draftOnboarding p
  ur   <- submit p.business do exerciseCmd cid SubmitForReview
  pend <- submit p.vetify do
    exerciseCmd ur RequestAmendment with note = "Fix director NIN"
  Some pc <- queryContractId p.business pend
  assertMsg "status should be PendingAmendment" (pc.status == PendingAmendment)
  let fixedProfile = sampleProfile with
        directors = [sampleDirector with ninNumber = "99999999999"]
  draft <- submit p.business do
    exerciseCmd pend Amend with
      updatedProfile      = fixedProfile
      updatedKyc          = sampleKyc
      updatedDocuments    = [sampleDocRef]
      policyMaxAmendments = None
  Some dc <- queryContractId p.business draft
  assertMsg "status back to Draft" (dc.status == Draft)
  assertMsg "amendmentCount incremented" (dc.amendmentCount == 1)
  assertMsg "agentScore cleared" (dc.agentScore == None)
  assertMsg "agentNote cleared after amendment" (dc.agentNote == None)
  assertMsg "documentHistory has 1 entry" (length dc.documentHistory == 1)
  ur2 <- submit p.business do exerciseCmd draft SubmitForReview
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur2 (agentApprove passingVerification 85 Low)
  Some r <- queryContractId p.vetify res
  assertMsg "outcome should be Approved after amendment" (r.outcome == Approved)

-- CAC number cannot change during amendment.
testAmendmentCannotChangeCac : Script ()
testAmendmentCannotChangeCac = do
  p    <- setupParties
  cid  <- draftOnboarding p
  ur   <- submit p.business do exerciseCmd cid SubmitForReview
  pend <- submit p.vetify do
    exerciseCmd ur RequestAmendment with note = "Data correction"
  submitMustFail p.business do
    exerciseCmd pend Amend with
      updatedProfile      = sampleProfile
      updatedKyc          = sampleKyc with cacRegNumber = "RC999999"
      updatedDocuments    = [sampleDocRef]
      policyMaxAmendments = None
  pure ()

