-- ─── Gap 7 (Malware scan gate) ───────────────────────────────────────────

-- A document with an explicit FLAGGED malware scan status blocks approval.
testFlaggedDocumentBlocksApproval : Script ()
testFlaggedDocumentBlocksApproval = do
  p <- setupParties
  cid <- submit p.business do
    createCmd BusinessOnboarding with
      business = p.business; vetify = p.vetify; verifier = p.verifier
      profile = sampleProfile; kyc = sampleKyc; status = Draft
      agentScore = None; agentRisk = None; submittedAt = None; amendmentCount = 0
      documents = [sampleDocRef with malwareScanStatus = Some "FLAGGED"]
      documentHistory = []; agentNote = None; agentVersion = None
      onboardingRef = Some "ONB-2026-MALWARE-001"; schemaVersion = 1; workflowVersion = 1
  ur <- submit p.business do exerciseCmd cid SubmitForReview
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur (agentApprove passingVerification 85 Low)
  pure ()

-- ─── Gap 1/2 (Policy-driven required document types) ─────────────────────

-- VerificationPolicy.requiredDocTypes enforces which document types must be
-- present before approval is permitted. Missing a required type blocks the choice.
testRequiredDocTypeEnforced : Script ()
testRequiredDocTypeEnforced = do
  p     <- setupParties
  vpCid <- submit p.vetify do
    createCmd VerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE", "UTILITY_BILL"]
      policyVersion    = "2026-v1"
      scoringWeights    = sampleVerificationScoringWeights
  -- draftOnboarding uses [sampleDocRef] = ["CAC_CERTIFICATE"] only — UTILITY_BILL missing
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur ((agentApprove passingVerification 85 Low) with policyCid = Some vpCid)
  pure ()

-- ─── Gap 5 + Gap 9 (Override type and reviewer notes) ────────────────────

-- When a human approves after agent flagging, both the override type and
-- reviewer notes are recorded on the VerificationResult.
testOverrideTypeAndReviewNotesRecorded : Script ()
testOverrideTypeAndReviewNotesRecorded = do
  p       <- setupParties
  cid     <- draftOnboarding p
  ur      <- submit p.business do exerciseCmd cid SubmitForReview
  flagged <- submit p.verifier do
    exerciseCmd ur FlagForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-verification-v1.0"
      note         = "Borderline NIN match — refer to human"
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd flagged (humanApprove p.verifier passingVerification 65 Medium)
  Some r <- queryContractId p.vetify res
  assertMsg "overrideType recorded as OverrodeApproval" (r.overrideType == Some OverrodeApproval)
  assertMsg "reviewNotes recorded" (r.reviewNotes /= None)
  pure ()

-- ─── Gap 1: Policy approval threshold enforcement ─────────────────────────

-- When an active VerificationPolicy exists, an agent may not auto-approve an
-- application whose score falls below policy.autoApproveMin (80).
-- Score 75 (Medium risk) is below the 80 threshold → submitMustFail.
testPolicyApprovalThresholdEnforced : Script ()
testPolicyApprovalThresholdEnforced = do
  p     <- setupParties
  vpCid <- submit p.vetify do
    createCmd VerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v1"
      scoringWeights    = sampleVerificationScoringWeights
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  -- Score 75 is Medium risk; policy requires >= 80 for agent auto-approval
  submitMustFail (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur ((agentApprove passingVerification 75 Medium) with policyCid = Some vpCid)
  pure ()

-- ─── Gap 1: EscalateOverdue reads SLA from active policy ─────────────────

-- When a VerificationPolicy is active with slaHours = 24, EscalateOverdue
-- uses 24h (not the caller-supplied 48h). After 25h the policy window has
-- expired → escalation succeeds even though the 48h parameter has not elapsed.
testEscalatePolicySlaUsed : Script ()
testEscalatePolicySlaUsed = do
  p     <- setupParties
  vpCid <- submit p.vetify do
    createCmd VerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 24        -- policy says 24h SLA
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v1"
      scoringWeights    = sampleVerificationScoringWeights
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  passTime (hours 25)              -- past policy's 24h window but not the 48h parameter
  -- slaHours = 48 is ignored; policy.slaHours = 24 applies → escalation succeeds
  escalated <- submit p.vetify do exerciseCmd ur EscalateOverdue with slaHours = 48; policyCid = Some vpCid
  Some e <- queryContractId p.vetify escalated
  assertMsg "Status must be ManualReview after policy-driven SLA expiry" (e.status == ManualReview)
  pure ()

-- ─── Gap 4: policyVersion derived from active VerificationPolicy ──────────

-- Approve records the policyVersion from the active VerificationPolicy,
-- ignoring the caller-supplied parameter value.
testPolicyVersionDerivedFromPolicy : Script ()
testPolicyVersionDerivedFromPolicy = do
  p     <- setupParties
  vpCid <- submit p.vetify do
    createCmd VerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v2"   -- intentionally different from agentApprove's "2026-v1"
      scoringWeights   = sampleVerificationScoringWeights
  cid <- draftOnboarding p
  ur  <- submit p.business do exerciseCmd cid SubmitForReview
  -- agentApprove helper hard-codes policyVersion = "2026-v1", but the active
  -- policy has "2026-v2" — the VerificationResult should record "2026-v2"
  res <- submit (actAs [p.verifier, p.vetify]) do
    exerciseCmd ur ((agentApprove passingVerification 85 Low) with policyCid = Some vpCid)
  Some r <- queryContractId p.vetify res
  assertMsg "policyVersion must come from active VerificationPolicy, not from the caller"
    (r.policyVersion == "2026-v2")
  pure ()

-- ─── Maker-checker for VerificationPolicy changes ──────────────────────────

-- ApprovePolicyChange with a distinct approver activates the proposal: the
-- new VerificationPolicy exists and carries the proposed scoringWeights.
testPolicyChangeApprovedByDifferentPerson : Script ()
testPolicyChangeApprovedByDifferentPerson = do
  p <- setupParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights with identityVerified = 30
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review — raise identity check weight"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  activeCid <- submit p.vetify do
    exerciseCmd endorsed ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = None
  Some active <- queryContractId p.vetify activeCid
  assertMsg "activated policy carries the proposed weights" (active.scoringWeights.identityVerified == 30)
  assertMsg "activated policy carries the proposed version" (active.policyVersion == "2026-v3")

-- The same person cannot both propose and approve — this is the whole point
-- of the gate, so it must fail, not just be discouraged by convention.
testPolicyChangeCannotSelfApprove : Script ()
testPolicyChangeCannotSelfApprove = do
  p <- setupParties
  t <- getTime
  -- A real, registered PolicyApprover is needed to supply a valid ContractId
  -- argument (no contract keys/conjured CIDs on SDK 3.4.11 / LF 2.2) — but the
  -- self-approve assertion (approvedBy == proposedBy below) fails before this
  -- ContractId is ever fetched, so its identity doesn't matter to this test.
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Alice (Risk Analyst)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- Approving a proposal replaces whichever VerificationPolicy was previously
-- active — old scoringWeights are gone, not merely shadowed.
testPolicyChangeReplacesActivePolicy : Script ()
testPolicyChangeReplacesActivePolicy = do
  p <- setupParties
  t <- getTime
  currentPolicyCid <- submit p.vetify do
    createCmd VerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v1"
      scoringWeights   = sampleVerificationScoringWeights
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v2"
      scoringWeights   = sampleVerificationScoringWeights with identityVerified = 20
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Lower identity check weight"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  activeCid <- submit p.vetify do
    exerciseCmd endorsed ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = Some currentPolicyCid
  Some active <- queryContractId p.vetify activeCid
  assertMsg "the new policy version is active" (active.policyVersion == "2026-v2")
  assertMsg "the old scoringWeights no longer apply" (active.scoringWeights.identityVerified == 20)
  -- Not asserted here: that a second VerificationPolicy create would now
  -- fail on the vetify-singleton key. dpm test's in-memory Script
  -- interpreter doesn't enforce ledger-level key uniqueness (see
  -- testVerificationRefKeyLookup's comment above) — only a real Canton
  -- participant does. ApprovePolicyChange's own successful create (asserted
  -- above) already proves the archive-then-create ran without a spurious
  -- duplicate-key failure against the old policy within the same transaction.
  pure ()

-- RejectPolicyChange withdraws a proposal without ever creating a
-- VerificationPolicy — self-rejection (withdrawing your own draft) is fine.
testPolicyChangeCanBeRejected : Script ()
testPolicyChangeCanBeRejected = do
  p <- setupParties
  t <- getTime
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Experimental change"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submit p.vetify do
    exerciseCmd pending RejectPolicyChange with
      rejectedBy      = "Alice (Risk Analyst)"
      rejectionReason = "Decided against it before anyone else reviewed"
  pure ()

-- Layer 1 of the Policy-Approval Security Roadmap: an unregistered name
-- cannot approve, even though it legitimately differs from proposedBy.
-- SDK 3.4.11 / LF 2.2 has no contract keys, so a ContractId can no longer be
-- conjured for an unregistered name via lookupByKey failing gracefully —
-- there is no valid ContractId to construct for someone who was never
-- registered at all. Instead this exercises the same underlying business
-- rule (requireActivePolicyApprover's name-match assertion in
-- Vetify.Governance) via a real, registered approver's ContractId presented
-- with a mismatched `approvedBy` name ("Carol", who never registered).
testPolicyChangeFailsIfApproverNotRegistered : Script ()
testPolicyChangeFailsIfApproverNotRegistered = do
  p <- setupParties
  t <- getTime
  -- A real registrant, "Bob" — but the approval below claims to be "Carol",
  -- who was never registered as a PolicyApprover.
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Carol (Nobody in Particular)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- A deactivated approver cannot approve, even though they were once registered.
testPolicyChangeFailsIfApproverDeactivated : Script ()
testPolicyChangeFailsIfApproverDeactivated = do
  p <- setupParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  deactivatedCid <- submit p.vetify do
    exerciseCmd approverCid DeactivatePolicyApprover with
      reason      = "Left the risk committee"
      performedBy = "Vetify Founder"
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = deactivatedCid
      currentPolicyCid = None
  pure ()

-- Layer 2 of the Policy-Approval Security Roadmap: vetify cannot finalize a
-- policy change on its own, even with a validly registered approver, until
-- the Risk Committee's own separately-signed transaction has endorsed it.
testPolicyChangeFailsWithoutRiskCommitteeEndorsement : Script ()
testPolicyChangeFailsWithoutRiskCommitteeEndorsement = do
  p <- setupParties
  t <- getTime
  approverCid <- submit p.vetify do
    createCmd PolicyApprover with
      vetify       = p.vetify
      approverName = "Bob (Risk Manager)"
      role         = "Risk Manager"
      authorizedBy = "Vetify Founder"
      authorizedAt = t
      active       = True
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  -- No EndorseByRiskCommittee call — a registered approver alone is not enough.
  submitMustFail p.vetify do
    exerciseCmd pending ApprovePolicyChange with
      approvedBy       = "Bob (Risk Manager)"
      approverCid      = approverCid
      currentPolicyCid = None
  pure ()

-- EndorseByRiskCommittee cannot be exercised twice on the same proposal.
testPolicyChangeCannotDoubleEndorse : Script ()
testPolicyChangeCannotDoubleEndorse = do
  p <- setupParties
  t <- getTime
  pending <- submit p.vetify do
    createCmd PendingVerificationPolicy with
      vetify           = p.vetify
      maxAmendments    = 5
      slaHours         = 48
      autoApproveMin   = 80
      autoRejectMax    = 50
      requiredDocTypes = ["CAC_CERTIFICATE"]
      policyVersion    = "2026-v3"
      scoringWeights   = sampleVerificationScoringWeights
      proposedBy       = "Alice (Risk Analyst)"
      reason           = "Quarterly rubric review"
      proposedAt       = t
      riskCommittee           = p.riskCommittee
      riskCommitteeEndorsedBy = None
      riskCommitteeEndorsedAt = None
  endorsed <- submit p.riskCommittee do
    exerciseCmd pending EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  submitMustFail p.riskCommittee do
    exerciseCmd endorsed EndorseByRiskCommittee with endorsedBy = "Imam Yusuf Abdullahi"
  pure ()
