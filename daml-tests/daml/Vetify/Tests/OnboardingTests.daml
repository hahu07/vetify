-- ─── Manual review metadata persistence ──────────────────────────────────

testFlagForManualReview : Script ()
testFlagForManualReview = do
  p       <- setupParties
  cid     <- draftOnboarding p
  ur      <- submit p.business do exerciseCmd cid SubmitForReview
  flagged <- submit p.verifier do
    exerciseCmd ur FlagForManualReview with
      riskScore    = 65
      riskLevel    = Medium
      agentVersion = "vetify-verification-v1.0"
      note         = "Borderline NIN match — refer to human"
  Some f <- queryContractId p.vetify flagged
  assertMsg "status should be ManualReview" (f.status == ManualReview)
  assertMsg "agentScore recorded" (f.agentScore == Some 65)
  assertMsg "agentNote persisted on contract"
    (f.agentNote == Some "Borderline NIN match — refer to human")
  assertMsg "agentVersion persisted on contract"
    (f.agentVersion == Some "vetify-verification-v1.0")

