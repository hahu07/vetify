 variant {
   err: text;
   ok: AdminAnalytics;
 };
type Result_5 = 
 variant {
   err: text;
   ok: IndividualProfile;
 };
type Result_4 = 
 variant {
   err: text;
   ok: record {
         items: vec NotificationRecord;
         total: nat;
       };
 };
type Result_3 = 
 variant {
   err: text;
   ok: record {
         mizanDone: bool;
         status: RegistrationStatus;
         tawthiqDone: bool;
       };
 };
type Result_2 = 
 variant {
   err: text;
