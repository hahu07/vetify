type http_request_result = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type http_header = 
 record {
   name: text;
   value: text;
 };
type _ImmutableObjectStorageRefillResult = 
 record {
   success: opt bool;
   topped_up_amount: opt nat;
 };
type _ImmutableObjectStorageRefillInformation = record {
                                                  proposed_top_up_amount:
                                                   opt nat;};
type _ImmutableObjectStorageCreateCertificateResult = 
 record {
   blob_hash: text;
   method: text;
 };
type UserRole__1 = 
 variant {
   admin;
   guest;
   user;
 };
type UserRole = 
 variant {
   admin;
   businessApplicant;
   financier;
 };
type UserId = principal;
type UploadStatus = 
 variant {
   notUploaded;
   uploaded;
 };
type TransformationOutput = 
 record {
   body: blob;
   headers: vec http_header;
   status: nat;
 };
type TransformationInput = 
 record {
   context: blob;
   response: http_request_result;
 };
type TransactionSummary = 
 record {
   income: nat;
   months: nat;
   totalCredits: nat;
   totalDebits: nat;
 };
type Timestamp = int;
type TawthiqRecord = 
 record {
   completedAt: opt Timestamp;
   creditReadinessVerdict: CreditReadinessVerdict;
   inconsistencyFlags: vec InconsistencyFlag;
   inconsistencyStatus: variant {
                          Clean;
                          Flagged;
                          Pending;
                        };
   narrativeSummary: text;
   shariaFlags: vec ShariaFlag;
   shariaScreeningNotes: text;
   shariaScreeningStatus: variant {
                            Failed;
                            Passed;
                            Pending;
                          };
 };
type TawthiqOverviewStats = 
