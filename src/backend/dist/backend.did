      ok: MizanRecord;
    });
  updateBusinessProfile: (userId: principal, updates:
   BusinessProfileUpdate) -> (variant {
                                err: text;
                                ok;
                              });
  updateBusinessStatus: (userId: principal, status: RegistrationStatus,
   reason: opt text) -> (bool);
  updateIndividualProfile: (address: opt text, occupation: opt text,
   employerName: opt text, monthlyIncome: opt nat, incomeSource:
   opt IncomeSource) -> (Result);
  updateKashifScoringConfig: (newConfig: KashifScoringConfig) ->
   (variant {
      err: text;
      ok;
    });
  updateMyProfile: (updates: BusinessProfileUpdate) ->
   (variant {
      err: text;
      ok;
    });
  update_privacy_settings: (applicantId: text, settings:
   ProfilePrivacySettings) -> (Result);
  uploadDocument: (docType: DocumentType, storageRef: ExternalBlob) ->
   (DocumentRecord);
  validateAdminInviteLink: (code: text) -> (bool) query;
}
