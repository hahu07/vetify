  getAuditLogForEntity: (entityId: text, page: nat, pageSize: nat) ->
   (AuditPage) query;
  getBootstrapAdmin: () -> (opt principal) query;
  getCallerUserRole: () -> (UserRole__1) query;
  getComparisonData: (businessIds: vec principal) ->
