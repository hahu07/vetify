   medium;
   pending;
 };
type RiskLevel = 
 variant {
   High;
   Low;
   Medium;
 };
type Result_8 = 
 variant {
   err: text;
   ok: record {
         items: vec IndividualSummary;
         total: nat;
       };
 };
type Result_7 = 
 variant {
   err: text;
   ok: record {
         items: vec AccountClosureRequest;
         total: nat;
       };
 };
