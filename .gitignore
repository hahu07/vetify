# ─── Daml build artefacts ────────────────────────────────────────────────────
.daml/
*.dar

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/

# ─── Environment / secrets ───────────────────────────────────────────────────
# Keep .env.example; never commit real secrets
.env
.env.local
.env.*.local
agents/.env
backend/.env
frontend/.env

# ─── AI / RAG vector store ───────────────────────────────────────────────────
# Generated by `npm run rag:ingest:shariah` — re-created from PDFs
agents/data/shariah-vectorstore/

# PDFs in the shariah knowledge base may be large / licensed — keep out of git
# Place them in agents/data/shariah/ locally and re-run ingestion
agents/data/shariah/*.pdf

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ─── TypeScript compile output ───────────────────────────────────────────────
agents/dist/
backend/dist/
frontend/dist/

# ─── Test / coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Docker volumes / postgres data ──────────────────────────────────────────
infra/postgres/data/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.gz
