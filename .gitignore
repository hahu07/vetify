# ─── Daml build artefacts ────────────────────────────────────────────────────
.daml/
*.dar
# Exception: archived baseline DARs the SCU upgrade-check gate (ci.yml,
# docs/daml-upgrade-lineage.md) diffs each new version against — these are
# deliberately committed, not build output to discard.
!docs/dar-archive/*.dar

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/

# ─── Environment / secrets ───────────────────────────────────────────────────
# Keep .env.example; never commit real secrets
.env
.env.local
.env.*.local
agents/.env
backend/.env
frontend/.env

# ─── AI / RAG vector store ───────────────────────────────────────────────────
# Generated by `npm run rag:ingest:shariah` — re-created from PDFs
agents/data/shariah-vectorstore/

# PDFs in the shariah knowledge base may be large / licensed — keep out of git
# Place them in agents/data/shariah/ locally and re-run ingestion
agents/data/shariah/*.pdf

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# ─── TypeScript compile output ───────────────────────────────────────────────
agents/dist/
backend/dist/
frontend/dist/

# ─── Test / coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Docker volumes / postgres data ──────────────────────────────────────────
infra/postgres/data/

# ─── Locally-stored KYC/onboarding document uploads (routes/documents.ts) ────
backend/uploads/

# ─── Local backup output (infra/scripts/backup-*.sh) ─────────────────────────
# Dumps contain password hashes and the full audit log — never commit them.
infra/backups/*
!infra/backups/.gitkeep

# ─── Docs (working notes, not shipped) ───────────────────────────────────────
# `docs/*` (not `docs/`) so the dar-archive re-include below actually works —
# once a parent directory itself is excluded, Git won't descend into it to
# apply nested negations, even to re-include the directory itself.
docs/*
!docs/dar-archive

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.gz
