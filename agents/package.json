{
  "name": "vetify-agents",
  "version": "0.1.0",
  "description": "AI agents for the Vetify financing workflow",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "acp": "tsx src/acp.ts",
    "mcp:canton": "tsx src/mcp/canton-server.ts",
    "mcp:mono": "tsx src/mcp/mono-server.ts",
    "mcp:youverify": "tsx src/mcp/youverify-server.ts",
    "mcp:shariah": "tsx src/mcp/shariah-server.ts",
    "rag:ingest:shariah": "tsx src/rag/shariah/ingest.ts",
    "test": "tsx --test src/scoring/*.test.ts"
  },
  "dependencies": {
    "deepagents": "^1.10.5",
    "deepagents-acp": "^0.1.15",
    "@langchain/community": "^1.1.29",
    "@langchain/textsplitters": "^1.0.1",
    "faiss-node": "^0.5.1",
    "pdf-parse": "^1.1.1",
    "langchain": "^1.5.2",
    "@langchain/anthropic": "^1.5.1",
    "@langchain/openai": "^1.5.3",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/mcp-adapters": "^1.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.0.0",
    "pino": "^9.5.0",
    "zod": "^3.22.0"
