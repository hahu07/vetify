# LLM Providers
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Primary model for reasoning (Verifier, Underwriting agents)
LLM_MODEL=claude-sonnet-4-6

# Canton Ledger — JSON Ledger API (v2), migrated from the classic v1 HTTP
# JSON API (see CLAUDE.md's Application Architecture section for why).
CANTON_LEDGER_URL=http://localhost:7575
CANTON_USER_ID=vetify-agents

# JWTs authorize *that* this backend may act as a party (Authorization header).
CANTON_VETIFY_JWT=your_vetify_party_jwt_token
CANTON_VERIFIER_JWT=your_verifier_party_jwt_token

# Party IDs are the actual on-ledger identity (e.g. "Vetify::1220...") — v2's
# explicit actAs/query-filter model needs these in addition to the JWTs
# above; v1 never did, since it inferred the acting party from the token
# alone. Obtain by allocating each party once against the target participant
# (POST /v2/parties {"partyIdHint": "Vetify"}) and recording the resulting
# `party` string from the response.
CANTON_VETIFY_PARTY_ID=Vetify::...
CANTON_VERIFIER_PARTY_ID=Verifier::...

CANTON_FI_PARTY=financialInstitution
CANTON_REGULATOR_PARTY=regulator

# Backend HTTP API (backend/src/index.ts) — the Underwriting Agent polls
# GET /api/webhooks/mono/creditworthiness/:reference here, since
# assess_creditworthiness's real result is delivered via webhook to the
# backend, not returned synchronously to the agent's own tool call.
BACKEND_URL=http://localhost:3000

# Youverify — AML, PEP & Sanctions screening, KYB (Nigerian-built compliance)
YOUVERIFY_API_KEY=your_youverify_api_key
YOUVERIFY_BASE_URL=https://api.youverify.co

# mono.co KYC/financial data
MONO_API_KEY=your_mono_api_key
MONO_API_URL=https://api.withmono.com/v2

# CAC Registry (Corporate Affairs Commission)
CAC_API_KEY=your_cac_api_key
CAC_API_URL=https://api.cac.gov.ng

# NIBSS (BVN / NIN validation)
NIBSS_API_KEY=your_nibss_api_key
NIBSS_API_URL=https://api.nibss-plc.com.ng

# LangSmith (observability and tracing)
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT=vetify
LANGCHAIN_TRACING_V2=true

# Risk thresholds for Model C gating (0–100)
RISK_THRESHOLD_AUTO_APPROVE=80
RISK_THRESHOLD_AUTO_REJECT=50

# Shariah RAG — place AAOIFI/CBN PDFs in SHARIAH_DATA_PATH, then run: npm run rag:ingest:shariah
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SHARIAH_DATA_PATH=./data/shariah
SHARIAH_VECTORSTORE_PATH=./data/shariah-vectorstore
