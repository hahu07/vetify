# LLM Providers
ANTHROPIC_API_KEY=your_anthropic_api_key
OPENAI_API_KEY=your_openai_api_key

# Primary model for reasoning (Verifier, Underwriting agents)
LLM_MODEL=claude-sonnet-4-6

# LLM resilience (review gap G9): per-invocation timeout and bounded retries.
# Retries are safe by architecture — evidence gathering has no side effects
# and every downstream decision is deterministic.
LLM_TIMEOUT_MS=180000
LLM_MAX_ATTEMPTS=2

# LangSmith tracing (optional — audit finding O-3, Phase 3 Enterprise
# Production Readiness Audit, 2026-07-08: this used to also appear, active
# and uncommented, near the bottom of this file — that duplicate is gone).
# Standard LangChain env wiring, no code change needed either way. Uncomment
# all three to get a trace per agent run; leave commented to run with no
# tracing at all (the default posture today).
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=your_langsmith_api_key
# LANGSMITH_PROJECT=vetify

# Every CANTON_*_JWT below (and other secrets) also accepts the <NAME>_FILE
# convention — set e.g. CANTON_VETIFY_JWT_FILE=/run/secrets/vetify_jwt to read
# from a mounted secret file instead of inline env (review gap G2; custody
# rules in docs/secrets-custody.md).

# Canton Ledger — JSON Ledger API (v2), migrated from the classic v1 HTTP
# JSON API (see CLAUDE.md's Application Architecture section for why).
CANTON_LEDGER_URL=http://localhost:7575
CANTON_USER_ID=vetify-agents

# JWTs authorize *that* this backend may act as a party (Authorization header).
CANTON_VETIFY_JWT=your_vetify_party_jwt_token
CANTON_VERIFIER_JWT=your_verifier_party_jwt_token
# Vetify's own underwriting team (Stage 6) — same "not a third party" framing
# as verifier. Screens/qualifies businesses before Stage 7 via BeginUnderwriting/
# RejectUnderwriting, both dual-controller with vetify.
CANTON_ASSESSOR_JWT=your_assessor_party_jwt_token
# Vetify's own portfolio-monitoring team (Stage 9) — same "not a third party"
# framing as verifier/assessor. Makes the real delinquency call via
# FlagDelinquent/ResumeActive, both dual-controller with vetify.
CANTON_SENTINEL_JWT=your_sentinel_party_jwt_token
# Genuinely independent Shari'a Supervisory Board party — AAOIFI governance
# standards require independence from management, so unlike verifier/
# assessor/sentinel above, this should NOT be held by the same team that
# operates the vetify platform party in a real deployment.
CANTON_ADVISOR_JWT=your_advisor_party_jwt_token
# The Collections Agent creates FI-signed templates (DirectDebitCollectionAttempt,
# GSMInvocation) and exercises FI-controlled choices — review gap G6.
CANTON_FI_JWT=your_financial_institution_party_jwt_token

# Party IDs are the actual on-ledger identity (e.g. "Vetify::1220...") — v2's
# explicit actAs/query-filter model needs these in addition to the JWTs
# above; v1 never did, since it inferred the acting party from the token
# alone. Obtain by allocating each party once against the target participant
# (POST /v2/parties {"partyIdHint": "Vetify"}) and recording the resulting
# `party` string from the response.
CANTON_VETIFY_PARTY_ID=Vetify::...
CANTON_VERIFIER_PARTY_ID=Verifier::...
CANTON_ASSESSOR_PARTY_ID=Assessor::...
CANTON_SENTINEL_PARTY_ID=Sentinel::...
CANTON_ADVISOR_PARTY_ID=Advisor::...
# Real Party IDs, not role names — written into PortfolioReport's party-typed
# fields by the Reporting Agent. (Renamed from CANTON_FI_PARTY/
# CANTON_REGULATOR_PARTY, whose role-name defaults were a latent ledger-write
# failure — review gap G7.) Regulator is optional: leave unset for reports
# with no regulator observer.
CANTON_FI_PARTY_ID=FinancialInstitution::...
CANTON_REGULATOR_PARTY_ID=Regulator::...

# Backend HTTP API (backend/src/index.ts) — the Underwriting Agent polls
# GET /api/webhooks/mono/creditworthiness/:reference here, since
# assess_creditworthiness's real result is delivered via webhook to the
# backend, not returned synchronously to the agent's own tool call.
BACKEND_URL=http://localhost:3000

# Youverify — AML, PEP & Sanctions screening, KYB (Nigerian-built compliance)
YOUVERIFY_API_KEY=your_youverify_api_key
YOUVERIFY_BASE_URL=https://api.youverify.co

# mono.co KYC/financial data
MONO_API_KEY=your_mono_api_key
MONO_API_URL=https://api.withmono.com/v2

# CAC Registry (Corporate Affairs Commission)
CAC_API_KEY=your_cac_api_key
CAC_API_URL=https://api.cac.gov.ng

# NIBSS (BVN / NIN validation)
NIBSS_API_KEY=your_nibss_api_key
NIBSS_API_URL=https://api.nibss-plc.com.ng

# Risk thresholds for Model C gating (0–100)
RISK_THRESHOLD_AUTO_APPROVE=80
RISK_THRESHOLD_AUTO_REJECT=50

# G14 rescreen scheduler: days since an ApprovedBusiness's approvedAt before the
# Supervisor's daily sweep exercises RequestRecertification, restarting its full
# Stage 3 AML/KYB/CDD cycle. Not a specific published CBN NIFI number — a
# deliberately conservative default pending an institution's own policy.
RESCREEN_INTERVAL_DAYS=180

# Shariah RAG — place AAOIFI/CBN PDFs in SHARIAH_DATA_PATH, then run: npm run rag:ingest:shariah
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SHARIAH_DATA_PATH=./data/shariah
SHARIAH_VECTORSTORE_PATH=./data/shariah-vectorstore
